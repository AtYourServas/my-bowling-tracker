---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · MyBowlingTracker</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family: system-ui, sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        padding: 1.5rem 1rem;
        max-width: 480px;
        margin-inline: auto;
        line-height: 1.4;
      }
      h1 {
        font-size: 1.5rem;
      }
      form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 1rem;
      }
      label {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 0.9rem;
      }
      input,
      select,
      textarea {
        font-size: 1rem;
        padding: 0.6rem;
        border: 1px solid #888;
        border-radius: 6px;
        font-family: inherit;
      }
      button {
        font-size: 1rem;
        padding: 0.7rem;
        border: none;
        border-radius: 6px;
        background: #2b6cb0;
        color: white;
        cursor: pointer;
      }
      button:active {
        opacity: 0.85;
      }
      button.danger {
        background: #c53030;
      }
      button.secondary {
        background: #718096;
      }
      .error {
        color: #c53030;
        font-size: 0.9rem;
      }
      .notice {
        color: #2f855a;
        font-size: 0.9rem;
      }
      p.switch {
        font-size: 0.9rem;
        margin-top: 1rem;
      }
      a {
        color: #2b6cb0;
      }
      nav.top {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
      }
      ul.list {
        list-style: none;
        margin: 1rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .card {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        display: block;
        text-decoration: none;
        color: inherit;
      }
      .card strong {
        display: block;
        font-size: 1.05rem;
      }
      .card span {
        display: block;
        font-size: 0.85rem;
        opacity: 0.75;
      }
      .empty {
        font-size: 0.9rem;
        opacity: 0.75;
        margin-top: 1rem;
      }
      .row-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
      }
      .row-actions button,
      .row-actions a {
        flex: 1;
        text-align: center;
      }
      hr {
        border: none;
        border-top: 1px solid #ccc;
        margin: 1.5rem 0;
      }

      /* Shot logging screen */
      .frame-picker {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.4rem;
        margin: 0.75rem 0;
      }
      .frame-btn {
        display: block;
        text-align: center;
        padding: 0.6rem 0;
        border-radius: 6px;
        border: 1px solid #888;
        text-decoration: none;
        color: inherit;
        font-size: 0.95rem;
      }
      .frame-btn.active {
        background: #2b6cb0;
        color: white;
        border-color: #2b6cb0;
      }
      .reference-box {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        border: 1px dashed #888;
        border-radius: 8px;
        padding: 0.6rem 0.8rem;
        font-size: 0.85rem;
        margin-top: -0.25rem;
      }
      .reference-box strong {
        font-size: 0.9rem;
      }
      .target-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }
      .pin-shortcuts {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
      }
      .pin-shortcuts button {
        flex: 1;
        background: #718096;
      }
      .pin-shortcuts button.active {
        background: #2f855a;
      }
      .pin-hint {
        font-size: 0.8rem;
        opacity: 0.75;
        margin: 0.5rem 0 0.25rem;
        text-align: center;
      }
      .pin-rows {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }
      .pin-row {
        display: flex;
        gap: 0.5rem;
      }
      .pin {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 50%;
        border: 2px solid #888;
        background: white;
        color: #333;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
      }
      .pin.standing {
        background: #c53030;
        border-color: #c53030;
        color: white;
      }
      @media (prefers-color-scheme: dark) {
        .pin {
          background: #1a1a1a;
          color: #eee;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
