---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} · MyBowlingTracker</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family: system-ui, sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        padding: 1.5rem 1rem;
        max-width: 480px;
        margin-inline: auto;
        line-height: 1.4;
      }
      h1 {
        font-size: 1.5rem;
      }
      form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 1rem;
      }
      label {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        font-size: 0.9rem;
      }
      input,
      select,
      textarea {
        font-size: 1rem;
        padding: 0.6rem;
        border: 1px solid #888;
        border-radius: 6px;
        font-family: inherit;
      }
      button {
        font-size: 1rem;
        padding: 0.7rem;
        border: none;
        border-radius: 6px;
        background: #2b6cb0;
        color: white;
        cursor: pointer;
      }
      button:active {
        opacity: 0.85;
      }
      button.danger {
        background: #c53030;
      }
      button.secondary {
        background: #718096;
      }
      .error {
        color: #c53030;
        font-size: 0.9rem;
      }
      .notice {
        color: #2f855a;
        font-size: 0.9rem;
      }
      p.switch {
        font-size: 0.9rem;
        margin-top: 1rem;
      }
      a {
        color: #2b6cb0;
      }
      nav.top {
        display: flex;
        gap: 1rem;
        margin-bottom: 1rem;
        font-size: 0.9rem;
      }
      ul.list {
        list-style: none;
        margin: 1rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .card {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        display: block;
        text-decoration: none;
        color: inherit;
      }
      .card strong {
        display: block;
        font-size: 1.05rem;
      }
      .card span {
        display: block;
        font-size: 0.85rem;
        opacity: 0.75;
      }
      .review-link {
        display: block;
        font-size: 0.8rem;
        margin: 0.2rem 0 0;
        text-align: right;
      }
      .empty {
        font-size: 0.9rem;
        opacity: 0.75;
        margin-top: 1rem;
      }
      .row-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
      }
      .row-actions button,
      .row-actions a {
        flex: 1;
        text-align: center;
      }
      hr {
        border: none;
        border-top: 1px solid #ccc;
        margin: 1.5rem 0;
      }

      .filter-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
        margin: 0.75rem 0;
        padding: 0.75rem;
        border: 1px solid #ccc;
        border-radius: 8px;
      }
      .filter-form label {
        font-size: 0.8rem;
      }
      .filter-form button {
        grid-column: span 2;
      }
      .filter-form a {
        grid-column: span 2;
        text-align: center;
        font-size: 0.85rem;
      }
      .review-frame {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 0.6rem 0.8rem;
        margin-bottom: 0.5rem;
      }
      .review-frame h2 {
        font-size: 0.95rem;
        margin: 0 0 0.35rem;
      }
      .review-frame ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }
      .review-frame li {
        font-size: 0.85rem;
      }
      .review-frame .none {
        font-size: 0.85rem;
        opacity: 0.6;
      }

      .score-box {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-top: 0.75rem;
      }
      .score-box form {
        flex-direction: row;
        align-items: flex-end;
        gap: 0.75rem;
        margin-top: 0;
      }
      .score-box label {
        flex: 1;
      }
      .score-box .empty {
        margin: 0.5rem 0 0;
      }

      /* Shot logging screen */
      .frame-picker {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0.4rem;
        margin: 0.75rem 0;
      }
      .frame-btn {
        display: block;
        text-align: center;
        padding: 0.6rem 0;
        border-radius: 6px;
        border: 1px solid #888;
        text-decoration: none;
        color: inherit;
        font-size: 0.95rem;
      }
      .frame-btn.active {
        background: #2b6cb0;
        color: white;
        border-color: #2b6cb0;
      }
      .reference-box {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        border: 1px dashed #888;
        border-radius: 8px;
        padding: 0.6rem 0.8rem;
        font-size: 0.85rem;
        margin-top: -0.25rem;
      }
      .reference-box strong {
        font-size: 0.9rem;
      }
      .target-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
      }
      .pin-shortcuts {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.5rem;
      }
      .pin-shortcuts button {
        flex: 1;
        background: #718096;
      }
      .pin-shortcuts button.active {
        background: #2f855a;
      }
      .pin-hint {
        font-size: 0.8rem;
        opacity: 0.75;
        margin: 0.5rem 0 0.25rem;
        text-align: center;
      }
      .pin-rows {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }
      .pin-row {
        display: flex;
        gap: 0.5rem;
      }
      .pin {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 50%;
        border: 2px solid #888;
        background: white;
        color: #333;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
      }
      .pin.standing {
        background: #c53030;
        border-color: #c53030;
        color: white;
      }
      @media (prefers-color-scheme: dark) {
        .pin {
          background: #1a1a1a;
          color: #eee;
        }
      }

      /* Stats charts */
      .stats-charts {
        --text-primary: #0b0b0b;
        --text-secondary: #52514e;
        --text-muted: #898781;
        --gridline: #e1e0d9;
        --axis: #c3c2b7;
        --surface: #fcfcfb;
        --series-1: #2a78d6;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 1rem;
      }
      @media (prefers-color-scheme: dark) {
        .stats-charts {
          --text-primary: #ffffff;
          --text-secondary: #c3c2b7;
          --text-muted: #898781;
          --gridline: #2c2c2a;
          --axis: #383835;
          --surface: #1a1a1a;
          --series-1: #3987e5;
        }
      }
      .hero-stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.15rem;
        padding: 1rem;
        border: 1px solid #ccc;
        border-radius: 8px;
      }
      .hero-label {
        font-size: 0.85rem;
        color: var(--text-secondary);
      }
      .hero-value {
        font-size: 2.5rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .hero-stat-secondary {
        padding: 0.6rem;
      }
      .hero-value-secondary {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-primary);
      }
      .best-stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.6rem;
        margin-top: 0.75rem;
      }
      .best-stat {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        padding: 0.6rem;
        border: 1px solid #ccc;
        border-radius: 8px;
      }
      .best-stat-label {
        font-size: 0.8rem;
        opacity: 0.75;
      }
      .best-stat-value {
        font-size: 1.5rem;
        font-weight: 600;
      }
      .best-stat-date {
        font-size: 0.75rem;
        opacity: 0.7;
      }
      .chart-card {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 0.75rem;
        background: var(--surface);
      }
      .chart-card h2 {
        font-size: 0.95rem;
        margin: 0 0 0.5rem;
        color: var(--text-primary);
      }
      .chart-svg {
        width: 100%;
        height: auto;
        display: block;
      }
      .chart-empty {
        font-size: 0.85rem;
        color: var(--text-secondary, #777);
      }
      .chart-axis {
        stroke: var(--axis);
        stroke-width: 1;
      }
      .chart-bar {
        fill: var(--series-1);
      }
      .chart-bar.hovered {
        fill: var(--series-1);
        opacity: 0.8;
      }
      .chart-tick {
        font-size: 8px;
        fill: var(--text-muted);
      }
      .chart-line {
        stroke: var(--series-1);
        stroke-width: 2;
        stroke-linejoin: round;
        stroke-linecap: round;
      }
      .chart-dot {
        fill: var(--series-1);
      }
      .chart-dot.hovered {
        fill: var(--series-1);
        r: 5;
      }
      .chart-dot-ring {
        fill: var(--surface);
      }
      .chart-hit {
        fill: transparent;
      }
      .chart-tooltip {
        min-height: 1.2rem;
        font-size: 0.85rem;
        color: var(--text-primary);
        margin: 0.4rem 0 0;
      }
      .chart-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 0.5rem;
        font-size: 0.85rem;
      }
      .chart-table th,
      .chart-table td {
        text-align: left;
        padding: 0.3rem 0.4rem;
        border-bottom: 1px solid var(--gridline);
      }
      .stats-charts details summary {
        font-size: 0.8rem;
        cursor: pointer;
        color: var(--text-secondary);
        margin-top: 0.4rem;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
