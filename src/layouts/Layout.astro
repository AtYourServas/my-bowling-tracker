---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;

const user = Astro.locals.user;
const path = Astro.url.pathname;

// Drives the mini-scoresheet pinfall dots (see MiniScoresheet.astro) — a
// per-profile setting rather than a page-local toggle, so it applies
// everywhere a mini-scoresheet renders (dashboard, sessions list, session page).
// `theme` rides along in the same query: rendering it straight into the
// data-theme attribute below means signed-in users get the right theme in
// the initial HTML, with no localStorage round-trip (and no flash) needed --
// which also sidesteps Safari not reliably persisting localStorage writes
// across relaunches of an installed home-screen PWA.
let showPinfall = true;
let savedTheme: string | null = null;
if (user) {
  const { data: profile } = await Astro.locals.supabase
    .from('profiles')
    .select('show_pinfall, theme')
    .eq('id', user.id)
    .maybeSingle();
  showPinfall = profile?.show_pinfall ?? true;
  savedTheme = profile?.theme ?? null;
}

// Every item lives in the collapsible top menu; items with an icon also
// appear in the mobile bottom tab bar.
const navItems = [
  { href: '/sessions', label: 'Sessions', icon: '🎳' },
  { href: '/drills', label: 'Drills', icon: '🎯' },
  { href: '/balls', label: 'Balls', icon: null },
  { href: '/approaches', label: 'Approaches', icon: null },
  { href: '/leagues', label: 'Leagues', icon: null },
  { href: '/notes', label: 'Notes', icon: '📝' },
  { href: '/stats', label: 'Stats', icon: '📊' },
  { href: '/settings', label: 'Settings', icon: '⚙️' },
];
const tabItems = navItems.filter((item) => item.icon);

const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<html lang="en" data-theme={savedTheme} class:list={{ 'show-pinfall': showPinfall }}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="MyBowling" />
    <meta name="theme-color" content="#f6f5f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121211" media="(prefers-color-scheme: dark)" />
    <title>{title} · MyBowlingTracker</title>
    <ClientRouter />
    <script is:inline>
      // ClientRouter (added above) intercepts every same-origin link click and
      // form submit by default, swapping content via fetch() instead of a real
      // navigation. The game-play flow (game page + its shot editor + review
      // sub-route) depends on every navigation into or out of it being a REAL
      // browser navigation -- sw.js's networkFirstGamePage only caches on
      // `request.mode === 'navigate'` GET requests, which a ClientRouter-driven
      // fetch() swap never produces, so a soft nav into a game page would
      // silently stop refreshing its offline cache. Force a real reload
      // whenever either side of the navigation is in that flow (leaving too,
      // not just entering -- GameLogger's stateful offline write queue should
      // always get a clean teardown, not a DOM morph). Keep this pattern
      // conceptually in sync with sw.js's GAME_PAGE_PATTERN; this one is
      // intentionally broader since it also covers the shot editor and review
      // sub-routes, which the service worker itself doesn't cache but which
      // are still part of the same stateful flow.
      var GAME_FLOW_PATTERN = /^\/sessions\/[^/]+\/games\/[^/]+(\/(shots\/[^/]+|review))?\/?$/;
      document.addEventListener('astro:before-preparation', function (e) {
        if (GAME_FLOW_PATTERN.test(e.to.pathname) || GAME_FLOW_PATTERN.test(e.from.pathname)) {
          e.preventDefault();
        }
      });
    </script>
    <script is:inline>
      // Offline Phase 3: register the game-page service worker. Deferred to
      // 'load' so it never competes with first paint; harmless pre-login.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js').catch(function () {});
        });
      }
    </script>
    <script is:inline>
      // The data-theme attribute on <html> is set server-side (see Layout.astro)
      // from the signed-in user's saved profile, so there's no flash for them —
      // this script only needs to fall back to localStorage for guests, or a
      // signed-in user who hasn't picked a theme yet (profile.theme is null).
      // Either way, the theme-color metas (which key off the OS scheme) must be
      // forced to match whatever theme ends up explicit — both get that color.
      (function () {
        try {
          var root = document.documentElement;
          var t = root.getAttribute('data-theme');
          if (t !== 'dark' && t !== 'light') {
            t = localStorage.getItem('theme');
            if (t === 'dark' || t === 'light') root.setAttribute('data-theme', t);
          }
          if (t === 'dark' || t === 'light') {
            var c = t === 'dark' ? '#121211' : '#f6f5f2';
            document.querySelectorAll('meta[name="theme-color"]').forEach(function (m) {
              m.setAttribute('content', c);
            });
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle light or dark theme" transition:persist transition:name="theme-toggle">
      ☾
    </button>
    {user && (
      <header class="appbar">
        <a class="brand" href="/dashboard">🎳 MyBowlingTracker</a>
        <details class="appmenu" id="appmenu">
          <summary><span class="menu-icon" aria-hidden="true">☰</span> Menu</summary>
          <nav class="menu-panel" aria-label="Primary">
            {navItems.map((item) => (
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
            ))}
            <form class="logout" method="POST" action="/api/auth/logout" data-pending-label="Logging Out…">
              <button type="submit">Log Out</button>
            </form>
          </nav>
        </details>
      </header>
    )}
    <slot />
    <dialog id="confirm-dialog" class="confirm-dialog" transition:persist transition:name="confirm-dialog">
      <p id="confirm-dialog-message"></p>
      <div class="confirm-dialog-actions">
        <button type="button" class="secondary" data-confirm-cancel>Cancel</button>
        <button type="button" class="danger" data-confirm-ok>Delete</button>
      </div>
    </dialog>
    {user && (
      <nav class="tabbar" aria-label="Quick navigation">
        {tabItems.map((item) => (
          <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
            <span class="tab-icon" aria-hidden="true">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </nav>
    )}
    <script is:inline>
      // Close the top menu on an outside click or Escape (navigating to a new
      // page replaces #appmenu with a fresh, closed one on its own either way).
      // #appmenu is NOT transition:persist'd (its nav links' aria-current must
      // re-render per page), so it gets swapped for a new DOM node on every
      // ClientRouter navigation -- look it up fresh on each event instead of
      // capturing it once, or these listeners would end up checking a stale,
      // detached node after the first soft navigation.
      (function () {
        document.addEventListener('click', function (e) {
          var menu = document.getElementById('appmenu');
          if (menu && menu.open && e.target instanceof Node && !menu.contains(e.target)) menu.open = false;
        });
        document.addEventListener('keydown', function (e) {
          if (e.key !== 'Escape') return;
          var menu = document.getElementById('appmenu');
          if (menu) menu.open = false;
        });
      })();
    </script>
    <script is:inline>
      // Forms marked data-confirm="message" get a styled <dialog> instead of
      // the browser's native confirm() before actually submitting. The OK
      // button defaults to a red "Delete" (most uses are destructive); a form
      // can override it with data-confirm-label="…" and data-confirm-style="secondary"
      // for a non-destructive confirm (e.g. "End Practice").
      (function () {
        var dialog = document.getElementById('confirm-dialog');
        var message = document.getElementById('confirm-dialog-message');
        var okButton = dialog && dialog.querySelector('[data-confirm-ok]');
        if (!dialog || !message || !okButton) return;
        var pendingForm = null;

        document.addEventListener(
          'submit',
          function (e) {
            var form = e.target;
            if (!(form instanceof HTMLFormElement)) return;
            var text = form.getAttribute('data-confirm');
            if (!text || form.hasAttribute('data-confirm-bypass')) return;
            e.preventDefault();
            pendingForm = form;
            message.textContent = text;
            okButton.textContent = form.getAttribute('data-confirm-label') || 'Delete';
            okButton.className = form.getAttribute('data-confirm-style') || 'danger';
            dialog.showModal();
          },
          true
        );

        dialog.querySelector('[data-confirm-cancel]').addEventListener('click', function () {
          pendingForm = null;
          dialog.close();
        });
        dialog.querySelector('[data-confirm-ok]').addEventListener('click', function () {
          var form = pendingForm;
          pendingForm = null;
          dialog.close();
          if (form) {
            form.setAttribute('data-confirm-bypass', '');
            form.requestSubmit();
          }
        });
        dialog.addEventListener('cancel', function () {
          pendingForm = null;
        });
      })();
    </script>
    <script is:inline>
      // A full-page POST gives no feedback until the server answers — on
      // submit, disable the form's submit buttons and relabel the tapped one
      // "Saving…" (override via data-pending-label) so slow connections don't
      // read as a dead tap or invite double-taps. Skips submits something else
      // intercepted (the confirm dialog's first pass, the game page's fetch
      // retry path — those own their own feedback) and GET filter forms.
      (function () {
        var SUBMITS = 'button[type="submit"], button:not([type]), input[type="submit"]';

        document.addEventListener('submit', function (e) {
          var form = e.target;
          if (!(form instanceof HTMLFormElement) || e.defaultPrevented) return;
          if ((form.getAttribute('method') || 'get').toLowerCase() !== 'post') return;
          if (form.hasAttribute('data-pending')) { e.preventDefault(); return; }
          form.setAttribute('data-pending', '');
          var label = form.getAttribute('data-pending-label') || 'Saving…';
          var target = e.submitter instanceof HTMLButtonElement
            ? e.submitter
            : form.querySelector('button[type="submit"], button:not([type])');
          // Deferred a tick so the submitting button's own name/value still posts.
          setTimeout(function () {
            form.querySelectorAll(SUBMITS).forEach(function (b) { b.disabled = true; });
            if (target) {
              target.setAttribute('data-label', target.textContent || '');
              target.textContent = label;
            }
          }, 0);
        });

        // Back/forward can restore a page from bfcache frozen in the pending
        // state — reset so its forms are usable again.
        window.addEventListener('pageshow', function (e) {
          if (!e.persisted) return;
          document.querySelectorAll('form[data-pending]').forEach(function (form) {
            form.removeAttribute('data-pending');
            form.querySelectorAll(SUBMITS).forEach(function (b) { b.disabled = false; });
            form.querySelectorAll('[data-label]').forEach(function (b) {
              b.textContent = b.getAttribute('data-label');
              b.removeAttribute('data-label');
            });
          });
        });
      })();
    </script>
    <script>
      // Offline Phase 3: a service worker now caches this device's most
      // recent copy of any visited game page (the "bowling-game-*" caches in
      // sw.js -- matched by prefix, not an exact name, so this doesn't need
      // updating every time sw.js bumps CACHE_VERSION) plus the IndexedDB
      // write queue/reference cache (Phase 2). Both hold one user's personal
      // data, so clear them on logout -- but only when nothing is still
      // waiting to sync, so a shared-device logout can never silently
      // discard an unsynced offline shot.
      import { hasQueuedWrites, clearAllOfflineData } from '../lib/offlineQueue';

      const GAME_CACHE_PREFIX = 'bowling-game-';

      document.addEventListener(
        'submit',
        async function (e) {
          const form = e.target;
          if (!(form instanceof HTMLFormElement) || !form.classList.contains('logout')) return;
          if (form.hasAttribute('data-offline-cleanup-bypass')) return;
          e.preventDefault();
          try {
            if (!(await hasQueuedWrites())) {
              if ('caches' in window) {
                const names = await caches.keys();
                await Promise.all(names.filter((n) => n.startsWith(GAME_CACHE_PREFIX)).map((n) => caches.delete(n)));
              }
              await clearAllOfflineData();
            }
          } catch (err) {
            // Best-effort only -- never block logout on a cache/IndexedDB failure.
          }
          form.setAttribute('data-offline-cleanup-bypass', '');
          form.requestSubmit();
        },
        true
      );
    </script>
    <script is:inline>
      (function () {
        var root = document.documentElement;
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function isDark() {
          var t = root.getAttribute('data-theme');
          return t ? t === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        }
        function render() { btn.textContent = isDark() ? '☀' : '☾'; }
        btn.addEventListener('click', function () {
          var next = isDark() ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
          var c = next === 'dark' ? '#121211' : '#f6f5f2';
          document.querySelectorAll('meta[name="theme-color"]').forEach(function (m) {
            m.setAttribute('content', c);
          });
          render();
          // localStorage is just an instant local echo -- the profile row is
          // the durable copy (see 0026_theme_preference.sql), since Safari
          // doesn't reliably persist localStorage across relaunches of an
          // installed home-screen PWA. Always attempt the save rather than
          // gating on a signed-in flag read off this button's own markup --
          // it has transition:persist, so that markup can be stale (e.g.
          // right after a client-router-soft-navigated login) even though
          // the user is in fact signed in. The endpoint 401s harmlessly for
          // guests. Fire-and-forget: a failed save just means next load
          // falls back to whatever was already saved.
          fetch('/api/profile/theme', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ theme: next }),
          }).catch(function () {});
        });
        render();
      })();
    </script>
  </body>
</html>
