---
import type { NoteEntry } from '../lib/notes';

interface Props {
  note: NoteEntry;
}

const { note } = Astro.props;

// Server-side fallback (UTC on Vercel); the script below rewrites it to the
// viewer's local timezone once hydrated.
const fallback = new Date(note.createdAt).toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
});
---

<article class="note">
  {(note.link || note.result) && (
    <div class="note-head">
      {note.link && <a class="note-loc" href={note.link.href}>{note.link.label} &rarr;</a>}
      {note.result && <span class="note-tag">{note.result}</span>}
    </div>
  )}
  <time class="note-time" datetime={note.createdAt} data-note-time>{fallback}</time>
  <p class="note-body">{note.body}</p>
  {note.details && (
    <ul class="note-details">
      {note.details.map((d) => (
        <li>
          <span class="dico" aria-hidden="true">{d.icon}</span>
          <span class="dlabel">{d.label}</span>
          <span class="dval">{d.value}</span>
        </li>
      ))}
    </ul>
  )}
  <slot />
</article>

<style>
  .note {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0.6rem 0.75rem;
  }
  .note-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }
  .note-loc {
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .note-tag {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    background: var(--surface-sunk);
    border-radius: var(--radius-sm);
    padding: 0.05rem 0.4rem;
    white-space: nowrap;
  }
  .note-time {
    display: block;
    color: var(--text-muted);
    font-size: var(--text-sm);
    margin-bottom: 0.35rem;
  }
  .note-body {
    margin: 0;
    white-space: pre-wrap;
  }
  .note-details {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.2rem;
  }
  .note-details li {
    display: grid;
    grid-template-columns: 1.4rem 5.2rem 1fr;
    align-items: baseline;
    gap: 0.4rem;
    font-size: var(--text-sm);
  }
  .note-details .dico {
    text-align: center;
  }
  .note-details .dlabel {
    color: var(--text-muted);
  }
  .note-details .dval {
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }
</style>

<script>
  // created_at is stored UTC; render each note time in the viewer's local zone.
  for (const el of document.querySelectorAll('time[data-note-time]')) {
    const iso = el.getAttribute('datetime');
    if (!iso) continue;
    const d = new Date(iso);
    if (!isNaN(d.getTime())) {
      el.textContent = d.toLocaleString(undefined, {
        month: 'short',
        day: 'numeric',
        hour: 'numeric',
        minute: '2-digit',
      });
    }
  }
</script>
