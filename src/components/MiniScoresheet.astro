---
import type { FrameCell, FramePinfall } from '../lib/scoring';

interface Props {
  cells: FrameCell[];
  pinfall: FramePinfall[];
  label?: string;
}
const { cells, pinfall, label } = Astro.props;

// Same corner-box rule as the game page: a struck frame (1-9) shows the X
// alone in the top-right corner, dropping the placeholder empty 2nd-ball box.
function displayBalls(cell: FrameCell) {
  return cell.frameNumber < 10 && cell.balls[0]?.kind === 'strike'
    ? cell.balls.slice(0, 1)
    : cell.balls;
}

const PIN_ROWS = [
  [7, 8, 9, 10],
  [4, 5, 6],
  [2, 3],
  [1],
];

// Which ball took a pin down (or it's still standing / unbowled), for the dots.
function pinState(pf: FramePinfall, p: number): 'unbowled' | 'down1' | 'down2' | 'standing' {
  const { leave1, leave2 } = pf;
  if (leave1 == null) return 'unbowled';
  if (!leave1.includes(p)) return 'down1'; // fell on the first ball
  if (leave2 != null && !leave2.includes(p)) return 'down2'; // picked up on the second ball
  return 'standing'; // still up after the frame's throws
}
---

<div class="mini-sheet-wrap">
  <div class="mini-sheet" aria-label={label ? `${label} scoresheet` : 'Scoresheet'}>
    {cells.map((cell) => {
      const pf = pinfall[cell.frameNumber - 1];
      return (
        <div class:list={['mcell', { f10: cell.frameNumber === 10 }]}>
          <div class="mfnum">{cell.frameNumber}</div>
          <div class="mballs">
            {displayBalls(cell).map((b) => (
              <span class:list={['mbox', { strike: b.kind === 'strike', spare: b.kind === 'spare', foul: b.kind === 'foul', empty: b.kind === 'empty' }]}>{b.text}</span>
            ))}
          </div>
          <div class:list={['mtotal', { blank: cell.cumulative == null }]}>{cell.cumulative ?? ''}</div>
          <div class="mini-pinfall" aria-hidden="true">
            {PIN_ROWS.map((row) => (
              <div class="pf-row">
                {row.map((p) => <span class:list={['pf-dot', pinState(pf, p)]}></span>)}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</div>

<style>
  .mini-sheet-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-top: var(--s2);
  }
  .mini-sheet {
    display: flex;
    min-width: max-content;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .mcell {
    width: 36px;
    flex: none;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .mcell.f10 { width: 54px; }
  .mcell:last-child { border-right: none; }

  /* fixed-height rows so the marks / totals / pinfall line up across every frame */
  .mfnum {
    height: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--text-muted);
    background: var(--surface-sunk);
    border-bottom: 1px solid var(--border);
  }
  .mballs {
    height: 17px;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding: 2px 3px 0;
  }
  .mbox {
    box-sizing: border-box;
    width: 13px;
    height: 13px;
    border: 1px solid var(--border);
    border-left: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-primary);
  }
  .mbox:first-child { border-left: 1px solid var(--border); }
  .mbox.strike { color: var(--strike-ink); background: var(--mustard-weak); font-weight: var(--fw-semi); }
  .mbox.spare { color: var(--spare-ink); background: var(--mustard-weak); font-weight: var(--fw-semi); }
  .mbox.foul { color: var(--coral); font-weight: var(--fw-semi); }
  .mbox.empty { color: var(--text-muted); }
  .mtotal {
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: var(--fw-semi);
    font-variant-numeric: tabular-nums;
  }
  .mtotal.blank { color: var(--border-strong); }

  /* Pinfall row — hidden until the session-wide "Show Pinfall" toggle is on. */
  .mini-pinfall {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 1.5px;
    padding: 3px 0 4px;
    border-top: 1px dashed var(--border);
  }
  :global(html.show-pinfall) .mini-pinfall { display: flex; }
  .pf-row { display: flex; gap: 1.5px; }
  .pf-dot {
    box-sizing: border-box;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--border-strong);
  }
  .pf-dot.standing { background: var(--coral); }
  .pf-dot.down2 { background: var(--good); }
  .pf-dot.down1 { background: var(--border-strong); opacity: 0.4; }
  .pf-dot.unbowled { background: transparent; border: 1px solid var(--border); }
</style>
