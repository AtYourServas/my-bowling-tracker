---
import type { FrameCell } from '../lib/scoring';

interface Props {
  cells: FrameCell[];
  firstBallLeave: (number[] | null)[];
  label?: string;
}
const { cells, firstBallLeave, label } = Astro.props;

// Same corner-box rule as the game page: a struck frame (1-9) shows the X
// alone in the top-right corner, dropping the placeholder empty 2nd-ball box.
function displayBalls(cell: FrameCell) {
  return cell.frameNumber < 10 && cell.balls[0]?.kind === 'strike'
    ? cell.balls.slice(0, 1)
    : cell.balls;
}

const PIN_ROWS = [
  [7, 8, 9, 10],
  [4, 5, 6],
  [2, 3],
  [1],
];
---

<div class="mini-sheet-wrap">
  <div class="mini-sheet" aria-label={label ? `${label} scoresheet` : 'Scoresheet'}>
    {cells.map((cell) => {
      const leave = firstBallLeave[cell.frameNumber - 1];
      return (
        <div class:list={['mcell', { f10: cell.frameNumber === 10 }]}>
          <div class="mballs">
            {displayBalls(cell).map((b) => (
              <span class:list={['mbox', { strike: b.kind === 'strike', spare: b.kind === 'spare', foul: b.kind === 'foul', empty: b.kind === 'empty' }]}>{b.text}</span>
            ))}
          </div>
          <div class:list={['mtotal', { blank: cell.cumulative == null }]}>{cell.cumulative ?? ''}</div>
          <div class="mini-pinfall" aria-hidden="true">
            {PIN_ROWS.map((row) => (
              <div class="pf-row">
                {row.map((p) => (
                  <span class:list={['pf-dot', { standing: leave != null && leave.includes(p), down: leave != null && !leave.includes(p), unbowled: leave == null }]}></span>
                ))}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</div>

<style>
  .mini-sheet-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-top: var(--s2);
  }
  .mini-sheet {
    display: flex;
    min-width: max-content;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .mcell {
    width: 34px;
    flex: none;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
  }
  .mcell.f10 { width: 48px; }
  .mcell:last-child { border-right: none; }
  .mballs {
    display: flex;
    justify-content: flex-end;
    padding: 2px 2px 0;
    min-height: 15px;
  }
  .mbox {
    min-width: 11px;
    height: 13px;
    padding: 0 1px;
    border: 1px solid var(--border);
    border-left: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-primary);
  }
  .mbox:first-child { border-left: 1px solid var(--border); }
  .mbox.strike { color: var(--strike-ink); background: var(--mustard-weak); font-weight: var(--fw-semi); }
  .mbox.spare { color: var(--spare-ink); background: var(--mustard-weak); font-weight: var(--fw-semi); }
  .mbox.foul { color: var(--coral); font-weight: var(--fw-semi); }
  .mbox.empty { color: var(--text-muted); }
  .mtotal {
    text-align: center;
    font-size: 0.72rem;
    font-weight: var(--fw-semi);
    font-variant-numeric: tabular-nums;
    padding: 1px 0 2px;
  }
  .mtotal.blank { color: var(--border-strong); }

  /* Pinfall row — hidden until the session-wide "Show Pinfall" toggle is on. */
  .mini-pinfall {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 1.5px;
    padding: 3px 0 4px;
    border-top: 1px dashed var(--border);
  }
  :global(html.show-pinfall) .mini-pinfall { display: flex; }
  .pf-row { display: flex; gap: 1.5px; }
  .pf-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--border-strong);
  }
  .pf-dot.standing { background: var(--coral); }
  .pf-dot.down { background: var(--border-strong); opacity: 0.4; }
  .pf-dot.unbowled { background: transparent; box-shadow: inset 0 0 0 1px var(--border); }
</style>
