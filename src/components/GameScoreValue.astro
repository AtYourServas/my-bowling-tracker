---
interface Props {
  primary: number | null; // scratch score
  handicap: number | null; // scratch + session handicap, when available
}
const { primary, handicap } = Astro.props;
---

{
  primary == null ? (
    <div class="game-card-score none">&mdash;</div>
  ) : handicap == null ? (
    <div class="game-card-score">{primary}</div>
  ) : (
    <div class="game-card-scores">
      <div class="score-stat">
        <span class="score-stat-label">Scratch</span>
        <span class="score-stat-value">{primary}</span>
      </div>
      <div class="score-stat">
        <span class="score-stat-label">Hdcp</span>
        <span class="score-stat-value">{handicap}</span>
      </div>
    </div>
  )
}
