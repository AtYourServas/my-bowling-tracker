---
import Layout from '../../layouts/Layout.astro';
import { laneLabel, laneConfigFromSession } from '../../lib/lanes';

const { supabase, user } = Astro.locals;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const alley_name = formData.get('alley_name')?.toString().trim() || null;
  const laneRaw = formData.get('lane_number')?.toString().trim();
  const lane_number = laneRaw ? Number(laneRaw) : null;
  const secondLaneRaw = formData.get('second_lane_number')?.toString().trim();
  const second_lane_number = secondLaneRaw ? Number(secondLaneRaw) : null;
  const session_type = formData.get('session_type')?.toString();
  const session_date = formData.get('session_date')?.toString() || new Date().toISOString().slice(0, 10);
  const lane_condition_notes = formData.get('lane_condition_notes')?.toString().trim() || null;
  const league_team_name = formData.get('league_team_name')?.toString().trim() || null;
  const league_id = formData.get('league_id')?.toString() || null;
  const manualHandicapRaw = formData.get('manual_handicap')?.toString().trim();
  const manual_handicap = manualHandicapRaw ? Number(manualHandicapRaw) : null;

  if (session_type !== 'league' && session_type !== 'practice') {
    error = 'Session type is required.';
  } else {
    // a league session with no team typed inherits the league's team name
    let effectiveTeamName = session_type === 'league' ? league_team_name : null;
    if (session_type === 'league' && league_id && !effectiveTeamName) {
      const { data: league } = await supabase
        .from('leagues')
        .select('team_name')
        .eq('id', league_id)
        .maybeSingle();
      effectiveTeamName = league?.team_name ?? null;
    }

    const { data, error: insertError } = await supabase
      .from('sessions')
      .insert({
        user_id: user!.id,
        alley_name,
        lane_number,
        second_lane_number,
        session_type,
        session_date,
        lane_condition_notes,
        league_team_name: effectiveTeamName,
        league_id: session_type === 'league' ? league_id : null,
        manual_handicap: session_type === 'league' ? manual_handicap : null,
      })
      .select('id')
      .single();

    if (insertError) {
      error = insertError.message;
    } else {
      return Astro.redirect(`/sessions/${data.id}`);
    }
  }
}

const params = Astro.url.searchParams;
const filterType = params.get('type') ?? '';
const filterAlley = params.get('alley') ?? '';
const filterFrom = params.get('from') ?? '';
const filterTo = params.get('to') ?? '';
const hasFilters = Boolean(filterType || filterAlley || filterFrom || filterTo);

let sessionsQuery = supabase
  .from('sessions')
  .select('*, leagues(name)')
  .order('session_date', { ascending: false })
  .order('created_at', { ascending: false });

if (filterType === 'league' || filterType === 'practice') {
  sessionsQuery = sessionsQuery.eq('session_type', filterType);
}
if (filterAlley) {
  sessionsQuery = sessionsQuery.eq('alley_name', filterAlley);
}
if (filterFrom) {
  sessionsQuery = sessionsQuery.gte('session_date', filterFrom);
}
if (filterTo) {
  sessionsQuery = sessionsQuery.lte('session_date', filterTo);
}

const { data: sessions } = await sessionsQuery;

const { data: alleyRows } = await supabase.from('sessions').select('alley_name').not('alley_name', 'is', null);
const alleyOptions = Array.from(new Set((alleyRows ?? []).map((r) => r.alley_name))).sort();

const { data: leagues } = await supabase.from('leagues').select('id, name, team_name').order('name');
---

<Layout title="Sessions">
  <nav class="top"><a href="/dashboard">&larr; Dashboard</a></nav>
  <h1>Sessions</h1>

  {error && <p class="error">{error}</p>}

  <form method="GET" class="filter-form">
    <label>
      Type
      <select name="type">
        <option value="" selected={!filterType}>All</option>
        <option value="league" selected={filterType === 'league'}>League</option>
        <option value="practice" selected={filterType === 'practice'}>Practice</option>
      </select>
    </label>
    <label>
      Alley
      <select name="alley">
        <option value="">All</option>
        {alleyOptions.map((alley) => (
          <option value={alley} selected={alley === filterAlley}>{alley}</option>
        ))}
      </select>
    </label>
    <label>
      From
      <input type="date" name="from" value={filterFrom} />
    </label>
    <label>
      To
      <input type="date" name="to" value={filterTo} />
    </label>
    <button type="submit">Filter</button>
    {hasFilters && <a href="/sessions">Clear filters</a>}
  </form>

  {sessions && sessions.length > 0 ? (
    <ul class="list">
      {sessions.map((session) => (
        <li>
          <a class="card" href={`/sessions/${session.id}`}>
            <strong>{session.alley_name || 'Unnamed alley'} {laneLabel(laneConfigFromSession(session)) ? `· ${laneLabel(laneConfigFromSession(session))}` : ''}</strong>
            <span>
              {session.session_date} · {session.session_type === 'league' ? 'League' : 'Practice'}
              {session.leagues?.name ? ` · ${session.leagues.name}` : ''}
            </span>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">{hasFilters ? 'No sessions match those filters.' : 'No sessions yet — start one below.'}</p>
  )}

  <hr />

  <h1>Start a session</h1>
  <form method="POST">
    <label>
      Alley name
      <input type="text" name="alley_name" />
    </label>
    <label>
      Starting lane
      <input type="number" name="lane_number" min="1" />
    </label>
    <label>
      Second lane (optional — for a two-lane pair)
      <input type="number" name="second_lane_number" min="1" placeholder="alternates each frame" />
    </label>
    <label>
      Date
      <input type="date" name="session_date" value={new Date().toISOString().slice(0, 10)} />
    </label>
    <label>
      Session type
      <select name="session_type" required>
        <option value="league">League</option>
        <option value="practice">Practice</option>
      </select>
    </label>
    <label>
      League (if league)
      <select name="league_id">
        <option value="" data-team="">None</option>
        {leagues?.map((league) => (
          <option value={league.id} data-team={league.team_name ?? ''}>{league.name}</option>
        ))}
      </select>
    </label>
    <label>
      Team name (if league)
      <input type="text" name="league_team_name" placeholder="Fills from the league — edit to override" />
    </label>
    <label>
      Handicap override (optional — overrides the league's calculated handicap)
      <input type="number" name="manual_handicap" />
    </label>
    <label>
      Lane condition notes
      <textarea name="lane_condition_notes" rows="2" placeholder="e.g. fresh oil, breaking down"></textarea>
    </label>
    <button type="submit">Start session</button>
  </form>
</Layout>

<script>
  // Selecting a league fills the team-name field from that league, while
  // leaving any name the user has typed themselves untouched (override).
  const leagueSelect = document.querySelector<HTMLSelectElement>('select[name="league_id"]');
  const teamInput = document.querySelector<HTMLInputElement>('input[name="league_team_name"]');
  if (leagueSelect && teamInput) {
    let autoValue = teamInput.value;
    leagueSelect.addEventListener('change', () => {
      const team = leagueSelect.selectedOptions[0]?.dataset.team ?? '';
      if (teamInput.value === '' || teamInput.value === autoValue) {
        teamInput.value = team;
        autoValue = team;
      }
    });
  }
</script>
