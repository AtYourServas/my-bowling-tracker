---
import Layout from '../../layouts/Layout.astro';
import GameScoreValue from '../../components/GameScoreValue.astro';
import MiniScoresheet from '../../components/MiniScoresheet.astro';
import { fetchDerivedScoreForGame, fetchMiniScoresheets, fetchWarmupFrames } from '../../lib/scoring';
import type { MiniSheet } from '../../lib/scoring';
import { fetchSessionHandicapDetail } from '../../lib/handicap';
import { fetchSessionLaneStats, fetchSessionStatFrames, computeSessionRates, computeGameRates } from '../../lib/stats';
import { laneLabel, laneConfigFromSession, hasLanePair } from '../../lib/lanes';
import { fetchSessionNotes } from '../../lib/notes';
import NoteCard from '../../components/NoteCard.astro';

const { supabase, user } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete_session') {
    const { error: deleteError } = await supabase.from('sessions').delete().eq('id', id);

    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/sessions');
    }
  } else if (intent === 'set_league') {
    const league_id = formData.get('league_id')?.toString() || null;
    const manualHandicapRaw = formData.get('manual_handicap')?.toString().trim();
    const manual_handicap = manualHandicapRaw ? Number(manualHandicapRaw) : null;

    const { error: updateError } = await supabase
      .from('sessions')
      .update({ league_id, manual_handicap })
      .eq('id', id);

    if (updateError) {
      error = updateError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'edit_lanes') {
    const laneRaw = formData.get('lane_number')?.toString().trim();
    const lane_number = laneRaw ? Number(laneRaw) : null;
    const secondLaneRaw = formData.get('second_lane_number')?.toString().trim();
    const second_lane_number = secondLaneRaw ? Number(secondLaneRaw) : null;

    const { error: laneError } = await supabase
      .from('sessions')
      .update({ lane_number, second_lane_number })
      .eq('id', id);

    if (laneError) {
      error = laneError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'edit_balls') {
    const default_ball_id = formData.get('default_ball_id')?.toString() || null;
    const default_spare_ball_id = formData.get('default_spare_ball_id')?.toString() || null;

    const { error: ballError } = await supabase
      .from('sessions')
      .update({ default_ball_id, default_spare_ball_id })
      .eq('id', id);

    if (ballError) {
      error = ballError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'set_game_score') {
    const gameId = formData.get('game_id')?.toString();
    const raw = formData.get('final_score')?.toString().trim();
    const final_score = raw ? Number(raw) : null;

    const { error: scoreError } = await supabase
      .from('games')
      .update({ final_score })
      .eq('id', gameId)
      .eq('session_id', id);

    if (scoreError) {
      error = scoreError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'add_note') {
    const body = formData.get('body')?.toString().trim();

    if (body) {
      const { error: noteError } = await supabase
        .from('session_notes')
        .insert({ user_id: user!.id, session_id: id, body });
      if (noteError) error = noteError.message;
      else return Astro.redirect(`/sessions/${id}?view=notes`);
    } else {
      return Astro.redirect(`/sessions/${id}?view=notes`);
    }
  } else if (intent === 'edit_note') {
    const noteId = formData.get('note_id')?.toString();
    const body = formData.get('body')?.toString().trim();

    if (noteId && body) {
      const { error: noteError } = await supabase
        .from('session_notes')
        .update({ body })
        .eq('id', noteId);
      if (noteError) error = noteError.message;
      else return Astro.redirect(`/sessions/${id}?view=notes`);
    } else {
      return Astro.redirect(`/sessions/${id}?view=notes`);
    }
  } else if (intent === 'delete_note') {
    const noteId = formData.get('note_id')?.toString();

    const { error: noteError } = await supabase.from('session_notes').delete().eq('id', noteId);
    if (noteError) error = noteError.message;
    else return Astro.redirect(`/sessions/${id}?view=notes`);
  } else {
    const slot = formData.get('slot')?.toString();
    const action = formData.get('action')?.toString();
    const rawScore = formData.get('final_score')?.toString().trim();
    // "Add & log throws" starts an empty game and opens the logger; "Add with
    // score" saves the typed score (if any) and stays on the session.
    const final_score = action === 'log' ? null : rawScore ? Number(rawScore) : null;

    const gameToInsert: Record<string, unknown> = { session_id: id, final_score };

    if (slot === 'practice') {
      gameToInsert.is_practice = true;
      gameToInsert.game_number = null;
    } else if (slot === 'game1' || slot === 'game2' || slot === 'game3') {
      gameToInsert.is_practice = false;
      gameToInsert.game_number = Number(slot.replace('game', ''));
    } else {
      // Freeform game for a standalone practice session.
      gameToInsert.is_practice = false;
      gameToInsert.game_number = null;
    }

    const { data, error: insertError } = await supabase
      .from('games')
      .insert(gameToInsert)
      .select('id')
      .single();

    if (insertError) {
      error = insertError.message;
    } else {
      return Astro.redirect(action === 'log' ? `/sessions/${id}/games/${data.id}` : `/sessions/${id}`);
    }
  }
}

const { data: session, error: sessionError } = await supabase
  .from('sessions')
  .select('*, leagues(name)')
  .eq('id', id)
  .maybeSingle();

if (sessionError) {
  throw new Error(`Failed to load session: ${sessionError.message}`);
}

if (!session) {
  return Astro.redirect('/sessions');
}

// Tabbed views keep the entry path (Games) front and centre; Stats and Notes
// each fetch their data only when shown.
const viewParam = Astro.url.searchParams.get('view');
const view: 'games' | 'stats' | 'notes' = viewParam === 'stats' || viewParam === 'notes' ? viewParam : 'games';

const handicap = await fetchSessionHandicapDetail(supabase, session);
const sessionHandicap = handicap.effective;
const leagueName = session.leagues?.name ?? null;

const laneConfig = laneConfigFromSession(session);
const { data: leagues } = await supabase.from('leagues').select('id, name').order('name');
const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const ballName = (ballId: string | null) => balls?.find((b) => b.id === ballId)?.name ?? null;
const defaultBallSummary =
  [ballName(session.default_ball_id), ballName(session.default_spare_ball_id) && `spare ${ballName(session.default_spare_ball_id)}`]
    .filter(Boolean)
    .join(' · ') || 'Not set';

const { data: games } = await supabase
  .from('games')
  .select('*')
  .eq('session_id', id)
  .order('created_at', { ascending: true });

// The slot label the games list uses for a game (league night vs freeform).
function gameLabel(game: { is_practice: boolean; game_number: number | null }, index: number): string {
  if (session.session_type !== 'league') return `Game ${index + 1}`;
  return game.is_practice ? 'Practice' : game.game_number ? `Game ${game.game_number}` : 'Game';
}

// Games view: derived scores + per-game marks/score strips (+ first-ball pinfall).
// The Practice slot (is_practice) is excluded -- it's an uncapped warmup with its own
// dedicated summary below, and these are all fixed-at-10-frames computations.
const scoredGames = (games ?? []).filter((g) => !g.is_practice);
const derivedScores = new Map<string, number | null>(
  view === 'games'
    ? await Promise.all(scoredGames.map(async (g) => [g.id, await fetchDerivedScoreForGame(supabase, g.id)] as const))
    : [],
);
const miniSheets = view === 'games' ? await fetchMiniScoresheets(supabase, scoredGames.map((g) => g.id)) : new Map<string, MiniSheet>();
const miniSheet = (gameId: string) => {
  const mini = miniSheets.get(gameId);
  return mini && mini.cells.some((c) => c.bowled) ? mini : null;
};

// The most recent game mid-bowl (frames logged, 10th unresolved, no saved
// score) — the "Resume" fast path back into the logger, which reopens on the
// earliest incomplete frame.
const inProgress =
  view === 'games'
    ? [...(games ?? [])].reverse().find((g) => {
        if (g.final_score != null) return false;
        const mini = miniSheets.get(g.id);
        return !!mini && mini.cells.some((c) => c.bowled) && mini.cells[9]?.cumulative == null;
      })
    : undefined;
const inProgressLabel = inProgress ? gameLabel(inProgress, (games ?? []).indexOf(inProgress)) : null;

function gameScore(game: { id: string; final_score: number | null; ended_early: boolean }) {
  const derived = derivedScores.get(game.id) ?? null;
  const scratch = game.final_score ?? derived;

  if (scratch == null) {
    return { primary: null as number | null, handicap: null as number | null, detail: 'No score yet' };
  }

  let detail = '';
  if (game.ended_early) {
    // last frame with any roll logged, not the last one with a fully-resolved
    // cumulative -- a trailing unresolved strike/spare bonus shouldn't hide
    // how far the game actually got
    const lastBowled = [...(miniSheets.get(game.id)?.cells ?? [])].reverse().find((c) => c.bowled);
    detail = lastBowled ? `through frame ${lastBowled.frameNumber}` : 'ended early';
  } else if (game.final_score != null && derived != null && derived !== game.final_score) {
    detail = `derived ${derived}`;
  } else if (game.final_score == null && derived != null) {
    detail = 'derived';
  }

  const handicap = sessionHandicap != null ? scratch + sessionHandicap : null;

  return { primary: scratch, handicap, detail };
}

// Stats view: session + per-game rates (classified exactly like /stats) and
// the per-lane breakdown, all off one scoped frames fetch.
const sessionFrames = view === 'stats' ? await fetchSessionStatFrames(supabase, id!) : [];
const sessionRates = view === 'stats' ? computeSessionRates(sessionFrames) : null;
const gameRateRows = (view === 'stats' ? (games ?? []) : []).flatMap((game, i) => {
  const rates = computeGameRates(sessionFrames, game.id);
  return rates ? [{ label: gameLabel(game, i), rates }] : [];
});
const laneStats =
  view === 'stats' && hasLanePair(laneConfig) ? await fetchSessionLaneStats(supabase, id!, laneConfig) : [];

// "62%" for 62/118, an em dash when there have been no opportunities — the
// same formatting as the stats page's rate tiles.
function formatRate(made: number, opportunities: number): string {
  if (opportunities === 0) return '—';
  return `${Math.round((made / opportunities) * 100)}%`;
}

const notes = view === 'notes' ? await fetchSessionNotes(supabase, id!) : [];

const practiceGame = games?.find((g) => g.is_practice);
// Practice's shot count -- an uncapped warmup has no score, so this (not a
// mini-scoresheet) is its whole summary on the games list.
const practiceShotCount =
  view === 'games' && practiceGame
    ? (await fetchWarmupFrames(supabase, practiceGame.id)).reduce((n, f) => n + f.shots.length, 0)
    : 0;
const game1 = games?.find((g) => g.game_number === 1);
const game2 = games?.find((g) => g.game_number === 2);
const game3 = games?.find((g) => g.game_number === 3);

const leagueSlots = [
  { key: 'game1', label: 'Game 1', game: game1 },
  { key: 'game2', label: 'Game 2', game: game2 },
  { key: 'game3', label: 'Game 3', game: game3 },
];

const setupSummary = [leagueName, laneLabel(laneConfig)].filter(Boolean).join(' · ') || 'Not set';
---

<Layout title={session.alley_name || 'Session'}>
  <nav class="top"><a href="/sessions">&larr; Sessions</a></nav>
  <h1>{session.alley_name || 'Unnamed alley'}{laneLabel(laneConfig) ? ` · ${laneLabel(laneConfig)}` : ''}</h1>
  <p class="empty">
    {session.session_date} · {session.session_type === 'league' ? 'League' : 'Practice'}
    {leagueName ? ` · ${leagueName}` : ''}
    {session.league_team_name ? ` · ${session.league_team_name}` : ''}
  </p>
  {session.lane_condition_notes && <p class="empty">Lane: {session.lane_condition_notes}</p>}

  {error && <p class="error">{error}</p>}

  <div class="entry-toggle session-tabs" role="group" aria-label="Session view">
    <a class:list={['seg', { active: view === 'games' }]} href={`/sessions/${id}`} aria-current={view === 'games' ? 'true' : undefined}>Games</a>
    <a class:list={['seg', { active: view === 'stats' }]} href={`/sessions/${id}?view=stats`} aria-current={view === 'stats' ? 'true' : undefined}>Stats</a>
    <a class:list={['seg', { active: view === 'notes' }]} href={`/sessions/${id}?view=notes`} aria-current={view === 'notes' ? 'true' : undefined}>Notes</a>
  </div>

  {view === 'games' && (
    <>
      {inProgress && (
        <a class="button resume-cta" href={`/sessions/${id}/games/${inProgress.id}`}>Resume {inProgressLabel} &rarr;</a>
      )}

      {session.session_type === 'league' ? (
        <ul class="list">
          <li>
            {practiceGame ? (
              <>
                <a class="card game-card" href={`/sessions/${id}/games/${practiceGame.id}`}>
                  <div class="game-card-main">
                    <strong>Practice</strong>
                    <div class="game-card-detail">
                      {practiceShotCount} shot{practiceShotCount === 1 ? '' : 's'}
                      {practiceGame.ended_early ? ' · Complete' : ''}
                    </div>
                  </div>
                </a>
              </>
            ) : (
              <div class="add-slot">
                <strong>Practice</strong>
                <form method="POST" class="add-game">
                  <input type="hidden" name="slot" value="practice" />
                  <button type="submit" name="action" value="log">Start Warmup</button>
                </form>
              </div>
            )}
          </li>
          {leagueSlots.map((slot) => {
            const score = slot.game ? gameScore(slot.game) : null;
            return (
              <li>
                {slot.game && score ? (
                  <>
                    <a class="card game-card" href={`/sessions/${id}/games/${slot.game.id}`}>
                      <div class="game-card-main">
                        <strong>{slot.label}</strong>
                        {score.detail && <div class="game-card-detail">{score.detail}</div>}
                      </div>
                      <GameScoreValue primary={score.primary} handicap={score.handicap} />
                    </a>
                    {miniSheet(slot.game.id) && (
                      <MiniScoresheet
                        cells={miniSheet(slot.game.id)!.cells}
                        pinfall={miniSheet(slot.game.id)!.pinfall}
                        label={slot.label}
                      />
                    )}
                    {score.primary == null ? (
                      <div class="game-actions">
                        <form method="POST" class="score-inline">
                          <input type="hidden" name="intent" value="set_game_score" />
                          <input type="hidden" name="game_id" value={slot.game.id} />
                          <input type="number" name="final_score" min="0" max="300" placeholder="final score" aria-label={`Final score for ${slot.label}`} />
                          <button type="submit" class="secondary">Save</button>
                        </form>
                        <a href={`/sessions/${id}/games/${slot.game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                      </div>
                    ) : (
                      <a href={`/sessions/${id}/games/${slot.game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                    )}
                  </>
                ) : (
                  <div class="add-slot">
                    <strong>{slot.label}</strong>
                    <form method="POST" class="add-game">
                      <input type="hidden" name="slot" value={slot.key} />
                      <input type="hidden" name="action" value="" />
                      <input type="number" name="final_score" min="0" max="300" placeholder="final score (optional)" aria-label={`Score for ${slot.label}`} />
                      <div class="add-game-actions">
                        <button type="button" data-action="score" class="secondary">Log Final Score</button>
                        <button type="button" data-action="log">Log Each Frame</button>
                      </div>
                    </form>
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      ) : (
        <>
          {games && games.length > 0 ? (
            <ul class="list">
              {games.map((game, i) => {
                const score = gameScore(game);
                return (
                  <li>
                    <a class="card game-card" href={`/sessions/${id}/games/${game.id}`}>
                      <div class="game-card-main">
                        <strong>Game {i + 1}</strong>
                        {score.detail && <div class="game-card-detail">{score.detail}</div>}
                      </div>
                      <GameScoreValue primary={score.primary} handicap={score.handicap} />
                    </a>
                    {miniSheet(game.id) && (
                      <MiniScoresheet
                        cells={miniSheet(game.id)!.cells}
                        pinfall={miniSheet(game.id)!.pinfall}
                        label={`Game ${i + 1}`}
                      />
                    )}
                    {score.primary == null ? (
                      <div class="game-actions">
                        <form method="POST" class="score-inline">
                          <input type="hidden" name="intent" value="set_game_score" />
                          <input type="hidden" name="game_id" value={game.id} />
                          <input type="number" name="final_score" min="0" max="300" placeholder="final score" aria-label={`Final score for game ${i + 1}`} />
                          <button type="submit" class="secondary">Save</button>
                        </form>
                        <a href={`/sessions/${id}/games/${game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                      </div>
                    ) : (
                      <a href={`/sessions/${id}/games/${game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                    )}
                  </li>
                );
              })}
            </ul>
          ) : (
            <p class="empty">No games yet — add one below.</p>
          )}
          <details class="add-game-toggle" open={!games || games.length === 0}>
            <summary>+ Add a Game</summary>
            <form method="POST" class="add-game">
              <input type="hidden" name="slot" value="new" />
              <input type="hidden" name="action" value="" />
              <input type="number" name="final_score" min="0" max="300" placeholder="final score (optional)" aria-label="Score for new game" />
              <div class="add-game-actions">
                <button type="button" data-action="score" class="secondary">Log Final Score</button>
                <button type="button" data-action="log">Log Each Frame</button>
              </div>
            </form>
          </details>
        </>
      )}

      <hr />

      <details class="score-box collapsible setup-box">
        <summary>
          <span class="sum-label">Session Setup</span>
          <span class="sum-value">{setupSummary}</span>
        </summary>

        {session.session_type === 'league' && (
          <details class="score-box collapsible" open={session.league_id == null}>
            <summary>
              <span class="sum-label">League</span>
              <span class="sum-value">{leagueName ?? 'None'}{sessionHandicap != null ? ` · Hdcp ${sessionHandicap}` : ''}</span>
            </summary>
            <form method="POST">
              <input type="hidden" name="intent" value="set_league" />
              <label>
                League
                <select name="league_id">
                  <option value="">None</option>
                  {leagues?.map((league) => (
                    <option value={league.id} selected={league.id === session.league_id}>{league.name}</option>
                  ))}
                </select>
              </label>
              <label>
                Handicap Override (optional)
                <input type="number" name="manual_handicap" value={session.manual_handicap ?? ''} placeholder={handicap.calculated != null ? String(handicap.calculated) : '—'} />
              </label>
              <button type="submit">Save</button>
            </form>
            <p class="empty">
              {handicap.calculated != null && `Calculated: ${handicap.calculated}. `}
              {handicap.override != null
                ? `Using your override of ${handicap.override}.`
                : sessionHandicap != null
                  ? `This session's handicap: ${sessionHandicap}.`
                  : 'No handicap available for this session yet.'}
            </p>
          </details>
        )}

        <details class="score-box collapsible" open={session.lane_number == null}>
          <summary>
            <span class="sum-label">Lanes</span>
            <span class="sum-value">{laneLabel(laneConfig) || 'Not set'}</span>
          </summary>
          <form method="POST">
            <input type="hidden" name="intent" value="edit_lanes" />
            <label>
              Starting Lane
              <input type="number" name="lane_number" min="1" value={session.lane_number ?? ''} />
            </label>
            <label>
              Second Lane (optional — for a two-lane pair)
              <input type="number" name="second_lane_number" min="1" value={session.second_lane_number ?? ''} placeholder="alternates each frame" />
            </label>
            <button type="submit">Save Lanes</button>
          </form>
          {hasLanePair(laneConfig) && (
            <p class="empty">
              Strict alternation — odd frames on lane {laneConfig.laneNumber}, even frames on lane {laneConfig.secondLaneNumber}.
            </p>
          )}
        </details>

        {balls && balls.length > 0 && (
          <details class="score-box collapsible" open={session.default_ball_id == null && session.default_spare_ball_id == null}>
            <summary>
              <span class="sum-label">Default Balls</span>
              <span class="sum-value">{defaultBallSummary}</span>
            </summary>
            <form method="POST">
              <input type="hidden" name="intent" value="edit_balls" />
              <label>
                Default Ball (pre-fills each throw)
                <select name="default_ball_id">
                  <option value="">None</option>
                  {balls.map((ball) => (
                    <option value={ball.id} selected={ball.id === session.default_ball_id}>{ball.name}</option>
                  ))}
                </select>
              </label>
              <label>
                Default Spare Ball
                <select name="default_spare_ball_id">
                  <option value="">None</option>
                  {balls.map((ball) => (
                    <option value={ball.id} selected={ball.id === session.default_spare_ball_id}>{ball.name}</option>
                  ))}
                </select>
              </label>
              <button type="submit">Save Balls</button>
            </form>
            <p class="empty">Ball 1 of each frame pre-fills your default ball; later balls pre-fill the spare ball. You can still change the ball on any shot.</p>
          </details>
        )}
      </details>

      <hr />

      <form method="POST" class="row-actions" data-confirm="Delete this session? All of its games, throws, and scores will be permanently removed.">
        <input type="hidden" name="intent" value="delete_session" />
        <button type="submit" class="danger">Delete Session</button>
      </form>
    </>
  )}

  {view === 'stats' && (
    <>
      {sessionRates ? (
        <div class="score-box">
          <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Rates Tonight</h2></div>
          <div class="rate-grid">
            <div class="rate-stat">
              <span class="rate-label">Strike Rate</span>
              <span class="rate-value">{formatRate(sessionRates.strikes, sessionRates.strikeOpportunities)}</span>
              <span class="rate-sub">
                {sessionRates.strikeOpportunities > 0
                  ? `${sessionRates.strikes} of ${sessionRates.strikeOpportunities} first balls`
                  : 'No first balls yet'}
              </span>
            </div>
            <div class="rate-stat">
              <span class="rate-label">Spare Conversion</span>
              <span class="rate-value">{formatRate(sessionRates.spares, sessionRates.spareOpportunities)}</span>
              <span class="rate-sub">
                {sessionRates.spareOpportunities > 0
                  ? `${sessionRates.spares} of ${sessionRates.spareOpportunities} leaves`
                  : 'No leaves yet'}
              </span>
            </div>
            <div class="rate-stat">
              <span class="rate-label">Split Conversion</span>
              <span class="rate-value">{formatRate(sessionRates.splitConversions, sessionRates.splitAttempts)}</span>
              <span class="rate-sub">
                {sessionRates.splitAttempts > 0
                  ? `${sessionRates.splitConversions} of ${sessionRates.splitAttempts} splits`
                  : 'No splits yet'}
              </span>
            </div>
            <div class="rate-stat">
              <span class="rate-label">Open Frames</span>
              <span class="rate-value">{formatRate(sessionRates.openFrames, sessionRates.completedFrames)}</span>
              <span class="rate-sub">
                {sessionRates.completedFrames > 0
                  ? `${sessionRates.openFrames} of ${sessionRates.completedFrames} frames`
                  : 'No frames done yet'}
              </span>
            </div>
            <div class="rate-stat">
              <span class="rate-label">Gutter Rate</span>
              <span class="rate-value">{formatRate(sessionRates.gutterBalls, sessionRates.deliveries)}</span>
              <span class="rate-sub">
                {sessionRates.deliveries > 0
                  ? `${sessionRates.gutterBalls} of ${sessionRates.deliveries} balls`
                  : 'No balls thrown yet'}
              </span>
            </div>
          </div>
          <p class="empty">Logged frames from tonight's games; the practice segment isn't counted.</p>
        </div>
      ) : (
        <p class="empty">No logged throws yet — stats appear as you bowl.</p>
      )}

      {gameRateRows.length > 0 && (
        <div class="score-box">
          <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>By Game Tonight</h2></div>
          <ul class="lane-stats">
            {gameRateRows.map((row) => (
              <li>
                <strong>{row.label}</strong>
                <span>
                  Strikes {formatRate(row.rates.strikes, row.rates.strikeOpportunities)}
                  {' · Spares '}{formatRate(row.rates.spares, row.rates.spareOpportunities)}
                  {' · Open '}{formatRate(row.rates.openFrames, row.rates.completedFrames)}
                </span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {laneStats.length > 0 && (
        <div class="score-box">
          <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>By Lane Tonight</h2></div>
          <ul class="lane-stats">
            {laneStats.map((s) => (
              <li>
                <strong>Lane {s.lane}</strong>
                <span>
                  {s.frames} frame{s.frames === 1 ? '' : 's'} · {s.strikes} strike{s.strikes === 1 ? '' : 's'}
                  {' · first-ball avg '}{s.firstBallAvg != null ? s.firstBallAvg.toFixed(1) : '—'}
                </span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </>
  )}

  {view === 'notes' && (
    <>
      <form method="POST" class="add-note">
        <input type="hidden" name="intent" value="add_note" />
        <textarea name="body" rows="2" placeholder="Jot a thought about tonight — lane read, adjustment, reminder…" aria-label="New note" required></textarea>
        <button type="submit" class="secondary">Add Note</button>
      </form>

      {notes.length > 0 ? (
        <ul class="note-stream">
          {notes.map((note) => (
            <li>
              <NoteCard note={note}>
                {note.kind === 'note' && (
                  <div class="note-actions">
                    <details class="note-edit">
                      <summary>Edit</summary>
                      <form method="POST">
                        <input type="hidden" name="intent" value="edit_note" />
                        <input type="hidden" name="note_id" value={note.id} />
                        <textarea name="body" rows="2" aria-label="Edit note" required>{note.body}</textarea>
                        <button type="submit" class="secondary">Save Note</button>
                      </form>
                    </details>
                    <form method="POST" data-confirm="Delete this note?">
                      <input type="hidden" name="intent" value="delete_note" />
                      <input type="hidden" name="note_id" value={note.id} />
                      <button type="submit" class="linklike danger">Delete</button>
                    </form>
                  </div>
                )}
              </NoteCard>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">No notes yet — add one above, or leave a note on any shot while logging.</p>
      )}
    </>
  )}
</Layout>

<script>
  // Each "add-game" form has two actions (Log Final Score / Log Each Frame)
  // sharing one final_score input. Log Each Frame ignores the typed score
  // (frame-by-frame logging builds the real score up shot by shot) -- if the
  // field isn't empty, that would otherwise silently discard whatever the
  // user just typed. Route both buttons through the shared confirm-dialog
  // (data-confirm, from Layout.astro) instead of a plain submit so that case
  // gets a heads-up; an empty field or the Log Final Score button submit
  // straight through.
  document.querySelectorAll<HTMLFormElement>('form.add-game').forEach((form) => {
    const scoreInput = form.querySelector<HTMLInputElement>('input[name="final_score"]');
    const actionInput = form.querySelector<HTMLInputElement>('input[name="action"]');
    if (!scoreInput || !actionInput) return;
    form.querySelectorAll<HTMLButtonElement>('button[data-action]').forEach((btn) => {
      btn.addEventListener('click', () => {
        actionInput.value = btn.dataset.action ?? '';
        if (btn.dataset.action === 'log' && scoreInput.value.trim()) {
          form.setAttribute(
            'data-confirm',
            `Log frame by frame instead? The score you typed ("${scoreInput.value}") won't be saved -- you'll build the score up as you log each frame.`,
          );
          form.setAttribute('data-confirm-label', 'Log Each Frame');
          form.setAttribute('data-confirm-style', 'secondary');
        } else {
          form.removeAttribute('data-confirm');
        }
        form.requestSubmit();
      });
    });
  });
</script>

