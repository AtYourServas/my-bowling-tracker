---
import Layout from '../../layouts/Layout.astro';
import GameScoreValue from '../../components/GameScoreValue.astro';
import { fetchDerivedScoreForGame } from '../../lib/scoring';
import { fetchSessionHandicapDetail } from '../../lib/handicap';
import { fetchSessionLaneStats } from '../../lib/stats';
import { laneLabel, laneConfigFromSession, hasLanePair } from '../../lib/lanes';

const { supabase } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete_session') {
    const { error: deleteError } = await supabase.from('sessions').delete().eq('id', id);

    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/sessions');
    }
  } else if (intent === 'set_league') {
    const league_id = formData.get('league_id')?.toString() || null;
    const manualHandicapRaw = formData.get('manual_handicap')?.toString().trim();
    const manual_handicap = manualHandicapRaw ? Number(manualHandicapRaw) : null;

    const { error: updateError } = await supabase
      .from('sessions')
      .update({ league_id, manual_handicap })
      .eq('id', id);

    if (updateError) {
      error = updateError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'edit_lanes') {
    const laneRaw = formData.get('lane_number')?.toString().trim();
    const lane_number = laneRaw ? Number(laneRaw) : null;
    const secondLaneRaw = formData.get('second_lane_number')?.toString().trim();
    const second_lane_number = secondLaneRaw ? Number(secondLaneRaw) : null;

    const { error: laneError } = await supabase
      .from('sessions')
      .update({ lane_number, second_lane_number })
      .eq('id', id);

    if (laneError) {
      error = laneError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'edit_balls') {
    const default_ball_id = formData.get('default_ball_id')?.toString() || null;
    const default_spare_ball_id = formData.get('default_spare_ball_id')?.toString() || null;

    const { error: ballError } = await supabase
      .from('sessions')
      .update({ default_ball_id, default_spare_ball_id })
      .eq('id', id);

    if (ballError) {
      error = ballError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else if (intent === 'set_game_score') {
    const gameId = formData.get('game_id')?.toString();
    const raw = formData.get('final_score')?.toString().trim();
    const final_score = raw ? Number(raw) : null;

    const { error: scoreError } = await supabase
      .from('games')
      .update({ final_score })
      .eq('id', gameId)
      .eq('session_id', id);

    if (scoreError) {
      error = scoreError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else {
    const slot = formData.get('slot')?.toString();
    const action = formData.get('action')?.toString();
    const rawScore = formData.get('final_score')?.toString().trim();
    // "Add & log throws" starts an empty game and opens the logger; "Add with
    // score" saves the typed score (if any) and stays on the session.
    const final_score = action === 'log' ? null : rawScore ? Number(rawScore) : null;

    const gameToInsert: Record<string, unknown> = { session_id: id, final_score };

    if (slot === 'practice') {
      gameToInsert.is_practice = true;
      gameToInsert.game_number = null;
    } else if (slot === 'game1' || slot === 'game2' || slot === 'game3') {
      gameToInsert.is_practice = false;
      gameToInsert.game_number = Number(slot.replace('game', ''));
    } else {
      // Freeform game for a standalone practice session.
      gameToInsert.is_practice = false;
      gameToInsert.game_number = null;
    }

    const { data, error: insertError } = await supabase
      .from('games')
      .insert(gameToInsert)
      .select('id')
      .single();

    if (insertError) {
      error = insertError.message;
    } else {
      return Astro.redirect(action === 'log' ? `/sessions/${id}/games/${data.id}` : `/sessions/${id}`);
    }
  }
}

const { data: session } = await supabase.from('sessions').select('*, leagues(name)').eq('id', id).maybeSingle();

if (!session) {
  return Astro.redirect('/sessions');
}

const handicap = await fetchSessionHandicapDetail(supabase, session);
const sessionHandicap = handicap.effective;
const leagueName = session.leagues?.name ?? null;

const laneConfig = laneConfigFromSession(session);
const laneStats = hasLanePair(laneConfig) ? await fetchSessionLaneStats(supabase, id!, laneConfig) : [];
const { data: leagues } = await supabase.from('leagues').select('id, name').order('name');
const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const ballName = (ballId: string | null) => balls?.find((b) => b.id === ballId)?.name ?? null;
const defaultBallSummary =
  [ballName(session.default_ball_id), ballName(session.default_spare_ball_id) && `spare ${ballName(session.default_spare_ball_id)}`]
    .filter(Boolean)
    .join(' · ') || 'Not set';

const { data: games } = await supabase
  .from('games')
  .select('*')
  .eq('session_id', id)
  .order('created_at', { ascending: true });

const derivedScores = new Map<string, number | null>(
  await Promise.all(
    (games ?? []).map(async (g) => [g.id, await fetchDerivedScoreForGame(supabase, g.id)] as const),
  ),
);

function gameScore(game: { id: string; final_score: number | null }) {
  const derived = derivedScores.get(game.id) ?? null;
  const scratch = game.final_score ?? derived;

  if (scratch == null) {
    return { primary: null as number | null, handicap: null as number | null, detail: 'No score yet' };
  }

  let detail = '';
  if (game.final_score != null && derived != null && derived !== game.final_score) {
    detail = `derived ${derived}`;
  } else if (game.final_score == null && derived != null) {
    detail = 'derived';
  }

  const handicap = sessionHandicap != null ? scratch + sessionHandicap : null;

  return { primary: scratch, handicap, detail };
}

const practiceGame = games?.find((g) => g.is_practice);
const game1 = games?.find((g) => g.game_number === 1);
const game2 = games?.find((g) => g.game_number === 2);
const game3 = games?.find((g) => g.game_number === 3);

const leagueSlots = [
  { key: 'practice', label: 'Practice', game: practiceGame },
  { key: 'game1', label: 'Game 1', game: game1 },
  { key: 'game2', label: 'Game 2', game: game2 },
  { key: 'game3', label: 'Game 3', game: game3 },
];
---

<Layout title={session.alley_name || 'Session'}>
  <nav class="top"><a href="/sessions">&larr; Sessions</a></nav>
  <h1>{session.alley_name || 'Unnamed alley'}{laneLabel(laneConfig) ? ` · ${laneLabel(laneConfig)}` : ''}</h1>
  <p class="empty">
    {session.session_date} · {session.session_type === 'league' ? 'League' : 'Practice'}
    {leagueName ? ` · ${leagueName}` : ''}
    {session.league_team_name ? ` · ${session.league_team_name}` : ''}
  </p>
  {session.lane_condition_notes && <p class="empty">Lane: {session.lane_condition_notes}</p>}

  {error && <p class="error">{error}</p>}

  {session.session_type === 'league' && (
    <details class="score-box collapsible" open={session.league_id == null}>
      <summary>
        <span class="sum-label">League</span>
        <span class="sum-value">{leagueName ?? 'None'}{sessionHandicap != null ? ` · Hdcp ${sessionHandicap}` : ''}</span>
      </summary>
      <form method="POST">
        <input type="hidden" name="intent" value="set_league" />
        <label>
          League
          <select name="league_id">
            <option value="">None</option>
            {leagues?.map((league) => (
              <option value={league.id} selected={league.id === session.league_id}>{league.name}</option>
            ))}
          </select>
        </label>
        <label>
          Handicap Override (optional)
          <input type="number" name="manual_handicap" value={session.manual_handicap ?? ''} placeholder={handicap.calculated != null ? String(handicap.calculated) : '—'} />
        </label>
        <button type="submit">Save</button>
      </form>
      <p class="empty">
        {handicap.calculated != null && `Calculated: ${handicap.calculated}. `}
        {handicap.override != null
          ? `Using your override of ${handicap.override}.`
          : sessionHandicap != null
            ? `This session's handicap: ${sessionHandicap}.`
            : 'No handicap available for this session yet.'}
      </p>
    </details>
  )}

  <details class="score-box collapsible" open={session.lane_number == null}>
    <summary>
      <span class="sum-label">Lanes</span>
      <span class="sum-value">{laneLabel(laneConfig) || 'Not set'}</span>
    </summary>
    <form method="POST">
      <input type="hidden" name="intent" value="edit_lanes" />
      <label>
        Starting Lane
        <input type="number" name="lane_number" min="1" value={session.lane_number ?? ''} />
      </label>
      <label>
        Second Lane (optional — for a two-lane pair)
        <input type="number" name="second_lane_number" min="1" value={session.second_lane_number ?? ''} placeholder="alternates each frame" />
      </label>
      <button type="submit">Save Lanes</button>
    </form>
    {hasLanePair(laneConfig) && (
      <p class="empty">
        Strict alternation — odd frames on lane {laneConfig.laneNumber}, even frames on lane {laneConfig.secondLaneNumber}.
      </p>
    )}
  </details>

  {balls && balls.length > 0 && (
    <details class="score-box collapsible" open={session.default_ball_id == null && session.default_spare_ball_id == null}>
      <summary>
        <span class="sum-label">Default Balls</span>
        <span class="sum-value">{defaultBallSummary}</span>
      </summary>
      <form method="POST">
        <input type="hidden" name="intent" value="edit_balls" />
        <label>
          Default Ball (pre-fills each throw)
          <select name="default_ball_id">
            <option value="">None</option>
            {balls.map((ball) => (
              <option value={ball.id} selected={ball.id === session.default_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
        <label>
          Default Spare Ball
          <select name="default_spare_ball_id">
            <option value="">None</option>
            {balls.map((ball) => (
              <option value={ball.id} selected={ball.id === session.default_spare_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
        <button type="submit">Save Balls</button>
      </form>
      <p class="empty">Ball 1 of each frame pre-fills your default ball; later balls pre-fill the spare ball. You can still change the ball on any shot.</p>
    </details>
  )}

  {laneStats.length > 0 && (
    <div class="score-box">
      <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>By lane tonight</h2></div>
      <ul class="lane-stats">
        {laneStats.map((s) => (
          <li>
            <strong>Lane {s.lane}</strong>
            <span>
              {s.frames} frame{s.frames === 1 ? '' : 's'} · {s.strikes} strike{s.strikes === 1 ? '' : 's'}
              {' · first-ball avg '}{s.firstBallAvg != null ? s.firstBallAvg.toFixed(1) : '—'}
            </span>
          </li>
        ))}
      </ul>
    </div>
  )}

  <hr />

  <h1>Games</h1>
  <p class="empty">Enter a game's final score, or add &amp; log it shot-by-shot.</p>

  {session.session_type === 'league' ? (
    <ul class="list">
      {leagueSlots.map((slot) => {
        const score = slot.game ? gameScore(slot.game) : null;
        return (
          <li>
            {slot.game && score ? (
              <>
                <a class="card game-card" href={`/sessions/${id}/games/${slot.game.id}`}>
                  <div class="game-card-main">
                    <strong>{slot.label}</strong>
                    {score.detail && <div class="game-card-detail">{score.detail}</div>}
                  </div>
                  <GameScoreValue primary={score.primary} handicap={score.handicap} />
                </a>
                {score.primary == null ? (
                  <div class="game-actions">
                    <form method="POST" class="score-inline">
                      <input type="hidden" name="intent" value="set_game_score" />
                      <input type="hidden" name="game_id" value={slot.game.id} />
                      <input type="number" name="final_score" min="0" max="300" placeholder="final score" aria-label={`Final score for ${slot.label}`} />
                      <button type="submit" class="secondary">Save</button>
                    </form>
                    <a href={`/sessions/${id}/games/${slot.game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                  </div>
                ) : (
                  <a href={`/sessions/${id}/games/${slot.game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                )}
              </>
            ) : (
              <div class="add-slot">
                <strong>{slot.label}</strong>
                <form method="POST" class="add-game">
                  <input type="hidden" name="slot" value={slot.key} />
                  <input type="number" name="final_score" min="0" max="300" placeholder="final score (optional)" aria-label={`Score for ${slot.label}`} />
                  <div class="add-game-actions">
                    <button type="submit" name="action" value="score" class="secondary">Add Score Only</button>
                    <button type="submit" name="action" value="log">Add &amp; Log Throws</button>
                  </div>
                </form>
              </div>
            )}
          </li>
        );
      })}
    </ul>
  ) : (
    <>
      {games && games.length > 0 ? (
        <ul class="list">
          {games.map((game, i) => {
            const score = gameScore(game);
            return (
              <li>
                <a class="card game-card" href={`/sessions/${id}/games/${game.id}`}>
                  <div class="game-card-main">
                    <strong>Game {i + 1}</strong>
                    {score.detail && <div class="game-card-detail">{score.detail}</div>}
                  </div>
                  <GameScoreValue primary={score.primary} handicap={score.handicap} />
                </a>
                {score.primary == null ? (
                  <div class="game-actions">
                    <form method="POST" class="score-inline">
                      <input type="hidden" name="intent" value="set_game_score" />
                      <input type="hidden" name="game_id" value={game.id} />
                      <input type="number" name="final_score" min="0" max="300" placeholder="final score" aria-label={`Final score for game ${i + 1}`} />
                      <button type="submit" class="secondary">Save</button>
                    </form>
                    <a href={`/sessions/${id}/games/${game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                  </div>
                ) : (
                  <a href={`/sessions/${id}/games/${game.id}/review`} class="review-link">Review Scorecard &rarr;</a>
                )}
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty">No games yet — add one below.</p>
      )}
      <form method="POST" class="add-game" style="margin-top: 1rem;">
        <input type="hidden" name="slot" value="new" />
        <input type="number" name="final_score" min="0" max="300" placeholder="final score (optional)" aria-label="Score for new game" />
        <div class="add-game-actions">
          <button type="submit" name="action" value="score" class="secondary">Add Score Only</button>
          <button type="submit" name="action" value="log">Add &amp; Log Throws</button>
        </div>
      </form>
    </>
  )}

  <hr />

  <form method="POST" class="row-actions" onsubmit="return confirm('Delete this session? All of its games, throws, and scores will be permanently removed.');">
    <input type="hidden" name="intent" value="delete_session" />
    <button type="submit" class="danger">Delete Session</button>
  </form>
</Layout>

<style>
  .lane-stats {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .lane-stats li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .lane-stats strong {
    font-variant-numeric: tabular-nums;
  }
  .lane-stats span {
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
  }
</style>
