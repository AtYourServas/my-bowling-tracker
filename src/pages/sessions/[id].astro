---
import Layout from '../../layouts/Layout.astro';
import GameScoreValue from '../../components/GameScoreValue.astro';
import { fetchDerivedScoreForGame } from '../../lib/scoring';
import { fetchSessionHandicap } from '../../lib/handicap';

const { supabase } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete_session') {
    const { error: deleteError } = await supabase.from('sessions').delete().eq('id', id);

    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/sessions');
    }
  } else if (intent === 'set_league') {
    const league_id = formData.get('league_id')?.toString() || null;
    const manualHandicapRaw = formData.get('manual_handicap')?.toString().trim();
    const manual_handicap = manualHandicapRaw ? Number(manualHandicapRaw) : null;

    const { error: updateError } = await supabase
      .from('sessions')
      .update({ league_id, manual_handicap })
      .eq('id', id);

    if (updateError) {
      error = updateError.message;
    } else {
      return Astro.redirect(`/sessions/${id}`);
    }
  } else {
    const slot = formData.get('slot')?.toString();

    const gameToInsert: Record<string, unknown> = { session_id: id };

    if (slot === 'practice') {
      gameToInsert.is_practice = true;
      gameToInsert.game_number = null;
    } else if (slot === 'game1' || slot === 'game2' || slot === 'game3') {
      gameToInsert.is_practice = false;
      gameToInsert.game_number = Number(slot.replace('game', ''));
    } else {
      // Freeform game for a standalone practice session.
      gameToInsert.is_practice = false;
      gameToInsert.game_number = null;
    }

    const { data, error: insertError } = await supabase
      .from('games')
      .insert(gameToInsert)
      .select('id')
      .single();

    if (insertError) {
      error = insertError.message;
    } else {
      return Astro.redirect(`/sessions/${id}/games/${data.id}`);
    }
  }
}

const { data: session } = await supabase.from('sessions').select('*').eq('id', id).maybeSingle();

if (!session) {
  return Astro.redirect('/sessions');
}

const sessionHandicap = await fetchSessionHandicap(supabase, session);
const { data: leagues } = await supabase.from('leagues').select('id, name').order('name');

const { data: games } = await supabase
  .from('games')
  .select('*')
  .eq('session_id', id)
  .order('created_at', { ascending: true });

const derivedScores = new Map<string, number | null>(
  await Promise.all(
    (games ?? []).map(async (g) => [g.id, await fetchDerivedScoreForGame(supabase, g.id)] as const),
  ),
);

function gameScore(game: { id: string; final_score: number | null }) {
  const derived = derivedScores.get(game.id) ?? null;
  const scratch = game.final_score ?? derived;

  if (scratch == null) {
    return { primary: null as number | null, handicap: null as number | null, detail: 'No score yet' };
  }

  let detail = '';
  if (game.final_score != null && derived != null && derived !== game.final_score) {
    detail = `derived ${derived}`;
  } else if (game.final_score == null && derived != null) {
    detail = 'derived';
  }

  const handicap = sessionHandicap != null ? scratch + sessionHandicap : null;

  return { primary: scratch, handicap, detail };
}

const practiceGame = games?.find((g) => g.is_practice);
const game1 = games?.find((g) => g.game_number === 1);
const game2 = games?.find((g) => g.game_number === 2);
const game3 = games?.find((g) => g.game_number === 3);

const leagueSlots = [
  { key: 'practice', label: 'Practice', game: practiceGame },
  { key: 'game1', label: 'Game 1', game: game1 },
  { key: 'game2', label: 'Game 2', game: game2 },
  { key: 'game3', label: 'Game 3', game: game3 },
];
---

<Layout title={session.alley_name || 'Session'}>
  <nav class="top"><a href="/sessions">&larr; Sessions</a></nav>
  <h1>{session.alley_name || 'Unnamed alley'}{session.lane_number ? ` · Lane ${session.lane_number}` : ''}</h1>
  <p class="empty">
    {session.session_date} · {session.session_type === 'league' ? 'League' : 'Practice'}
    {session.league_team_name ? ` · ${session.league_team_name}` : ''}
  </p>
  {session.lane_condition_notes && <p class="empty">Lane: {session.lane_condition_notes}</p>}

  {error && <p class="error">{error}</p>}

  {session.session_type === 'league' && (
    <div class="score-box">
      <form method="POST">
        <input type="hidden" name="intent" value="set_league" />
        <label>
          League
          <select name="league_id">
            <option value="">None</option>
            {leagues?.map((league) => (
              <option value={league.id} selected={league.id === session.league_id}>{league.name}</option>
            ))}
          </select>
        </label>
        <label>
          Manual handicap (if league's type is Manual)
          <input type="number" name="manual_handicap" value={session.manual_handicap ?? ''} />
        </label>
        <button type="submit">Save</button>
      </form>
      <p class="empty">
        {sessionHandicap != null ? `This session's handicap: ${sessionHandicap}` : 'No handicap available for this session yet.'}
      </p>
    </div>
  )}

  <hr />

  <h1>Games</h1>

  {session.session_type === 'league' ? (
    <ul class="list">
      {leagueSlots.map((slot) => {
        const score = slot.game ? gameScore(slot.game) : null;
        return (
          <li>
            {slot.game && score ? (
              <>
                <a class="card game-card" href={`/sessions/${id}/games/${slot.game.id}`}>
                  <div class="game-card-main">
                    <strong>{slot.label}</strong>
                    {score.detail && <div class="game-card-detail">{score.detail}</div>}
                  </div>
                  <GameScoreValue primary={score.primary} handicap={score.handicap} />
                </a>
                <a href={`/sessions/${id}/games/${slot.game.id}/review`} class="review-link">Review scorecard &rarr;</a>
              </>
            ) : (
              <form method="POST">
                <input type="hidden" name="slot" value={slot.key} />
                <button type="submit">Add {slot.label}</button>
              </form>
            )}
          </li>
        );
      })}
    </ul>
  ) : (
    <>
      {games && games.length > 0 ? (
        <ul class="list">
          {games.map((game, i) => {
            const score = gameScore(game);
            return (
              <li>
                <a class="card game-card" href={`/sessions/${id}/games/${game.id}`}>
                  <div class="game-card-main">
                    <strong>Game {i + 1}</strong>
                    {score.detail && <div class="game-card-detail">{score.detail}</div>}
                  </div>
                  <GameScoreValue primary={score.primary} handicap={score.handicap} />
                </a>
                <a href={`/sessions/${id}/games/${game.id}/review`} class="review-link">Review scorecard &rarr;</a>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="empty">No games yet — add one below.</p>
      )}
      <form method="POST" style="margin-top: 1rem;">
        <input type="hidden" name="slot" value="new" />
        <button type="submit">Add game</button>
      </form>
    </>
  )}

  <hr />

  <form method="POST" class="row-actions">
    <input type="hidden" name="intent" value="delete_session" />
    <button type="submit" class="danger">Delete session</button>
  </form>
</Layout>
