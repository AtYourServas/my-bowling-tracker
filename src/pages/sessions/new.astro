---
import Layout from '../../layouts/Layout.astro';

const { supabase, user } = Astro.locals;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const alley_name = formData.get('alley_name')?.toString().trim() || null;
  const laneRaw = formData.get('lane_number')?.toString().trim();
  const lane_number = laneRaw ? Number(laneRaw) : null;
  const secondLaneRaw = formData.get('second_lane_number')?.toString().trim();
  const second_lane_number = secondLaneRaw ? Number(secondLaneRaw) : null;
  const session_type = formData.get('session_type')?.toString();
  const session_date = formData.get('session_date')?.toString() || new Date().toISOString().slice(0, 10);
  const lane_condition_notes = formData.get('lane_condition_notes')?.toString().trim() || null;
  const league_team_name = formData.get('league_team_name')?.toString().trim() || null;
  const league_name = formData.get('league_name')?.toString().trim() || '';
  const manualHandicapRaw = formData.get('manual_handicap')?.toString().trim();
  const manual_handicap = manualHandicapRaw ? Number(manualHandicapRaw) : null;
  const default_ball_id = formData.get('default_ball_id')?.toString() || null;
  const default_spare_ball_id = formData.get('default_spare_ball_id')?.toString() || null;

  if (session_type !== 'league' && session_type !== 'practice') {
    error = 'Session type is required.';
  } else if (
    (lane_number != null && Number.isNaN(lane_number)) ||
    (second_lane_number != null && Number.isNaN(second_lane_number)) ||
    (manual_handicap != null && Number.isNaN(manual_handicap))
  ) {
    error = 'Lane numbers and handicap must be valid numbers.';
  } else {
    // Resolve the typed league name to an existing league (case/whitespace-
    // insensitive) or create a new one -- the field is free text now, not a
    // dropdown of existing ids, so "the league" isn't known until submit.
    // A league session with no team typed inherits the matched/created
    // league's team name.
    let league_id: string | null = null;
    let effectiveTeamName = session_type === 'league' ? league_team_name : null;

    if (session_type === 'league' && league_name) {
      const { data: existingLeagues } = await supabase.from('leagues').select('id, name, team_name');
      const match = (existingLeagues ?? []).find((l) => l.name.trim().toLowerCase() === league_name.toLowerCase());

      if (match) {
        league_id = match.id;
        if (!effectiveTeamName) effectiveTeamName = match.team_name ?? null;
      } else {
        const { data: newLeague, error: leagueInsertError } = await supabase
          .from('leagues')
          .insert({ user_id: user!.id, name: league_name })
          .select('id')
          .single();

        if (leagueInsertError) {
          error = leagueInsertError.message;
        } else {
          league_id = newLeague.id;
        }
      }
    }

    if (!error) {
      const { data, error: insertError } = await supabase
        .from('sessions')
        .insert({
          user_id: user!.id,
          alley_name,
          lane_number,
          second_lane_number,
          session_type,
          session_date,
          lane_condition_notes,
          league_team_name: effectiveTeamName,
          league_id: session_type === 'league' ? league_id : null,
          manual_handicap: session_type === 'league' ? manual_handicap : null,
          default_ball_id,
          default_spare_ball_id,
        })
        .select('id')
        .single();

      if (insertError) {
        error = insertError.message;
      } else {
        return Astro.redirect(`/sessions/${data.id}`);
      }
    }
  }
}

const { data: leagues } = await supabase.from('leagues').select('id, name, team_name').order('name');
const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const { data: profile } = await supabase
  .from('profiles')
  .select('default_ball_id, default_spare_ball_id')
  .eq('id', user!.id)
  .maybeSingle();
---

<Layout title="Start a session">
  <nav class="top"><a href="/sessions">&larr; Sessions</a></nav>
  <h1>Start a Session</h1>

  {error && <p class="error">{error}</p>}

  <form method="POST">
    <label>
      Alley Name
      <input type="text" name="alley_name" />
    </label>
    <label>
      Starting Lane
      <input type="number" name="lane_number" min="1" />
    </label>
    <label>
      Second Lane (optional — for a two-lane pair)
      <input type="number" name="second_lane_number" min="1" placeholder="alternates each frame" />
    </label>
    <label>
      Date
      <input type="date" name="session_date" value={new Date().toISOString().slice(0, 10)} />
    </label>
    <label>
      Session Type
      <select name="session_type" required>
        <option value="league">League</option>
        <option value="practice">Practice</option>
      </select>
    </label>
    <div class="league-only">
      <label>
        League
        <input type="text" name="league_name" list="league-options" autocomplete="off" placeholder="Type or pick a league" />
        <datalist id="league-options">
          {leagues?.map((league) => (
            <option value={league.name} data-id={league.id} data-team={league.team_name ?? ''} />
          ))}
        </datalist>
      </label>
      <label>
        Team Name
        <input type="text" name="league_team_name" placeholder="Fills from the league — edit to override" />
      </label>
      <label>
        Handicap Override (optional — overrides the league's calculated handicap)
        <input type="number" name="manual_handicap" />
      </label>
    </div>
    {balls && balls.length > 0 && (
      <>
        <label>
          Default Ball (pre-fills each throw)
          <select name="default_ball_id">
            <option value="">None</option>
            {balls.map((ball) => (
              <option value={ball.id} selected={ball.id === profile?.default_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
        <label>
          Default Spare Ball
          <select name="default_spare_ball_id">
            <option value="">None</option>
            {balls.map((ball) => (
              <option value={ball.id} selected={ball.id === profile?.default_spare_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
      </>
    )}
    <label>
      Lane Condition Notes
      <textarea name="lane_condition_notes" rows="2" placeholder="e.g. fresh oil, breaking down"></textarea>
    </label>
    <button type="submit">Start Session</button>
  </form>
</Layout>

<style>
  .league-only {
    display: flex;
    flex-direction: column;
    gap: var(--s3);
  }
  /* Author display:flex above beats the UA [hidden] rule (author origin always
     wins over UA origin regardless of specificity) -- same class of bug fixed
     for details>form in PR 76. Restate it explicitly so JS-toggled hidden works. */
  .league-only[hidden] {
    display: none;
  }
</style>

<script>
  // Wrapped in astro:page-load (fires on the initial load AND every
  // ClientRouter navigation, including a repeat visit to this same page):
  // Astro dedupes identical script content against what's already run THIS
  // session, so a plain top-level body here would only ever wire up the
  // FIRST visit to /sessions/new -- navigating away and back later would
  // land on an unwired form.
  document.addEventListener('astro:page-load', () => {
    // Matching a saved league name (typed or picked from the datalist) fills
    // the team-name field and, from that league's most recent session,
    // Alley Name/Lane/Second Lane -- while leaving anything the user has
    // typed themselves untouched (each field only auto-fills if it's still
    // empty or still equals the last value THIS script auto-filled).
    const leagueInput = document.querySelector<HTMLInputElement>('input[name="league_name"]');
    const teamInput = document.querySelector<HTMLInputElement>('input[name="league_team_name"]');
    const alleyInput = document.querySelector<HTMLInputElement>('input[name="alley_name"]');
    const laneInput = document.querySelector<HTMLInputElement>('input[name="lane_number"]');
    const secondLaneInput = document.querySelector<HTMLInputElement>('input[name="second_lane_number"]');

    if (leagueInput && teamInput) {
      let autoTeam = teamInput.value;
      let autoAlley = alleyInput?.value ?? '';
      let autoLane = laneInput?.value ?? '';
      let autoSecondLane = secondLaneInput?.value ?? '';
      let lastMatchedId: string | null = null;

      leagueInput.addEventListener('input', () => {
        const typed = leagueInput.value.trim().toLowerCase();
        const option = typed
          ? Array.from(document.querySelectorAll<HTMLOptionElement>('#league-options option')).find(
              (o) => o.value.trim().toLowerCase() === typed,
            )
          : undefined;

        const team = option?.dataset.team ?? '';
        if (teamInput.value === '' || teamInput.value === autoTeam) {
          teamInput.value = team;
          autoTeam = team;
        }

        const id = option?.dataset.id ?? null;
        if (!id || id === lastMatchedId) return;
        lastMatchedId = id;

        fetch(`/api/leagues/last-session?league_id=${encodeURIComponent(id)}`)
          .then((res) => (res.ok ? res.json() : null))
          .then((last: { alley_name: string | null; lane_number: number | null; second_lane_number: number | null } | null) => {
            if (!last) return;
            if (alleyInput && (alleyInput.value === '' || alleyInput.value === autoAlley)) {
              const alley = last.alley_name ?? '';
              alleyInput.value = alley;
              autoAlley = alley;
            }
            if (laneInput && (laneInput.value === '' || laneInput.value === autoLane)) {
              const lane = last.lane_number != null ? String(last.lane_number) : '';
              laneInput.value = lane;
              autoLane = lane;
            }
            if (secondLaneInput && (secondLaneInput.value === '' || secondLaneInput.value === autoSecondLane)) {
              const secondLane = last.second_lane_number != null ? String(last.second_lane_number) : '';
              secondLaneInput.value = secondLane;
              autoSecondLane = secondLane;
            }
          })
          .catch(() => {});
      });
    }

    // League/Team/Handicap Override only apply to a league session -- hide them
    // for Practice so a first-time practice bowler isn't shown fields that
    // don't apply (the server already ignores them outside session_type='league').
    const sessionTypeSelect = document.querySelector<HTMLSelectElement>('select[name="session_type"]');
    const leagueOnly = document.querySelector<HTMLDivElement>('.league-only');
    if (sessionTypeSelect && leagueOnly) {
      const sync = () => {
        leagueOnly.hidden = sessionTypeSelect.value !== 'league';
      };
      sessionTypeSelect.addEventListener('change', sync);
      sync();
    }
  });
</script>
