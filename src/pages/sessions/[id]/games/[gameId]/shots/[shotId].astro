---
import Layout from '../../../../../../layouts/Layout.astro';
import ShotForm from '../../../../../../components/ShotForm';
import { allowedMarks, pinsFacedBefore, WARMUP_FRAME } from '../../../../../../lib/scoring';
import type { ShotLite } from '../../../../../../lib/scoring';
import { suggestedApproachName } from '../../../../../../lib/leaves';

const { supabase, user } = Astro.locals;
const { id: sessionId, gameId, shotId } = Astro.params;

// carried through from the game page so editing a shot returns you to the same
// score-entry mode (see PR 12)
const mode = Astro.url.searchParams.get('mode') === 'type' ? 'type' : 'pick';
const modeQ = `&mode=${mode}`;

let error: string | null = null;

const { data: shot } = await supabase
  .from('shots')
  .select('*, frames(frame_number, games(is_practice))')
  .eq('id', shotId)
  .maybeSingle();

if (!shot) {
  return Astro.redirect(`/sessions/${sessionId}/games/${gameId}`);
}

const frameNumber = shot.frames.frame_number;
// warmup (the League session's Practice slot) never applies the real 10th-frame
// bonus-ball rules, even on literal frame 10 -- see WARMUP_FRAME.
const ruleFrameNumber = (shot.frames as any).games?.is_practice ? WARMUP_FRAME : frameNumber;

// which marks are legal for this ball, based on the shots thrown before it in
// the frame (so editing ball 2 of a normal frame won't offer Strike, etc.) --
// computed up front so the save-as-approach POST branch below can use it too.
const { data: siblingShots } = await supabase
  .from('shots')
  .select('pins_standing, strike, spare, foul, created_at')
  .eq('frame_id', shot.frame_id)
  .order('created_at', { ascending: true });
const priorShots = (siblingShots ?? []).filter((s) => s.created_at < shot.created_at) as ShotLite[];
const marks = allowedMarks(ruleFrameNumber, priorShots);

// the leave this ball faced, so the picker's Missed/quick-count shortcuts work
// on the right pins when editing (ShotForm treats [] as a fresh rack) -- and
// what a "Save as Approach" from this shot targets.
const faced = pinsFacedBefore(priorShots);
const facedLeave = faced.length === 10 ? [] : faced;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete') {
    const { error: deleteError } = await supabase.from('shots').delete().eq('id', shotId);
    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${modeQ}`);
    }
  } else if (intent === 'save_as_approach') {
    // reads the form's CURRENT ball/marks (not the stored shot), so any tweak
    // made before clicking Save as Approach is what gets saved
    const ball_id = formData.get('ball_id')?.toString() || null;
    const lineup_position = formData.get('lineup_position')?.toString().trim() || null;
    const slide_position = formData.get('slide_position')?.toString().trim() || null;
    const target_type = formData.get('target_type')?.toString() || null;
    const targetValueRaw = formData.get('target_value')?.toString().trim();
    const target_value = targetValueRaw ? Number(targetValueRaw) : null;

    const { data: inserted, error: insertError } = await supabase
      .from('approaches')
      .insert({
        user_id: user!.id,
        name: suggestedApproachName(facedLeave),
        reference_ball_id: ball_id,
        reference_lineup: lineup_position,
        reference_slide: slide_position,
        reference_target_type: target_type,
        reference_target_value: target_value,
        leave: facedLeave,
      })
      .select('id')
      .single();

    if (insertError) {
      error = insertError.message;
    } else {
      return Astro.redirect(`/sessions/${sessionId}/games/${gameId}/shots/${shotId}?saved=${inserted.id}${modeQ}`);
    }
  } else {
    const pinsRaw = formData.get('pins_standing')?.toString() ?? '';
    const pins_standing = pinsRaw
      ? pinsRaw
          .split(',')
          .map(Number)
          .filter((n) => n >= 1 && n <= 10)
      : [];

    const ball_id = formData.get('ball_id')?.toString() || null;
    const approach_id = formData.get('approach_id')?.toString() || null;
    const lineup_position = formData.get('lineup_position')?.toString().trim() || null;
    const slide_position = formData.get('slide_position')?.toString().trim() || null;
    const target_type = formData.get('target_type')?.toString() || null;
    const targetValueRaw = formData.get('target_value')?.toString().trim();
    const target_value = targetValueRaw ? Number(targetValueRaw) : null;
    const strike = formData.get('strike') === 'true';
    const spare = formData.get('spare') === 'true';
    const foul = formData.get('foul') === 'true';
    const hook_timing = formData.get('hook_timing')?.toString() || null;
    const miss_direction = formData.get('miss_direction')?.toString() || null;
    const breakpointRaw = formData.get('breakpoint_board')?.toString().trim();
    const breakpoint_board = breakpointRaw ? Number(breakpointRaw) : null;
    const note = formData.get('note')?.toString().trim() || null;

    const { error: updateError } = await supabase
      .from('shots')
      .update({
        ball_id,
        approach_id,
        lineup_position,
        slide_position,
        target_type,
        target_value,
        pins_standing,
        strike,
        spare,
        foul,
        hook_timing,
        miss_direction,
        breakpoint_board,
        note,
      })
      .eq('id', shotId);

    if (updateError) {
      error = updateError.message;
    } else {
      return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${modeQ}`);
    }
  }
}

const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const { data: approaches } = await supabase
  .from('approaches')
  .select('id, name, reference_lineup, reference_slide, reference_target_type, reference_target_value, leave')
  .order('name');

---

<Layout title={`Frame ${frameNumber} shot`}>
  <nav class="top"><a href={`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${modeQ}`}>&larr; Frame {frameNumber}</a></nav>
  <h1>Edit Shot</h1>

  {error && <p class="error">{error}</p>}

  <ShotForm
    client:load
    balls={balls ?? []}
    approaches={approaches ?? []}
    frameNumber={frameNumber}
    submitLabel="Save Changes"
    startingPins={facedLeave}
    allowStrike={marks.strike}
    allowSpare={marks.spare}
    mode={mode}
    initial={{
      approach_id: shot.approach_id,
      ball_id: shot.ball_id,
      lineup_position: shot.lineup_position,
      slide_position: shot.slide_position,
      target_type: shot.target_type,
      target_value: shot.target_value,
      pins_standing: shot.pins_standing ?? [],
      strike: shot.strike,
      spare: shot.spare,
      foul: shot.foul,
      hook_timing: shot.hook_timing,
      miss_direction: shot.miss_direction,
      breakpoint_board: shot.breakpoint_board,
      note: shot.note,
    }}
  />

  <form method="POST" class="row-actions" data-confirm="Delete this shot?">
    <input type="hidden" name="intent" value="delete" />
    <button type="submit" class="danger">Delete Shot</button>
  </form>
</Layout>
