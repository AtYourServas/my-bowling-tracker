---
import Layout from '../../../../layouts/Layout.astro';
import ShotForm from '../../../../components/ShotForm';
import NoteCard from '../../../../components/NoteCard.astro';
import {
  fetchScoresheetForGame,
  fetchRunningScoreForGame,
  frameProgress,
  computeFrameRolls,
  allowedMarks,
  pinsStandingBefore,
  pinsFacedBefore,
  parseShotShorthand,
  fetchEarliestIncompleteFrame,
  fetchWarmupFrames,
  computeWarmupSheet,
  fetchEarliestIncompleteWarmupFrame,
  WARMUP_FRAME,
} from '../../../../lib/scoring';
import type { ShotLite } from '../../../../lib/scoring';
import { fetchSessionHandicap } from '../../../../lib/handicap';
import { fetchLeaveNotes, notesForLeave, leaveAnchor } from '../../../../lib/notes';
import { leaveDisplayName, suggestedApproachName } from '../../../../lib/leaves';
import { laneForFrame, laneConfigFromSession } from '../../../../lib/lanes';

const { supabase, user } = Astro.locals;
const { id: sessionId, gameId } = Astro.params;

let error: string | null = null;

// Fetched up front (rather than after POST handling, as before) so isWarmup is known
// before frame-number parsing and the resume redirect below need to branch on it. Reads
// are unaffected by any mutation a POST intent below performs -- is_practice never
// changes, and the sessions join is read-only context.
const { data: game } = await supabase
  .from('games')
  .select('*, sessions(alley_name, session_date, session_type, league_id, manual_handicap, lane_number, second_lane_number, default_ball_id, default_spare_ball_id)')
  .eq('id', gameId)
  .maybeSingle();

if (!game) {
  return Astro.redirect(`/sessions/${sessionId}`);
}

// The League session's Practice slot: an unbounded warmup, not a normal capped 10-frame
// game -- see PR 67. (Standalone practice *sessions* use is_practice=false freeform
// games and keep the normal capped logger below.)
const isWarmup = game.is_practice;

// Score-entry mode: an explicit ?mode= (set by the on-page toggle) wins and
// sticks frame-to-frame; otherwise fall back to the profile's saved default.
const urlMode = Astro.url.searchParams.get('mode');
let mode: 'pick' | 'type' = urlMode === 'type' ? 'type' : 'pick';
if (urlMode !== 'type' && urlMode !== 'pick') {
  const { data: prof } = await supabase.from('profiles').select('default_entry_mode').eq('id', user!.id).maybeSingle();
  mode = prof?.default_entry_mode === 'type' ? 'type' : 'pick';
}
const modeQ = `&mode=${mode}`;

// Opening a game with no explicit frame lands on the earliest unfinished frame,
// so you resume where you left off instead of always starting at frame 1.
const frameParam = Astro.url.searchParams.get('frame');
if (Astro.request.method === 'GET' && frameParam == null) {
  const resume = isWarmup
    ? await fetchEarliestIncompleteWarmupFrame(supabase, gameId!)
    : await fetchEarliestIncompleteFrame(supabase, gameId!);
  return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${resume}${modeQ}`);
}

const frameNumber = isWarmup ? Math.max(1, Number(frameParam) || 1) : Math.min(10, Math.max(1, Number(frameParam) || 1));
// frame number normalized so frame-shot rules (frameProgress/allowedMarks/parseShotShorthand)
// never apply the real 10th-frame bonus-ball special case to a warmup game, even on its
// literal frame 10, 20, ... -- see WARMUP_FRAME.
const ruleFrameNumber = isWarmup ? WARMUP_FRAME : frameNumber;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();
  // echoed back by every entry form so the chosen mode persists across frames
  const postMode = formData.get('mode')?.toString() === 'type' ? 'type' : 'pick';
  const postModeQ = `&mode=${postMode}`;

  if (intent === 'delete_game') {
    const { error: deleteError } = await supabase.from('games').delete().eq('id', gameId);

    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect(`/sessions/${sessionId}`);
    }
  } else if (intent === 'set_score') {
    const raw = formData.get('final_score')?.toString().trim();
    const final_score = raw ? Number(raw) : null;

    // a manually-typed score always wins as the score of record -- clear
    // ended_early so a game finished for real after being ended early
    // doesn't stay flagged (and excluded from stats) forever
    const { error: scoreError } = await supabase.from('games').update({ final_score, ended_early: false }).eq('id', gameId);

    if (scoreError) {
      error = scoreError.message;
    } else {
      return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${postModeQ}`);
    }
  } else if (intent === 'end_practice_early') {
    if (isWarmup) {
      // warmup has no score to card -- ending it just marks it done, even with
      // zero shots logged (e.g. you started it and changed your mind)
      const { error: endError } = await supabase.from('games').update({ ended_early: true }).eq('id', gameId);
      if (endError) {
        error = endError.message;
      } else {
        return Astro.redirect(`/sessions/${sessionId}`);
      }
    } else {
      const eligible = game.is_practice || game.sessions?.session_type === 'practice';

      if (!eligible) {
        error = 'This game cannot be ended early.';
      } else {
        const partial = await fetchRunningScoreForGame(supabase, gameId!);

        if (partial == null) {
          error = 'Log at least one ball before ending the game early.';
        } else {
          const { error: endError } = await supabase
            .from('games')
            .update({ final_score: partial.score, ended_early: true })
            .eq('id', gameId);

          if (endError) {
            error = endError.message;
          } else {
            return Astro.redirect(`/sessions/${sessionId}`);
          }
        }
      }
    }
  } else if (intent === 'add_note') {
    const body = formData.get('body')?.toString().trim();

    if (body) {
      const { error: noteError } = await supabase
        .from('session_notes')
        .insert({ user_id: user!.id, session_id: sessionId, body });
      if (noteError) error = noteError.message;
      else return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${postModeQ}#note`);
    } else {
      return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${postModeQ}#note`);
    }
  } else if (intent === 'save_as_approach') {
    // the leave the ACTIVE frame currently faces -- same rule the picker
    // itself uses, computed fresh rather than relying on frames not yet
    // created for a not-yet-thrown first ball
    const { data: activeFrame } = await supabase
      .from('frames')
      .select('id')
      .eq('game_id', gameId)
      .eq('frame_number', frameNumber)
      .maybeSingle();
    const { data: existing } = activeFrame
      ? await supabase
          .from('shots')
          .select('pins_standing, strike, spare, foul, created_at')
          .eq('frame_id', activeFrame.id)
          .order('created_at', { ascending: true })
      : { data: [] };
    const faced = pinsFacedBefore((existing ?? []) as ShotLite[]);
    const facedLeave = faced.length === 10 ? [] : faced;

    const ball_id = formData.get('ball_id')?.toString() || null;
    const lineup_position = formData.get('lineup_position')?.toString().trim() || null;
    const slide_position = formData.get('slide_position')?.toString().trim() || null;
    const target_type = formData.get('target_type')?.toString() || null;
    const targetValueRaw = formData.get('target_value')?.toString().trim();
    const target_value = targetValueRaw ? Number(targetValueRaw) : null;

    const { data: inserted, error: insertError } = await supabase
      .from('approaches')
      .insert({
        user_id: user!.id,
        name: suggestedApproachName(facedLeave),
        reference_ball_id: ball_id,
        reference_lineup: lineup_position,
        reference_slide: slide_position,
        reference_target_type: target_type,
        reference_target_value: target_value,
        leave: facedLeave,
      })
      .select('id')
      .single();

    if (insertError) {
      error = insertError.message;
    } else {
      return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${frameNumber}${postModeQ}&saved=${inserted.id}`);
    }
  } else if (intent === 'log_shot' || intent === 'log_shorthand') {
    let { data: frame } = await supabase
      .from('frames')
      .select('id')
      .eq('game_id', gameId)
      .eq('frame_number', frameNumber)
      .maybeSingle();

    if (!frame) {
      const { data: newFrame, error: frameError } = await supabase
        .from('frames')
        .insert({ game_id: gameId, frame_number: frameNumber })
        .select('id')
        .single();

      if (frameError) {
        error = frameError.message;
      } else {
        frame = newFrame;
      }
    }

    if (frame) {
      // enforce the physical shot cap (2/frame, 3 in the 10th only on strike/spare)
      const { data: existing } = await supabase
        .from('shots')
        .select('pins_standing, strike, spare, foul')
        .eq('frame_id', frame.id)
        .order('created_at', { ascending: true });
      const existingShots = (existing ?? []) as ShotLite[];

      if (!frameProgress(ruleFrameNumber, existingShots).canAdd) {
        error = `Frame ${frameNumber} already has all of its shots.`;
      } else if (intent === 'log_shorthand') {
        // typed straight into the scoresheet frame: parse the shorthand into the
        // same pin state the picker produces. An empty box is a gutter (0 down),
        // never a strike. Quick entry uses the session's default ball for the ball.
        const ballIndex = existingShots.length;
        const rawShort = formData.get('shorthand')?.toString().trim() || 'G';
        const parsed = parseShotShorthand(rawShort, {
          priorStanding: pinsStandingBefore(existingShots),
          ballIndex,
          frameNumber: ruleFrameNumber,
        });

        if (!parsed.ok) {
          error = parsed.error;
        } else {
          const { data: sess } = await supabase
            .from('games')
            .select('sessions(default_ball_id, default_spare_ball_id)')
            .eq('id', gameId)
            .maybeSingle();
          const s = (sess?.sessions ?? {}) as { default_ball_id?: string | null; default_spare_ball_id?: string | null };
          const ball_id = ballIndex === 0 ? s.default_ball_id ?? null : s.default_spare_ball_id ?? s.default_ball_id ?? null;
          const { standing, strike, spare, foul } = parsed.result;

          const { error: insertError } = await supabase.from('shots').insert({
            frame_id: frame.id,
            ball_id,
            pins_standing: standing,
            strike,
            spare,
            foul,
          });

          if (insertError) {
            error = insertError.message;
          } else {
            const after = frameProgress(ruleFrameNumber, [...existingShots, { pins_standing: standing, strike, spare, foul }]);
            const target = after.complete && (isWarmup || frameNumber < 10) ? frameNumber + 1 : frameNumber;
            return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${target}${postModeQ}`);
          }
        }
      } else {
        // log_shot: full detail entry from the pin-diagram form
        const pinsRaw = formData.get('pins_standing')?.toString() ?? '';
        const pins_standing = pinsRaw
          ? pinsRaw
              .split(',')
              .map(Number)
              .filter((n) => n >= 1 && n <= 10)
          : [];

        const ball_id = formData.get('ball_id')?.toString() || null;
        const approach_id = formData.get('approach_id')?.toString() || null;
        const lineup_position = formData.get('lineup_position')?.toString().trim() || null;
        const slide_position = formData.get('slide_position')?.toString().trim() || null;
        const target_type = formData.get('target_type')?.toString() || null;
        const targetValueRaw = formData.get('target_value')?.toString().trim();
        const target_value = targetValueRaw ? Number(targetValueRaw) : null;
        const strike = formData.get('strike') === 'true';
        const spare = formData.get('spare') === 'true';
        const foul = formData.get('foul') === 'true';
        const hook_timing = formData.get('hook_timing')?.toString() || null;
        const miss_direction = formData.get('miss_direction')?.toString() || null;
        const breakpointRaw = formData.get('breakpoint_board')?.toString().trim();
        const breakpoint_board = breakpointRaw ? Number(breakpointRaw) : null;
        const note = formData.get('note')?.toString().trim() || null;

        const { error: insertError } = await supabase.from('shots').insert({
          frame_id: frame.id,
          ball_id,
          approach_id,
          lineup_position,
          slide_position,
          target_type,
          target_value,
          pins_standing,
          strike,
          spare,
          foul,
          hook_timing,
          miss_direction,
          breakpoint_board,
          note,
        });

        if (insertError) {
          error = insertError.message;
        } else {
          // auto-advance: a completed frame jumps to the next; an unfinished
          // one stays put so the form reappears for the next ball
          const after = frameProgress(ruleFrameNumber, [...existingShots, { pins_standing, strike, spare, foul }]);
          const target = after.complete && (isWarmup || frameNumber < 10) ? frameNumber + 1 : frameNumber;
          return Astro.redirect(`/sessions/${sessionId}/games/${gameId}?frame=${target}${postModeQ}`);
        }
      }
    }
  }
}

const cells = isWarmup
  ? computeWarmupSheet(await fetchWarmupFrames(supabase, gameId!), frameNumber)
  : await fetchScoresheetForGame(supabase, gameId!);
const through = [...cells].reverse().find((c) => c.cumulative != null);
const runningTotal = through?.cumulative ?? null;
const finalDerived = !isWarmup ? cells[9]?.cumulative ?? null : null; // full total once all 10 resolve
const scratchScore = game.final_score ?? finalDerived ?? runningTotal;

// Practice-session games (standalone practice, is_practice=false) can be ended
// before frame 10 with a partial score -- competitive league games can't.
// Warmup (is_practice=true) has its own always-available "End Practice" below,
// no score involved. The partial score uses computeRunningScore (face-value on
// any unresolved trailing bonus), not the strict cumulative above, so a couple
// of strikes in a row at the start of a game don't leave the button unable to
// show a score.
const isPracticeSessionGame = !isWarmup && game.sessions?.session_type === 'practice';
const partialScore =
  isPracticeSessionGame && game.final_score == null && finalDerived == null
    ? await fetchRunningScoreForGame(supabase, gameId!)
    : null;
const canEndEarly = partialScore != null;
const lastBowled = [...cells].reverse().find((c) => c.bowled) ?? null;
const sessionHandicap = isWarmup ? null : await fetchSessionHandicap(supabase, { id: sessionId!, ...game.sessions });

const sessionMeta = [
  game.sessions?.alley_name,
  game.sessions?.session_date
    ? new Date(`${game.sessions.session_date}T00:00:00`).toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
      })
    : null,
]
  .filter(Boolean)
  .join(' · ');

const { data: frameRow } = await supabase
  .from('frames')
  .select('id')
  .eq('game_id', gameId)
  .eq('frame_number', frameNumber)
  .maybeSingle();

const { data: shots } = frameRow
  ? await supabase
      .from('shots')
      .select('*, balls(name)')
      .eq('frame_id', frameRow.id)
      .order('created_at', { ascending: true })
  : { data: [] };

const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const { data: approaches } = await supabase
  .from('approaches')
  .select('id, name, reference_lineup, reference_slide, reference_target_type, reference_target_value, leave')
  .order('name');

// profile preferences: hidden shot-logger fields + the default strike approach
const { data: prefRow } = await supabase
  .from('profiles')
  .select('hidden_shot_fields, default_approach_id')
  .eq('id', user!.id)
  .maybeSingle();
const hiddenShotFields = prefRow?.hidden_shot_fields ?? [];

const gameLabel = game.is_practice ? 'Practice' : game.game_number ? `Game ${game.game_number}` : 'Game';

// under a two-lane pair, strict alternation puts each frame on a derived lane
const laneConfig = laneConfigFromSession(game.sessions ?? { lane_number: null, second_lane_number: null });
const frameLane = laneForFrame(frameNumber, laneConfig);
const showFrameLane = laneConfig.secondLaneNumber != null && frameLane != null;

// current-frame state (reuses the scoresheet's roll + completeness logic)
const frameShots = (shots ?? []) as any[];
const progress = frameProgress(ruleFrameNumber, frameShots as ShotLite[]);
const marks = allowedMarks(ruleFrameNumber, frameShots as ShotLite[]);
const knockedPerBall = computeFrameRolls(frameShots as ShotLite[]);
const frameMarks = cells[frameNumber - 1].balls;
const ordinals = ['First', 'Second', 'Third'];

// pins left standing after the last logged ball seed the next ball's picker
const startingPins = frameShots.length ? frameShots[frameShots.length - 1].pins_standing ?? [] : [];

// the leave this ball faces (pins standing before it — a full rack on ball 1 /
// after a respot), used to surface what you noted the last times you shot it
const facedNow = pinsFacedBefore(frameShots as ShotLite[]);
// surface those past notes (exact faced-leave match, across all your sessions);
// shown capped, the rest linked on /notes
const leaveNotes = progress.nextBall != null ? notesForLeave(await fetchLeaveNotes(supabase), facedNow) : [];
const leaveNotesShown = leaveNotes.slice(0, 5);

// pre-select the session's default ball on the first ball of a frame and the
// spare ball on later balls; each shot's ball can still be changed manually
const defaultBallId =
  progress.nextBall === 1
    ? game.sessions?.default_ball_id ?? null
    : game.sessions?.default_spare_ball_id ?? game.sessions?.default_ball_id ?? null;

// the profile's default strike approach prefills any ball facing a full rack
// (frame first balls + 10th-frame respots); its marks auto-apply in ShotForm
const defaultApproachId = startingPins.length === 0 ? prefRow?.default_approach_id ?? null : null;

// frames 1-9 that completed on a lone strike: a 2nd ball needs the strike edited away
const strikeLockShot = (isWarmup || frameNumber < 10) && progress.complete && frameShots.length === 1 ? frameShots[0] : null;

const prevFrame = frameNumber > 1 ? frameNumber - 1 : null;
const nextFrame = isWarmup ? frameNumber + 1 : frameNumber < 10 ? frameNumber + 1 : null;
const frameHref = (n: number, m: 'pick' | 'type' = mode) => `/sessions/${sessionId}/games/${gameId}?frame=${n}&mode=${m}`;

// the ball box (0-based) awaiting entry in the active frame, when typing
const activeBox = progress.nextBall != null ? progress.nextBall - 1 : -1;

// A struck frame (1-9, or any warmup frame) shows the X alone in the top-right
// corner box, the traditional scoresheet look — drop the placeholder empty
// 2nd-ball square. Warmup never has a real 10th-frame 3-ball layout.
function displayBalls(cell: (typeof cells)[number]) {
  return (isWarmup || cell.frameNumber < 10) && cell.balls[0]?.kind === 'strike'
    ? cell.balls.slice(0, 1)
    : cell.balls;
}

function ballResult(i: number): string {
  if (frameShots[i]?.foul) return 'Foul — counts 0';
  const kind = frameMarks[i]?.kind;
  if (kind === 'strike') return 'Strike';
  if (kind === 'spare') return 'Spare';
  const knocked = knockedPerBall[i] ?? 0;
  return knocked === 0 ? 'Gutter — 0 down' : `${knocked} down`;
}

const savedApproachId = Astro.url.searchParams.get('saved');
---

<Layout title={gameLabel}>
  <nav class="top"><a href={`/sessions/${sessionId}`}>&larr; Session</a></nav>
  <h1>{gameLabel}</h1>
  {sessionMeta && <p class="meta">{sessionMeta}</p>}
  {game.ended_early && lastBowled && (
    <p class="empty">{isWarmup ? 'Practice complete' : 'Ended early'} &middot; through frame {lastBowled.frameNumber}</p>
  )}

  {error && <p class="error">{error}</p>}
  {savedApproachId && (
    <p class="empty">Saved as approach — <a href={`/approaches/${savedApproachId}`}>View &amp; edit &rarr;</a></p>
  )}

  <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Scoresheet</h2></div>

  <div class="entry-toggle" role="group" aria-label="Score entry mode">
    <a class:list={['seg', { active: mode === 'pick' }]} href={frameHref(frameNumber, 'pick')} aria-current={mode === 'pick' ? 'true' : undefined}>Pick Pins</a>
    <a class:list={['seg', { active: mode === 'type' }]} href={frameHref(frameNumber, 'type')} aria-current={mode === 'type' ? 'true' : undefined}>Type</a>
  </div>

  {mode === 'type' && progress.nextBall != null && (
    <div class="type-legend">
      <p class="type-instruction">Type into the highlighted frame, then press Enter.</p>
      <ul class="legend" aria-label="Shorthand key">
        <li><span class="k">X</span> strike</li>
        <li><span class="k">/</span> spare</li>
        <li><span class="k">G 0 -</span> gutter / miss</li>
        <li><span class="k">F</span> foul</li>
      </ul>
    </div>
  )}

  <form method="POST">
    <input type="hidden" name="intent" value="log_shorthand" />
    <input type="hidden" name="frame_number" value={frameNumber} />
    <input type="hidden" name="mode" value={mode} />
    <div class="sheetwrap">
      <div class="sheet" role="group" aria-label="Frames">
        {cells.map((cell) => {
          const isActive = cell.frameNumber === frameNumber;
          const typeHere = mode === 'type' && isActive && progress.nextBall != null;
          const cls = ['cell', { active: isActive, future: !cell.bowled && !isActive, f10: !isWarmup && cell.frameNumber === 10 }];
          return typeHere ? (
            <div class:list={[...cls, 'typing']} aria-current="true" aria-label={`Frame ${cell.frameNumber}, entering ball ${progress.nextBall}`}>
              <span class="fnum">{cell.frameNumber}</span>
              <span class="balls">
                {cell.balls.map((b, i) => (
                  i === activeBox ? (
                    <input
                      class="bbox bbox-input"
                      type="text"
                      name="shorthand"
                      value=""
                      maxlength="2"
                      autocomplete="off"
                      autocapitalize="characters"
                      autofocus
                      aria-label={`Frame ${frameNumber}, ball ${progress.nextBall}`}
                    />
                  ) : (
                    <span class:list={['bbox', { mark: b.kind === 'strike' || b.kind === 'spare', strike: b.kind === 'strike', spare: b.kind === 'spare', foul: b.kind === 'foul', empty: b.kind === 'empty' }]}>{b.text}</span>
                  )
                ))}
              </span>
              <span class:list={['total', { blank: cell.cumulative == null }]}>{cell.cumulative == null ? '—' : cell.cumulative}</span>
            </div>
          ) : (
            <a
              class:list={cls}
              href={frameHref(cell.frameNumber)}
              aria-current={isActive ? 'true' : undefined}
              aria-label={`Frame ${cell.frameNumber}${cell.cumulative != null ? `, ${cell.cumulative}` : ''}`}
            >
              <span class="fnum">{cell.frameNumber}</span>
              <span class="balls">
                {displayBalls(cell).map((b) => (
                  <span class:list={['bbox', { mark: b.kind === 'strike' || b.kind === 'spare', strike: b.kind === 'strike', spare: b.kind === 'spare', foul: b.kind === 'foul', empty: b.kind === 'empty' }]}>{b.text}</span>
                ))}
              </span>
              <span class:list={['total', { blank: cell.cumulative == null }]}>{cell.cumulative == null ? '—' : cell.cumulative}</span>
            </a>
          );
        })}
      </div>
    </div>
    {mode === 'type' && progress.nextBall != null && (
      <div class="type-controls">
        <button type="submit" class="secondary">Log Ball {progress.nextBall}</button>
      </div>
    )}
  </form>

  {!isWarmup && (
    <div class="scorecard">
      <div class="scorenow">
        <div class="row">
          <span class="n">{runningTotal ?? '—'}</span>
          <span class="lbl">{through ? `through ${through.frameNumber}` : 'no frames yet'}</span>
        </div>
        {scratchScore != null && sessionHandicap != null && (
          <span class="hcap">+ handicap {sessionHandicap} = <b>{scratchScore + sessionHandicap}</b></span>
        )}
      </div>
      <form class="finalscore" method="POST">
        <input type="hidden" name="intent" value="set_score" />
        <input type="hidden" name="mode" value={mode} />
        <label for="final_score">Final Score</label>
        <input
          id="final_score"
          type="number"
          name="final_score"
          min="0"
          max="300"
          value={game.final_score ?? ''}
          placeholder="&#8212;"
        />
        <button type="submit" class="secondary">Save</button>
      </form>
    </div>
  )}

  <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Now Bowling &middot; Frame {frameNumber}{progress.nextBall != null && ` · Ball ${progress.nextBall}`}{showFrameLane && ` · Lane ${frameLane}`}</h2></div>
  <div class="framenav-row">
    {prevFrame
      ? <a class="framenav" href={frameHref(prevFrame)} aria-label={`Go to frame ${prevFrame}`} rel="prev">&larr; Prev Frame</a>
      : <span class="framenav disabled" aria-hidden="true">&larr; Prev Frame</span>}
    {nextFrame
      ? <a class="framenav" href={frameHref(nextFrame)} aria-label={`Go to frame ${nextFrame}`} rel="next">Next Frame &rarr;</a>
      : <span class="framenav disabled" aria-hidden="true">Next Frame &rarr;</span>}
  </div>

  <details class="game-note" id="note">
    <summary>+ Add a Note</summary>
    <form method="POST" class="add-note">
      <input type="hidden" name="intent" value="add_note" />
      <input type="hidden" name="mode" value={mode} />
      <textarea name="body" rows="2" placeholder="Quick thought while bowling — lane read, adjustment, reminder…" aria-label="New note" required></textarea>
      <button type="submit" class="secondary">Add Note</button>
    </form>
  </details>

  {frameShots.length > 0 && (
    <ul class="ball-log">
      {frameShots.map((shot: any, i: number) => (
        <li>
          <a class="ball-row" href={`/sessions/${sessionId}/games/${gameId}/shots/${shot.id}?mode=${mode}`}>
            <span class="ball-ord">{ordinals[i] ?? `Ball ${i + 1}`} ball</span>
            <span class="ball-result">{ballResult(i)}</span>
            <span class="ball-detail">
              {[shot.balls?.name, shot.target_type && shot.target_value != null ? `${shot.target_type} ${shot.target_value}` : null, shot.hook_timing]
                .filter(Boolean)
                .join(' · ')}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}

  {leaveNotes.length > 0 && (
    <details class="leave-notes" open>
      <summary>Past Notes &middot; {leaveDisplayName(facedNow)} <span class="ln-count">({leaveNotes.length})</span></summary>
      <ul class="note-stream">
        {leaveNotesShown.map((note) => (
          <li><NoteCard note={note} /></li>
        ))}
      </ul>
      {leaveNotes.length > leaveNotesShown.length && (
        <a class="leave-more" href={`/notes?view=leave#${leaveAnchor(facedNow)}`}>See all {leaveNotes.length} &rarr;</a>
      )}
    </details>
  )}

  {progress.nextBall != null ? (
    mode === 'pick' ? (
      <>
        <p class="logball">+ Log Ball {progress.nextBall}</p>
        <ShotForm
          client:load
          balls={balls ?? []}
          approaches={approaches ?? []}
          frameNumber={frameNumber}
          startingPins={startingPins}
          allowStrike={marks.strike}
          allowSpare={marks.spare}
          defaultBallId={defaultBallId}
          defaultApproachId={defaultApproachId}
          mode={mode}
          hiddenFields={hiddenShotFields}
          submitLabel={`Log Ball ${progress.nextBall}`}
        />
      </>
    ) : (
      <p class="logball">Type ball {progress.nextBall} into frame {frameNumber} above, then press Enter.</p>
    )
  ) : strikeLockShot ? (
    <p class="framedone">
      Strike &mdash; frame {frameNumber} complete. To add a second ball,{' '}
      <a href={`/sessions/${sessionId}/games/${gameId}/shots/${strikeLockShot.id}?mode=${mode}`}>edit the strike</a> first.
    </p>
  ) : (
    <p class="framedone">
      Frame {frameNumber} complete.{' '}
      {nextFrame && <a href={frameHref(nextFrame)}>Go to frame {nextFrame} &rarr;</a>}
    </p>
  )}

  <hr />

  {isWarmup && !game.ended_early && (
    <form
      method="POST"
      class="row-actions"
      data-confirm="End practice? Everything logged so far stays saved -- you can still come back and add more."
      data-confirm-label="End Practice"
      data-confirm-style="secondary"
    >
      <input type="hidden" name="intent" value="end_practice_early" />
      <button type="submit" class="secondary">End Practice</button>
    </form>
  )}

  {canEndEarly && partialScore && (
    <form method="POST" class="row-actions" data-confirm={`End this game after frame ${partialScore.throughFrame} with a score of ${partialScore.score}? You can keep bowling later and re-save the score to correct it.`}>
      <input type="hidden" name="intent" value="end_practice_early" />
      <button type="submit" class="secondary">End Game Here &middot; Score {partialScore.score}</button>
    </form>
  )}

  {isWarmup ? (
    <form method="POST" class="row-actions" data-confirm="Discard this practice? Nothing logged will be saved.">
      <input type="hidden" name="intent" value="delete_game" />
      <button type="submit" class="danger">Close Without Logging</button>
    </form>
  ) : (
    <form method="POST" class="row-actions" data-confirm="Delete this game? Its throws and scores will be permanently removed.">
      <input type="hidden" name="intent" value="delete_game" />
      <button type="submit" class="danger">Delete Game</button>
    </form>
  )}

  <div class="retry-banner" id="retry-banner" role="alert" hidden>
    <span class="retry-msg">Couldn't reach the server — your ball is held here. Retry when the connection's back.</span>
    <button type="button" id="retry-send" class="secondary">Retry</button>
  </div>
</Layout>

<script>
  // Center the active frame in the horizontally-scrolling scoresheet on load,
  // so resuming late in a game (e.g. frame 8) doesn't leave it off-screen.
  const wrap = document.querySelector('.sheetwrap');
  const active = wrap?.querySelector('.cell.active');
  if (wrap instanceof HTMLElement && active instanceof HTMLElement) {
    const delta =
      active.getBoundingClientRect().left -
      wrap.getBoundingClientRect().left -
      (wrap.clientWidth - active.offsetWidth) / 2;
    wrap.scrollLeft += delta;
  }

  // Unsaved-shot guard: once you've started entering a ball — picked/toggled
  // pins, placed a reference mark, typed shorthand, or filled a detail field —
  // warn before navigating away (a frame nav, the mode toggle, an app-bar link,
  // or a browser back/refresh) so an in-progress shot isn't silently lost.
  // Logging the ball submits the entry form, which clears the guard.
  let shotDirty = false;
  const markDirty = () => {
    shotDirty = true;
  };
  // The pin-picker form (pick mode) and the shorthand box (type mode) are the
  // two shot-entry surfaces; other forms (note / final score / delete) are left
  // unguarded since they don't hold an in-progress throw.
  const entryForms = [
    document.querySelector('input[name="pins_standing"]')?.closest('form'),
    document.querySelector('input[name="shorthand"]')?.closest('form'),
  ];
  // Retry guard: the entry forms submit via fetch() so a dropped connection at
  // the alley keeps this page — and the throw's data — alive behind a Retry
  // button, instead of dumping to the browser's dead error page. The pending
  // throw is held in memory only: on failure the page never unloads, so there
  // is nothing to persist. The throw stays "dirty" (beforeunload still warns)
  // until the server confirms it with a redirect.
  const banner = document.getElementById('retry-banner');
  const retryBtn = document.getElementById('retry-send');
  let pending: { form: HTMLFormElement; data: FormData } | null = null;
  let sending = false;

  function showRetry() {
    sending = false;
    if (retryBtn instanceof HTMLButtonElement) {
      retryBtn.disabled = false;
      retryBtn.textContent = 'Retry';
    }
    if (banner) banner.hidden = false;
  }

  async function send() {
    if (!pending || sending) return;
    sending = true;
    if (retryBtn instanceof HTMLButtonElement) {
      retryBtn.disabled = true;
      retryBtn.textContent = 'Retrying…';
    }

    // a flaky connection can also hang forever — give up after 15s and offer Retry
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 15000);
    let response: Response;
    try {
      response = await fetch(window.location.href, {
        method: 'POST',
        body: pending.data,
        credentials: 'same-origin',
        signal: ctrl.signal,
      });
    } catch {
      showRetry();
      return;
    } finally {
      clearTimeout(timer);
    }

    if (response.redirected) {
      // the shot saved — the redirect target is the next frame (auto-advance included)
      shotDirty = false;
      pending = null;
      window.location.assign(response.url);
      return;
    }

    if (response.ok) {
      // 200 without a redirect = the server re-rendered this page with a
      // validation message (shot cap, bad shorthand) and inserted nothing. The
      // connection is clearly alive, so hand back to a native submit to show
      // that message the normal way (form.submit() skips this interceptor).
      const failedForm = pending.form;
      pending = null;
      sending = false;
      shotDirty = false; // don't let beforeunload second-guess the native submit
      failedForm.submit();
      return;
    }

    showRetry();
  }

  for (const form of entryForms) {
    if (!(form instanceof HTMLFormElement)) continue;
    form.addEventListener('input', markDirty);
    form.addEventListener('change', markDirty);
    form.addEventListener('click', (e) => {
      // pin toggles / shortcuts and LanePicker taps register as button or svg
      // clicks (the submit button is excluded — it submits the throw instead)
      if (e.target instanceof Element && e.target.closest('button:not([type="submit"]), svg')) {
        markDirty();
      }
    });
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (sending) return; // ignore double-taps while a send is in flight
      if (banner) banner.hidden = true;
      pending = { form, data: new FormData(form) };
      void send();
    });
  }

  if (retryBtn) retryBtn.addEventListener('click', () => void send());

  window.addEventListener('beforeunload', (e) => {
    if (shotDirty) {
      e.preventDefault();
      e.returnValue = '';
    }
  });
</script>

<style>
  .game-note {
    margin: 0.5rem 0 1rem;
  }
  .game-note summary {
    cursor: pointer;
    color: var(--accent);
    font-weight: 600;
  }
  .add-note {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .add-note button {
    align-self: flex-start;
  }
  .leave-notes {
    margin: 0.5rem 0 1rem;
  }
  .leave-notes > summary {
    cursor: pointer;
    color: var(--accent);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .leave-notes .ln-count {
    color: var(--text-muted);
    font-weight: 400;
  }
  .leave-notes .note-stream {
    margin-top: 0.6rem;
  }
  .note-stream {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .leave-more {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    font-weight: 600;
  }
  .retry-banner {
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    bottom: calc(var(--s4) + var(--tabbar-clearance));
    z-index: 50;
    display: flex;
    align-items: center;
    gap: var(--s3);
    width: max-content;
    max-width: min(440px, calc(100vw - 2rem));
    padding: var(--s3) var(--s4);
    background: var(--surface);
    border: 1px solid var(--coral);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }
  .retry-banner[hidden] { display: none; }
  .retry-msg { font-size: var(--text-sm); color: var(--text-primary); }
  .retry-banner button { flex: none; }
</style>
