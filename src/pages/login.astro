---
import Layout from '../layouts/Layout.astro';

let error: string | null = null;
const notice = Astro.url.searchParams.get('reset') === '1' ? 'Your password has been updated. Log in with your new password.' : null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString() ?? '';
  const password = formData.get('password')?.toString() ?? '';

  if (!email || !password) {
    error = 'Email and password are required.';
  } else {
    const { error: signInError } = await Astro.locals.supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (signInError) {
      error = signInError.message;
    } else {
      return Astro.redirect('/dashboard');
    }
  }
}
---

<Layout title="Log In">
  <h1>Log In</h1>

  {error && <p class="error">{error}</p>}
  {notice && <p class="notice">{notice}</p>}

  <form method="POST" data-pending-label="Logging In…">
    <label>
      Email
      <input type="email" name="email" required autocomplete="email" />
    </label>
    <label>
      Password
      <input type="password" name="password" required autocomplete="current-password" />
    </label>
    <button type="submit">Log In</button>
  </form>

  <p class="switch"><a href="/forgot-password">Forgot your password?</a></p>
  <p class="switch">Need an account? <a href="/signup">Sign Up</a></p>
</Layout>
