---
import Layout from '../layouts/Layout.astro';
import { SHOT_FIELDS, SHOT_FIELD_KEYS } from '../lib/shotFields';
import { APPROACH_FIELDS, APPROACH_FIELD_KEYS } from '../lib/approachFields';

const { supabase, user } = Astro.locals;

let error: string | null = null;
let saved = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const display_name = formData.get('display_name')?.toString().trim() || null;
  const default_ball_id = formData.get('default_ball_id')?.toString() || null;
  const default_spare_ball_id = formData.get('default_spare_ball_id')?.toString() || null;
  const default_entry_mode = formData.get('default_entry_mode')?.toString() === 'type' ? 'type' : 'pick';
  // each shown checkbox posts show_<key>='on'; anything not checked is hidden
  const hidden_shot_fields = SHOT_FIELD_KEYS.filter((key) => formData.get(`show_${key}`) !== 'on');
  const hidden_approach_fields = APPROACH_FIELD_KEYS.filter((key) => formData.get(`approach_show_${key}`) !== 'on');

  const { error: updateError } = await supabase
    .from('profiles')
    .update({ display_name, default_ball_id, default_spare_ball_id, default_entry_mode, hidden_shot_fields, hidden_approach_fields })
    .eq('id', user!.id);

  if (updateError) {
    error = updateError.message;
  } else {
    saved = true;
  }
}

const { data: profile } = await supabase
  .from('profiles')
  .select('display_name, default_ball_id, default_spare_ball_id, default_entry_mode, hidden_shot_fields, hidden_approach_fields')
  .eq('id', user!.id)
  .maybeSingle();

const entryMode = profile?.default_entry_mode === 'type' ? 'type' : 'pick';
const hiddenShotFields: string[] = profile?.hidden_shot_fields ?? [];
const hiddenApproachFields: string[] = profile?.hidden_approach_fields ?? [];

const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const hasBalls = (balls?.length ?? 0) > 0;
---

<Layout title="Settings">
  <nav class="top"><a href="/dashboard">&larr; Dashboard</a></nav>
  <h1>Settings</h1>

  {error && <p class="error">{error}</p>}
  {saved && <p class="empty">Settings saved.</p>}

  <form method="POST">
    <label>
      Display Name
      <input type="text" name="display_name" value={profile?.display_name ?? ''} />
    </label>

    <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Score Entry</h2></div>
    <p class="empty">How a game opens for logging. You can switch modes any time with the toggle above the scoresheet.</p>
    <label>
      Default Entry Mode
      <select name="default_entry_mode">
        <option value="pick" selected={entryMode === 'pick'}>Pick pins — tap the pin diagram</option>
        <option value="type" selected={entryMode === 'type'}>Type — type the result into the frame</option>
      </select>
    </label>

    <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Shot Logger Fields</h2></div>
    <p class="empty">Choose which optional details show when logging a shot. Pins, strike/spare, and ball are always shown. Editing an existing shot always shows every field so nothing is hidden.</p>
    <div class="toggle-actions">
      <button type="button" class="secondary" data-grid="shot-fields" data-check="on">Select All</button>
      <button type="button" class="secondary" data-grid="shot-fields" data-check="off">Clear All</button>
    </div>
    <div class="field-toggles" id="shot-fields">
      {SHOT_FIELDS.map((f) => (
        <label class="check">
          <input type="checkbox" name={`show_${f.key}`} checked={!hiddenShotFields.includes(f.key)} />
          {f.label}
        </label>
      ))}
    </div>

    <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Approach Fields</h2></div>
    <p class="empty">Choose which optional details show on the add/edit approach form. Name and leave are always shown. A field you hide keeps any value it already had — unhide it to change that value.</p>
    <div class="toggle-actions">
      <button type="button" class="secondary" data-grid="approach-fields" data-check="on">Select All</button>
      <button type="button" class="secondary" data-grid="approach-fields" data-check="off">Clear All</button>
    </div>
    <div class="field-toggles" id="approach-fields">
      {APPROACH_FIELDS.map((f) => (
        <label class="check">
          <input type="checkbox" name={`approach_show_${f.key}`} checked={!hiddenApproachFields.includes(f.key)} />
          {f.label}
        </label>
      ))}
    </div>

    <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Default Balls</h2></div>
    <p class="empty">Used to pre-fill the ball for each throw when you start a new session. You can override it per session and per shot.</p>

    {hasBalls ? (
      <>
        <label>
          Default Ball (Fresh Rack)
          <select name="default_ball_id">
            <option value="">None</option>
            {balls!.map((ball) => (
              <option value={ball.id} selected={ball.id === profile?.default_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
        <label>
          Default Spare Ball
          <select name="default_spare_ball_id">
            <option value="">None</option>
            {balls!.map((ball) => (
              <option value={ball.id} selected={ball.id === profile?.default_spare_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
      </>
    ) : (
      <p class="empty">Add a ball on <a href="/balls">My Balls</a> first to set your defaults.</p>
    )}

    <button type="submit">Save Settings</button>
  </form>

  <script>
    // Each Select All / Clear All button targets its own grid by id, so the two
    // field grids (shot logger + approach) toggle independently.
    document.querySelectorAll<HTMLButtonElement>('.toggle-actions button[data-grid]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const grid = document.getElementById(btn.dataset.grid!);
        const checked = btn.dataset.check === 'on';
        grid?.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((box) => (box.checked = checked));
      });
    });
  </script>
</Layout>
