---
import Layout from '../layouts/Layout.astro';

const { supabase, user } = Astro.locals;

let error: string | null = null;
let saved = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const display_name = formData.get('display_name')?.toString().trim() || null;
  const default_ball_id = formData.get('default_ball_id')?.toString() || null;
  const default_spare_ball_id = formData.get('default_spare_ball_id')?.toString() || null;

  const { error: updateError } = await supabase
    .from('profiles')
    .update({ display_name, default_ball_id, default_spare_ball_id })
    .eq('id', user!.id);

  if (updateError) {
    error = updateError.message;
  } else {
    saved = true;
  }
}

const { data: profile } = await supabase
  .from('profiles')
  .select('display_name, default_ball_id, default_spare_ball_id')
  .eq('id', user!.id)
  .maybeSingle();

const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const hasBalls = (balls?.length ?? 0) > 0;
---

<Layout title="Settings">
  <nav class="top"><a href="/dashboard">&larr; Dashboard</a></nav>
  <h1>Settings</h1>

  {error && <p class="error">{error}</p>}
  {saved && <p class="empty">Settings saved.</p>}

  <form method="POST">
    <label>
      Display Name
      <input type="text" name="display_name" value={profile?.display_name ?? ''} />
    </label>

    <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Default Balls</h2></div>
    <p class="empty">Used to pre-fill the ball for each throw when you start a new session. You can override it per session and per shot.</p>

    {hasBalls ? (
      <>
        <label>
          Default Ball (fresh rack)
          <select name="default_ball_id">
            <option value="">None</option>
            {balls!.map((ball) => (
              <option value={ball.id} selected={ball.id === profile?.default_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
        <label>
          Default Spare Ball
          <select name="default_spare_ball_id">
            <option value="">None</option>
            {balls!.map((ball) => (
              <option value={ball.id} selected={ball.id === profile?.default_spare_ball_id}>{ball.name}</option>
            ))}
          </select>
        </label>
      </>
    ) : (
      <p class="empty">Add a ball on <a href="/balls">My Balls</a> first to set your defaults.</p>
    )}

    <button type="submit">Save Settings</button>
  </form>
</Layout>
