---
import Layout from '../layouts/Layout.astro';

let error: string | null = null;
let notice: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString().trim() ?? '';

  if (!email) {
    error = 'Email is required.';
  } else {
    await Astro.locals.supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${Astro.url.origin}/reset-password`,
    });
    // Supabase's response doesn't reveal whether the email is registered --
    // same message either way, so this can't be used to probe for accounts.
    notice = "If an account exists for that email, we've sent a password reset link.";
  }
}
---

<Layout title="Reset Password">
  <h1>Reset Password</h1>

  {error && <p class="error">{error}</p>}

  {notice ? (
    <p class="notice">{notice}</p>
  ) : (
    <>
      <p class="empty">Enter your account email and we'll send you a link to set a new password.</p>
      <form method="POST">
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <button type="submit">Send Reset Link</button>
      </form>
    </>
  )}

  <p class="switch"><a href="/login">Back to Log In</a></p>
</Layout>
