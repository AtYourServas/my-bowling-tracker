---
import Layout from '../layouts/Layout.astro';

const { supabase } = Astro.locals;

let error: string | null = null;
// Set once the recovery code has been exchanged for a session (this request
// or an earlier one on this same visit) -- required before a new password
// can be saved.
let linkValid = Astro.locals.user != null;

const code = Astro.url.searchParams.get('code');
if (code && !linkValid) {
  const { error: exchangeError } = await supabase.auth.exchangeCodeForSession(code);
  if (exchangeError) {
    error = 'This reset link is invalid or has expired. Request a new one.';
  } else {
    linkValid = true;
  }
}

if (Astro.request.method === 'POST') {
  if (!linkValid) {
    error = 'This reset link is invalid or has expired. Request a new one.';
  } else {
    const formData = await Astro.request.formData();
    const new_password = formData.get('new_password')?.toString() ?? '';
    const confirm_password = formData.get('confirm_password')?.toString() ?? '';

    if (!new_password || new_password !== confirm_password) {
      error = 'Passwords must match.';
    } else if (new_password.length < 6) {
      error = 'Password must be at least 6 characters.';
    } else {
      const { error: updateError } = await supabase.auth.updateUser({ password: new_password });

      if (updateError) {
        error = updateError.message;
      } else {
        // sign out so the reset ends at a fresh login with the new password,
        // rather than leaving the recovery session active
        await supabase.auth.signOut();
        return Astro.redirect('/login?reset=1');
      }
    }
  }
}
---

<Layout title="Set New Password">
  <h1>Set New Password</h1>

  {error && <p class="error">{error}</p>}

  {linkValid ? (
    <form method="POST" data-pending-label="Updating…">
      <label>
        New Password
        <input type="password" name="new_password" required minlength="6" autocomplete="new-password" />
      </label>
      <label>
        Confirm New Password
        <input type="password" name="confirm_password" required minlength="6" autocomplete="new-password" />
      </label>
      <button type="submit">Update Password</button>
    </form>
  ) : (
    <p class="empty"><a href="/forgot-password">Request a new reset link</a>.</p>
  )}
</Layout>
