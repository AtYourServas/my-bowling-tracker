---
import Layout from '../../layouts/Layout.astro';
import {
  fetchAllGamesWithScores,
  fetchStatFrames,
  filterScoredGames,
  computeHandicapTrend,
  computeRateStats,
  average,
} from '../../lib/stats';
import { buildSessionHandicapResolver } from '../../lib/handicap';

const { supabase } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete') {
    const { error: deleteError } = await supabase.from('leagues').delete().eq('id', id);
    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/leagues');
    }
  } else {
    const name = formData.get('name')?.toString().trim() ?? '';
    const team_name = formData.get('team_name')?.toString().trim() || null;
    const basisRaw = formData.get('handicap_basis')?.toString().trim();
    const handicap_basis = basisRaw ? Number(basisRaw) : 200;
    const percentRaw = formData.get('handicap_percent')?.toString().trim();
    const handicap_percent = percentRaw ? Number(percentRaw) / 100 : 0.8;
    const handicap_type = formData.get('handicap_type')?.toString() || 'rolling';
    const bookAvgRaw = formData.get('book_average')?.toString().trim();
    const book_average = bookAvgRaw ? Number(bookAvgRaw) : null;
    const notes = formData.get('notes')?.toString().trim() || null;

    if (!name) {
      error = 'League name is required.';
    } else {
      const { error: updateError } = await supabase
        .from('leagues')
        .update({ name, team_name, handicap_basis, handicap_percent, handicap_type, book_average, notes })
        .eq('id', id);

      if (updateError) {
        error = updateError.message;
      } else {
        return Astro.redirect('/leagues');
      }
    }
  }
}

const { data: league } = await supabase.from('leagues').select('*').eq('id', id).maybeSingle();

if (!league) {
  return Astro.redirect('/leagues');
}

// Your stats in this league vs. your other leagues combined -- there's no
// other-bowlers' data anywhere in this app (leagues are private per
// account), so "compared to others" means compared to your own other
// leagues. filterScoredGames/frameInFilter only support matching ONE
// leagueId, not "any other league", so the other-leagues buckets are plain
// filters instead.
const [allGamesEver, allFrames] = await Promise.all([fetchAllGamesWithScores(supabase), fetchStatFrames(supabase)]);
const handicapOf = await buildSessionHandicapResolver(supabase, allGamesEver);

const thisLeagueGames = filterScoredGames(allGamesEver, { includePracticeSessions: false, leagueId: id });
const otherLeagueGames = allGamesEver.filter(
  (g) => !g.isPractice && g.sessionType === 'league' && g.leagueId && g.leagueId !== id,
);

const avgScoreThis = average(thisLeagueGames.map((g) => g.score));
const avgScoreOther = average(otherLeagueGames.map((g) => g.score));

const avgHandicapThis = average(computeHandicapTrend(thisLeagueGames, handicapOf).map((p) => p.handicap));
const avgHandicapOther = average(computeHandicapTrend(otherLeagueGames, handicapOf).map((p) => p.handicap));

const rateThis = computeRateStats(allFrames, { includePracticeSessions: false, leagueId: id });
const otherFrames = allFrames.filter((f) => !f.isPractice && f.sessionType === 'league' && f.leagueId && f.leagueId !== id);
const rateOther = computeRateStats(otherFrames, { includePracticeSessions: false, leagueId: null });

const sparePctThis = rateThis && rateThis.spareOpportunities > 0 ? (rateThis.spares / rateThis.spareOpportunities) * 100 : null;
const sparePctOther = rateOther && rateOther.spareOpportunities > 0 ? (rateOther.spares / rateOther.spareOpportunities) * 100 : null;
---

<Layout title={league.name}>
  <nav class="top"><a href="/leagues">&larr; My Leagues</a></nav>
  <h1>Edit League</h1>

  {error && <p class="error">{error}</p>}

  <div class="league-compare">
    <h2>Your Stats in This League</h2>
    {avgScoreThis == null && avgScoreOther == null ? (
      <p class="empty">No league games logged yet.</p>
    ) : (
      <table class="compare-table">
        <thead>
          <tr>
            <th></th>
            <th>This League</th>
            <th>Your Other Leagues</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Average Score</td>
            <td>
              {avgScoreThis != null ? avgScoreThis.toFixed(1) : '—'}
              <span class="compare-sub"> ({thisLeagueGames.length} games)</span>
            </td>
            <td>
              {avgScoreOther != null ? avgScoreOther.toFixed(1) : '—'}
              <span class="compare-sub"> ({otherLeagueGames.length} games)</span>
            </td>
          </tr>
          {(avgHandicapThis != null || avgHandicapOther != null) && (
            <tr>
              <td>Average Handicap</td>
              <td>{avgHandicapThis != null ? avgHandicapThis.toFixed(1) : '—'}</td>
              <td>{avgHandicapOther != null ? avgHandicapOther.toFixed(1) : '—'}</td>
            </tr>
          )}
          <tr>
            <td>Spare Conversion</td>
            <td>
              {sparePctThis != null ? `${sparePctThis.toFixed(0)}%` : '—'}
              <span class="compare-sub"> ({rateThis?.spareOpportunities ?? 0} leaves)</span>
            </td>
            <td>
              {sparePctOther != null ? `${sparePctOther.toFixed(0)}%` : '—'}
              <span class="compare-sub"> ({rateOther?.spareOpportunities ?? 0} leaves)</span>
            </td>
          </tr>
        </tbody>
      </table>
    )}
  </div>

  <hr />

  <form method="POST">
    <label>
      Name
      <input type="text" name="name" required value={league.name} />
    </label>
    <label>
      Team Name
      <input type="text" name="team_name" value={league.team_name ?? ''} placeholder="auto-fills new sessions" />
    </label>
    <label>
      Handicap Basis
      <input type="number" name="handicap_basis" value={league.handicap_basis} />
    </label>
    <label>
      Handicap Percentage
      <input type="number" name="handicap_percent" value={Math.round(league.handicap_percent * 100)} min="0" max="100" />
    </label>
    <label>
      Handicap Type
      <select name="handicap_type">
        <option value="rolling" selected={league.handicap_type === 'rolling'}>Rolling average (recalculated week to week from prior weeks)</option>
        <option value="book_average" selected={league.handicap_type === 'book_average'}>Book average (fixed value I set)</option>
        <option value="manual" selected={league.handicap_type === 'manual'}>Manual entry (I type the number each week)</option>
      </select>
    </label>
    <label>
      Book Average (only used for Book Average type)
      <input type="number" name="book_average" value={league.book_average ?? ''} />
    </label>
    <label>
      Notes
      <textarea name="notes" rows="2">{league.notes ?? ''}</textarea>
    </label>
    <button type="submit">Save Changes</button>
  </form>

  <form method="POST" class="row-actions" data-confirm={`Delete "${league.name}"? Sessions already linked to this league keep their data, but you won't be able to start new ones under it.`}>
    <input type="hidden" name="intent" value="delete" />
    <button type="submit" class="danger">Delete League</button>
  </form>
</Layout>

<style>
  .compare-table {
    width: 100%;
    border-collapse: collapse;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: var(--s2) var(--s3);
    border-bottom: 1px solid var(--border);
  }
  .compare-table th {
    color: var(--text-muted);
    font-weight: var(--fw-med);
    font-size: var(--text-sm);
  }
  .compare-sub {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }
</style>
