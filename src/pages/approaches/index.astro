---
import Layout from '../../layouts/Layout.astro';
import LeavePicker from '../../components/LeavePicker';
import { leaveLabel, isSpareLeave } from '../../lib/leaves';
import { markLabel, targetLabel } from '../../lib/marks';

const { supabase } = Astro.locals;

const params = Astro.url.searchParams;
const filterBall = params.get('ball') ?? '';
const filterKind = params.get('kind') ?? ''; // '', 'strike', 'spare'
const filterPins = (params.get('pins') ?? '')
  .split(',')
  .map(Number)
  .filter((n) => n >= 1 && n <= 10);
const hasFilters = Boolean(filterBall || filterKind || filterPins.length);

let approachesQuery = supabase
  .from('approaches')
  .select('*, balls(name)')
  .order('created_at', { ascending: false });

if (filterBall) {
  approachesQuery = approachesQuery.eq('reference_ball_id', filterBall);
}

const { data: allApproaches } = await approachesQuery;

// Kind (derived from leave) and the pin-selector filter run in memory: strike =
// no leave, spare = has leave; the pin filter keeps approaches whose leave
// includes every highlighted pin.
const approaches = (allApproaches ?? []).filter((a: any) => {
  const leave: number[] = a.leave ?? [];
  if (filterKind === 'strike' && isSpareLeave(leave)) return false;
  if (filterKind === 'spare' && !isSpareLeave(leave)) return false;
  if (filterPins.length && !filterPins.every((p) => leave.includes(p))) return false;
  return true;
});

const { data: balls } = await supabase.from('balls').select('id, name').order('name');
---

<Layout title="My Approaches">
  <nav class="top"><a href="/dashboard">&larr; Dashboard</a></nav>
  <div class="page-head">
    <h1>My Approaches</h1>
    <a class="button" href="/approaches/new">Add a Saved Approach</a>
  </div>

  <details class="filter-collapse" open={hasFilters}>
  <summary>
    Filters
    {hasFilters && <span class="filter-badge">Active</span>}
  </summary>
  <form method="GET" class="filter-form">
    {balls && balls.length > 0 && (
      <label>
        Ball
        <select name="ball">
          <option value="">All</option>
          {balls.map((ball) => (
            <option value={ball.id} selected={ball.id === filterBall}>{ball.name}</option>
          ))}
        </select>
      </label>
    )}
    <label>
      Kind
      <select name="kind">
        <option value="" selected={!filterKind}>All</option>
        <option value="strike" selected={filterKind === 'strike'}>Strike</option>
        <option value="spare" selected={filterKind === 'spare'}>Spare</option>
      </select>
    </label>
    <div class="pin-filter">
      <span class="pin-filter-label">Leave</span>
      <LeavePicker client:load variant="filter" fieldName="pins" initialLeave={filterPins} />
    </div>
    <button type="submit">Filter</button>
    {hasFilters && <a href="/approaches">Clear Filters</a>}
  </form>
  </details>

  {approaches.length > 0 ? (
    <ul class="list">
      {approaches.map((approach: any) => (
        <li>
          <a class="card" href={`/approaches/${approach.id}`}>
            <strong>{approach.name}</strong>
            <span class="leave-tag">{leaveLabel(approach.leave)}</span>
            {approach.balls?.name && <span>Ball: {approach.balls.name}</span>}
            {approach.reference_lineup && <span>Alignment (Starting Point): {markLabel(approach.reference_lineup)}</span>}
            {approach.reference_target_type && approach.reference_target_value != null && (
              <span>Visual Target: {targetLabel(approach.reference_target_type, approach.reference_target_value)}</span>
            )}
            {approach.reference_slide && <span>Slide Position (Finish): {markLabel(approach.reference_slide)}</span>}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">
      {hasFilters ? 'No approaches match those filters.' : 'No approaches yet.'} <a href="/approaches/new">Add a Saved Approach</a>.
    </p>
  )}
</Layout>

<style>
  .filter-collapse {
    margin: var(--s3) 0;
  }
  .filter-collapse > summary {
    display: flex;
    align-items: center;
    gap: var(--s2);
    cursor: pointer;
    list-style: none;
    padding: var(--s2) var(--s3);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .filter-collapse > summary::-webkit-details-marker { display: none; }
  .filter-collapse > summary::after {
    content: '▾';
    margin-left: auto;
    transition: transform 0.15s ease;
  }
  .filter-collapse[open] > summary::after { transform: rotate(180deg); }
  .filter-collapse[open] > summary {
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
  }
  .filter-collapse > .filter-form {
    margin-top: 0;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
  .filter-badge {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--accent);
  }
  .leave-tag {
    font-weight: 600;
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }
  .pin-filter {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .pin-filter-label {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
</style>
