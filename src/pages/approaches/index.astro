---
import Layout from '../../layouts/Layout.astro';

const { supabase } = Astro.locals;

const filterBall = Astro.url.searchParams.get('ball') ?? '';

let approachesQuery = supabase
  .from('approaches')
  .select('*, balls(name)')
  .order('created_at', { ascending: false });

if (filterBall) {
  approachesQuery = approachesQuery.eq('reference_ball_id', filterBall);
}

const { data: approaches } = await approachesQuery;

const { data: balls } = await supabase.from('balls').select('id, name').order('name');
---

<Layout title="My Approaches">
  <nav class="top"><a href="/dashboard">&larr; Dashboard</a></nav>
  <div class="page-head">
    <h1>My Approaches</h1>
    <a class="button" href="/approaches/new">+ Add Approach</a>
  </div>

  {balls && balls.length > 0 && (
    <form method="GET" class="filter-form">
      <label>
        Ball
        <select name="ball">
          <option value="">All</option>
          {balls.map((ball) => (
            <option value={ball.id} selected={ball.id === filterBall}>{ball.name}</option>
          ))}
        </select>
      </label>
      <button type="submit">Filter</button>
      {filterBall && <a href="/approaches">Clear Filter</a>}
    </form>
  )}

  {approaches && approaches.length > 0 ? (
    <ul class="list">
      {approaches.map((approach: any) => (
        <li>
          <a class="card" href={`/approaches/${approach.id}`}>
            <strong>{approach.name}</strong>
            {approach.balls?.name && <span>Ball: {approach.balls.name}</span>}
            {approach.reference_lineup && <span>Alignment (Starting Point): {approach.reference_lineup}</span>}
            {approach.reference_target_type && approach.reference_target_value != null && (
              <span>Visual Target: {approach.reference_target_type} {approach.reference_target_value}</span>
            )}
            {approach.reference_slide && <span>Slide Position (Finish): {approach.reference_slide}</span>}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="empty">
      {filterBall ? 'No approaches use that ball.' : 'No approaches yet.'} <a href="/approaches/new">Add an Approach</a>.
    </p>
  )}
</Layout>
