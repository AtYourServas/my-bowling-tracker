---
import Layout from '../../layouts/Layout.astro';
import LanePicker from '../../components/LanePicker';
import LeavePicker from '../../components/LeavePicker';

const APPROACH_NAMES = {
  lineup: 'reference_lineup',
  targetType: 'reference_target_type',
  targetValue: 'reference_target_value',
  slide: 'reference_slide',
};
const APPROACH_MARKS = ['stance', 'target', 'slide'] as const;

/** Parse a stored mark (text or numeric) into a board number for the picker. */
function toBoard(v: string | number | null | undefined): number | null {
  if (v == null || v === '') return null;
  const n = typeof v === 'number' ? v : Number(v);
  return Number.isFinite(n) ? n : null;
}

/** Interpret a legacy 'arrow' target value as a board. Bowlers name arrows by
 *  the board they sit on (the 5th arrow is board 25), so a value over 7 is
 *  already a board; only a small arrow index (1-7) is scaled up (arrow N = board 5N). */
function arrowToBoard(v: string | number | null | undefined): number | null {
  const n = toBoard(v);
  if (n == null) return null;
  return n <= 7 ? n * 5 : n;
}

const { supabase, user } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete') {
    const { error: deleteError } = await supabase.from('approaches').delete().eq('id', id);
    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/approaches');
    }
  } else {
    const name = formData.get('name')?.toString().trim() ?? '';
    const leaveRaw = formData.get('leave')?.toString() ?? '';
    const leave = leaveRaw
      ? leaveRaw.split(',').map(Number).filter((n) => n >= 1 && n <= 10)
      : [];

    if (!name) {
      error = 'Approach name is required.';
    } else {
      // Only overwrite the fields actually rendered on the form. A hidden field
      // (profiles.hidden_approach_fields) posts no input, so it's left out of the
      // update and keeps its stored value instead of being wiped to null. Name
      // and leave are always shown, so always update.
      const update: Record<string, unknown> = { name, leave };
      if (formData.has('reference_ball_id')) {
        update.reference_ball_id = formData.get('reference_ball_id')?.toString() || null;
      }
      if (formData.has('reference_lineup')) {
        update.reference_lineup = formData.get('reference_lineup')?.toString().trim() || null;
      }
      if (formData.has('reference_target_type')) {
        update.reference_target_type = formData.get('reference_target_type')?.toString() || null;
        const targetValueRaw = formData.get('reference_target_value')?.toString().trim();
        update.reference_target_value = targetValueRaw ? Number(targetValueRaw) : null;
      }
      if (formData.has('reference_slide')) {
        update.reference_slide = formData.get('reference_slide')?.toString().trim() || null;
      }
      if (formData.has('notes')) {
        update.notes = formData.get('notes')?.toString().trim() || null;
      }

      const { error: updateError } = await supabase.from('approaches').update(update).eq('id', id);

      if (updateError) {
        error = updateError.message;
      } else {
        return Astro.redirect('/approaches');
      }
    }
  }
}

const { data: approach } = await supabase.from('approaches').select('*').eq('id', id).maybeSingle();

if (!approach) {
  return Astro.redirect('/approaches');
}

const { data: balls } = await supabase.from('balls').select('id, name').order('name');

// profile preference: optional approach fields the bowler has hidden (PR 37).
// A hidden mark drops its LanePicker strip; a hidden field isn't rendered. The
// POST above preserves any stored value a hidden field already had.
const { data: prefRow } = await supabase
  .from('profiles')
  .select('hidden_approach_fields')
  .eq('id', user!.id)
  .maybeSingle();
const hiddenFields: string[] = prefRow?.hidden_approach_fields ?? [];
const show = (key: string) => !hiddenFields.includes(key);
const shownMarks = APPROACH_MARKS.filter((m) => show(m));

// seed the lane picker from the stored approach. An older 'arrow' target maps to
// its board via arrowToBoard; a 'pin' target can't be placed.
const initialTarget =
  approach.reference_target_type === 'board'
    ? toBoard(approach.reference_target_value)
    : approach.reference_target_type === 'arrow'
      ? arrowToBoard(approach.reference_target_value)
      : null;
---

<Layout title={approach.name}>
  <nav class="top"><a href="/approaches">&larr; My Approaches</a></nav>
  <h1>Edit Approach</h1>

  {error && <p class="error">{error}</p>}

  <form method="POST">
    <label>
      Name
      <input type="text" id="approach-name" name="name" required value={approach.name} />
    </label>
    {show('ball') && (
      <label>
        Reference Ball
        <select name="reference_ball_id">
          <option value="">None</option>
          {balls?.map((ball) => (
            <option value={ball.id} selected={ball.id === approach.reference_ball_id}>
              {ball.name}
            </option>
          ))}
        </select>
      </label>
    )}
    <div class="sechead-mini"><span class="chev"><i></i><i></i><i></i></span><h3>Leave</h3></div>
    <LeavePicker client:load initialLeave={approach.leave ?? []} />
    {shownMarks.length > 0 && (
      <>
        <div class="sechead-mini"><span class="chev"><i></i><i></i><i></i></span><h3>Reference Marks</h3></div>
        <LanePicker
          client:load
          names={APPROACH_NAMES}
          marks={shownMarks}
          initialLineup={toBoard(approach.reference_lineup)}
          initialTarget={initialTarget}
          initialSlide={toBoard(approach.reference_slide)}
        />
      </>
    )}

    {show('notes') && (
      <label>
        Notes
        <textarea name="notes" rows="3">{approach.notes ?? ''}</textarea>
      </label>
    )}
    <button type="submit">Save Changes</button>
  </form>

  <form method="POST" class="row-actions" data-confirm={`Delete "${approach.name}"? This can't be undone.`}>
    <input type="hidden" name="intent" value="delete" />
    <button type="submit" class="danger">Delete Approach</button>
  </form>
</Layout>
