---
import Layout from '../layouts/Layout.astro';
import MiniScoresheet from '../components/MiniScoresheet.astro';
import { fetchMiniScoresheets, fetchEarliestIncompleteFrame, type MiniSheet } from '../lib/scoring';
import { fetchAllGamesWithScores, filterScoredGames, average } from '../lib/stats';

const { supabase, user } = Astro.locals;

const todayStr = new Date().toISOString().slice(0, 10);

// ---- Onboarding dismissal / Start League Night / Start Practice --------------
// Re-tapping either start button (e.g. a double-tap) should land on tonight's
// game, not spawn a second session -- reuses today's session of the same type
// (same league, for league night) if one already exists, and its earliest
// open game if there is one.
type GameStub = { id: string; final_score: number | null };

async function findOrCreateOpenGame(
  sessionType: 'league' | 'practice',
  leagueId: string | null,
  insertFields: Record<string, unknown>,
): Promise<string> {
  let existingQuery = supabase
    .from('sessions')
    .select('id, games(id, final_score, created_at)')
    .eq('session_date', todayStr)
    .eq('session_type', sessionType);
  if (leagueId) existingQuery = existingQuery.eq('league_id', leagueId);
  const { data: existing } = await existingQuery
    .order('created_at', { ascending: false })
    .limit(1)
    .maybeSingle<{ id: string; games: GameStub[] }>();

  let sessionId = existing?.id ?? null;
  if (!sessionId) {
    const { data: created } = await supabase.from('sessions').insert(insertFields).select('id').single();
    sessionId = created?.id ?? null;
  }

  if (!sessionId) return '/sessions/new';

  const games = existing?.games ?? [];

  let openGame: GameStub | null;
  if (sessionType === 'practice') {
    // Practice sessions hold any number of freeform games -- a finished one
    // (manual score, or all 10 frames resolved) should never block starting
    // the next, so re-tapping Start Practice always lands on unfinished work
    // instead of reopening an already-complete game.
    const sheets = games.length ? await fetchMiniScoresheets(supabase, games.map((g) => g.id)) : new Map<string, MiniSheet>();
    const isComplete = (g: GameStub) => g.final_score != null || (sheets.get(g.id)?.cells[9]?.cumulative ?? null) != null;
    openGame = games.find((g) => !isComplete(g)) ?? null;
  } else {
    // League night always targets the "Game 1" slot -- Games 2/3 are added
    // from the session page once Game 1 is underway.
    openGame = games.find((g) => g.final_score == null) ?? games[0] ?? null;
  }

  const gameId = openGame
    ? openGame.id
    : (
        await supabase
          .from('games')
          .insert({ session_id: sessionId, is_practice: sessionType === 'practice', game_number: sessionType === 'league' ? 1 : null })
          .select('id')
          .single()
      ).data?.id;

  return gameId ? `/sessions/${sessionId}/games/${gameId}` : `/sessions/${sessionId}`;
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent');

  if (intent === 'dismiss_onboarding') {
    // upsert like the settings save: a pre-trigger account has no profiles row
    await supabase.from('profiles').upsert({ id: user!.id, onboarding_dismissed: true });
    return Astro.redirect('/dashboard');
  }

  if (intent === 'start_league_night') {
    const { data: mostRecentLeague } = await supabase
      .from('sessions')
      .select('league_id, alley_name, lane_number, second_lane_number, league_team_name, default_ball_id, default_spare_ball_id')
      .eq('session_type', 'league')
      .not('league_id', 'is', null)
      .order('session_date', { ascending: false })
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    let leagueId = mostRecentLeague?.league_id ?? null;
    let teamName = mostRecentLeague?.league_team_name ?? null;
    if (!leagueId) {
      const { data: anyLeague } = await supabase
        .from('leagues')
        .select('id, team_name')
        .order('created_at', { ascending: false })
        .limit(1)
        .maybeSingle();
      leagueId = anyLeague?.id ?? null;
      teamName = anyLeague?.team_name ?? null;
    }

    if (leagueId) {
      const { data: profile } = await supabase
        .from('profiles')
        .select('default_ball_id, default_spare_ball_id')
        .eq('id', user!.id)
        .maybeSingle();

      const redirectPath = await findOrCreateOpenGame('league', leagueId, {
        user_id: user!.id,
        session_type: 'league',
        session_date: todayStr,
        league_id: leagueId,
        league_team_name: teamName,
        alley_name: mostRecentLeague?.alley_name ?? null,
        lane_number: mostRecentLeague?.lane_number ?? null,
        second_lane_number: mostRecentLeague?.second_lane_number ?? null,
        default_ball_id: mostRecentLeague?.default_ball_id ?? profile?.default_ball_id ?? null,
        default_spare_ball_id: mostRecentLeague?.default_spare_ball_id ?? profile?.default_spare_ball_id ?? null,
      });
      return Astro.redirect(redirectPath);
    }

    // No league to start a night for (shouldn't happen -- the button only
    // renders once one exists) -- fall back to the manual flow.
    return Astro.redirect('/sessions/new');
  }

  if (intent === 'start_practice') {
    const { data: mostRecentPractice } = await supabase
      .from('sessions')
      .select('alley_name, lane_number, second_lane_number, default_ball_id, default_spare_ball_id')
      .eq('session_type', 'practice')
      .order('session_date', { ascending: false })
      .order('created_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    const { data: profile } = await supabase
      .from('profiles')
      .select('default_ball_id, default_spare_ball_id')
      .eq('id', user!.id)
      .maybeSingle();

    const redirectPath = await findOrCreateOpenGame('practice', null, {
      user_id: user!.id,
      session_type: 'practice',
      session_date: todayStr,
      alley_name: mostRecentPractice?.alley_name ?? null,
      lane_number: mostRecentPractice?.lane_number ?? null,
      second_lane_number: mostRecentPractice?.second_lane_number ?? null,
      default_ball_id: mostRecentPractice?.default_ball_id ?? profile?.default_ball_id ?? null,
      default_spare_ball_id: mostRecentPractice?.default_spare_ball_id ?? profile?.default_spare_ball_id ?? null,
    });
    return Astro.redirect(redirectPath);
  }

  return Astro.redirect('/dashboard');
}

// ---- Averages + trend -------------------------------------------------------
// Same default slice as the stats page (practice sessions included, the
// Practice segment of a league night excluded).
const allGamesEver = await fetchAllGamesWithScores(supabase);
const scoredGames = filterScoredGames(allGamesEver, { includePracticeSessions: true });
const overallAverage = average(scoredGames.map((g) => g.score));

// Trend = current average vs the running average as of ~4 weeks ago. Needs at
// least one scored game on the far side of the cutoff to be meaningful.
const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 28);
const cutoffStr = cutoff.toISOString().slice(0, 10);
const gamesThen = scoredGames.filter((g) => g.sessionDate <= cutoffStr);
const averageThen = gamesThen.length < scoredGames.length ? average(gamesThen.map((g) => g.score)) : null;
const delta = overallAverage != null && averageThen != null ? overallAverage - averageThen : null;

// ---- Latest session (resume + recap) ----------------------------------------
type GameRow = {
  id: string;
  final_score: number | null;
  is_practice: boolean;
  game_number: number | null;
};
type SessionRow = {
  id: string;
  session_date: string;
  session_type: string;
  alley_name: string | null;
  leagues: { name: string } | null;
  games: GameRow[];
};

const { data: latestRows } = await supabase
  .from('sessions')
  .select('id, session_date, session_type, alley_name, leagues(name), games(id, final_score, is_practice, game_number, created_at)')
  .order('session_date', { ascending: false })
  .order('created_at', { ascending: false })
  .order('created_at', { foreignTable: 'games', ascending: true })
  .limit(1);
const latest = (latestRows?.[0] ?? null) as SessionRow | null;

const latestSheets = latest
  ? await fetchMiniScoresheets(supabase, latest.games.map((g) => g.id))
  : new Map<string, MiniSheet>();

function gameLabel(game: GameRow, index: number) {
  if (game.is_practice) return 'Practice';
  if (game.game_number != null) return `Game ${game.game_number}`;
  return `Game ${index + 1}`;
}

function sessionName(s: SessionRow) {
  return s.leagues?.name ?? s.alley_name ?? (s.session_type === 'league' ? 'League' : 'Practice');
}

// A game is done once it has a manual final score or a fully resolvable sheet.
function gameComplete(game: GameRow, sheets: Map<string, MiniSheet>) {
  if (game.final_score != null) return true;
  const sheet = sheets.get(game.id);
  return sheet != null && sheet.cells[9].cumulative != null;
}

// Resume = the earliest unfinished game of the most recent session.
const resumeIndex = latest ? latest.games.findIndex((g) => !gameComplete(g, latestSheets)) : -1;
const resumeGame = resumeIndex >= 0 ? latest!.games[resumeIndex] : null;
const resumeFrame = resumeGame ? await fetchEarliestIncompleteFrame(supabase, resumeGame.id) : null;

// ---- Last-session recap ------------------------------------------------------
// The most recent session with at least one scored game. Usually the latest
// session itself; falls back to wherever the newest score lives.
const lastScored = scoredGames.length > 0 ? scoredGames[scoredGames.length - 1] : null;
const recapSessionId = latest && latest.games.some((g) => latestSheets.get(g.id)?.cells.some((c) => c.bowled))
  ? latest.id
  : lastScored?.sessionId ?? null;

let recap: SessionRow | null = null;
let recapSheets = latestSheets;
if (recapSessionId && latest && recapSessionId === latest.id) {
  recap = latest;
} else if (recapSessionId) {
  const { data: recapRows } = await supabase
    .from('sessions')
    .select('id, session_date, session_type, alley_name, leagues(name), games(id, final_score, is_practice, game_number, created_at)')
    .eq('id', recapSessionId)
    .order('created_at', { foreignTable: 'games', ascending: true })
    .limit(1);
  recap = (recapRows?.[0] ?? null) as SessionRow | null;
  recapSheets = recap ? await fetchMiniScoresheets(supabase, recap.games.map((g) => g.id)) : new Map();
}

const scoreBySessionGame = new Map(allGamesEver.map((g) => [g.gameId, g.score]));

// Series = the session's non-practice-segment scores, like the series stats.
const recapSeries = recap
  ? recap.games
      .filter((g) => !g.is_practice)
      .map((g) => g.final_score ?? scoreBySessionGame.get(g.id) ?? null)
      .filter((s): s is number => s != null)
  : [];

const recapStrip = (gameId: string) => {
  const sheet = recapSheets.get(gameId);
  return sheet && sheet.cells.some((c) => c.bowled) ? sheet : null;
};

// ---- First-run checklist -----------------------------------------------------
// Steps auto-check off the data itself (head-only count queries); the card shows
// until every step is done or the user dismisses it for good (migration 0016).
const [{ data: onboardProfile }, { count: ballCount }, { count: leagueCount }] = await Promise.all([
  supabase.from('profiles').select('onboarding_dismissed').eq('id', user!.id).maybeSingle(),
  supabase.from('balls').select('id', { count: 'exact', head: true }),
  supabase.from('leagues').select('id', { count: 'exact', head: true }),
]);

const onboardSteps = [
  { label: 'Add a Ball', href: '/balls', done: (ballCount ?? 0) > 0 },
  { label: 'Set Up Your League', href: '/leagues', done: (leagueCount ?? 0) > 0 },
  { label: 'Start Your First Session', href: '/sessions/new', done: latest != null },
];
const showOnboarding = !onboardProfile?.onboarding_dismissed && onboardSteps.some((s) => !s.done);
---

<Layout title="Dashboard">
  <h1>Dashboard</h1>

  {showOnboarding && (
    <section class="onboard-card">
      <div class="onboard-head">
        <h2>Get Set Up</h2>
        <form method="POST">
          <input type="hidden" name="intent" value="dismiss_onboarding" />
          <button type="submit" class="onboard-dismiss" title="Dismiss" aria-label="Dismiss the setup checklist">&#x2715;</button>
        </form>
      </div>
      <ol class="onboard-steps">
        {onboardSteps.map((step, i) => (
          <li class:list={['onboard-step', { done: step.done }]}>
            <span class="onboard-mark" aria-hidden="true">{step.done ? '✓' : i + 1}</span>
            {step.done ? (
              <span class="onboard-label">{step.label}</span>
            ) : (
              <a class="onboard-label" href={step.href}>{step.label} &rarr;</a>
            )}
          </li>
        ))}
      </ol>
    </section>
  )}

  {!resumeGame && recap && (
    <div class="dash-start-row">
      {(leagueCount ?? 0) > 0 && (
        <form method="POST" class="dash-start-form">
          <input type="hidden" name="intent" value="start_league_night" />
          <button type="submit" class="button dash-start">🎳 Start League Night</button>
        </form>
      )}
      <form method="POST" class="dash-start-form">
        <input type="hidden" name="intent" value="start_practice" />
        <button type="submit" class:list={['button', 'dash-start', { secondary: (leagueCount ?? 0) > 0 }]}>🎯 Start Practice</button>
      </form>
    </div>
  )}

  {resumeGame && latest && (
    <a class="resume-tile" href={`/sessions/${latest.id}/games/${resumeGame.id}`}>
      <span class="resume-kicker">{latest.session_date === todayStr ? 'Continue Tonight' : 'Pick Up Where You Left Off'}</span>
      <span class="resume-line">
        {sessionName(latest)} · {gameLabel(resumeGame, resumeIndex)}, Frame {resumeFrame}
      </span>
      <span class="resume-meta">{latest.session_date === todayStr ? 'Tonight' : latest.session_date} →</span>
    </a>
  )}

  <div class="dash-hero">
    <span class="dash-label">Current Average</span>
    <span class="dash-value">{overallAverage != null ? overallAverage.toFixed(1) : '—'}</span>
    {delta != null && (
      <span class:list={['dash-delta', Math.abs(delta) < 0.05 ? 'steady' : delta > 0 ? 'up' : 'down']}>
        {Math.abs(delta) < 0.05 ? '— steady' : `${delta > 0 ? '▲' : '▼'} ${delta > 0 ? '+' : '−'}${Math.abs(delta).toFixed(1)}`} vs 4 weeks ago
      </span>
    )}
  </div>

  {recap ? (
    <section class="dash-recap">
      <div class="recap-head">
        <h2>{recap.session_date === todayStr ? 'Tonight So Far' : 'Last Session'}</h2>
        <a href={`/sessions/${recap.id}`}>View Session →</a>
      </div>
      <p class="recap-meta">
        {recap.session_date} · {sessionName(recap)}
        {recapSeries.length > 1 ? ` · Series ${recapSeries.reduce((a, b) => a + b, 0)} (${recapSeries.length} games)` : ''}
      </p>
      {recap.games.map((game, i) => {
        const sheet = recapStrip(game.id);
        if (!sheet) return null;
        const score = game.final_score ?? scoreBySessionGame.get(game.id) ?? null;
        return (
          <div class="recap-game">
            <div class="recap-game-head">
              <span>{gameLabel(game, i)}</span>
              <b>{score ?? 'In Progress'}</b>
            </div>
            <MiniScoresheet cells={sheet.cells} pinfall={sheet.pinfall} label={gameLabel(game, i)} />
          </div>
        );
      })}
    </section>
  ) : (
    // the checklist's step 3 already points at /sessions/new — don't say it twice
    !showOnboarding && (
      <p class="empty">No sessions yet — <a href="/sessions/new">start a session</a> to see your scores here.</p>
    )
  )}


</Layout>

<style>
  .onboard-card {
    margin-top: var(--s4);
    padding: var(--s4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .onboard-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
  }
  .onboard-head h2 { margin: 0; font-size: var(--text-base); }
  .onboard-head form { margin: 0; }
  .onboard-dismiss {
    padding: 0 var(--s1);
    background: none;
    border: none;
    box-shadow: none;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1;
    cursor: pointer;
  }
  .onboard-dismiss:hover { color: var(--text-primary); }
  .onboard-steps {
    list-style: none;
    margin: var(--s3) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }
  .onboard-step {
    display: flex;
    align-items: center;
    gap: var(--s3);
  }
  .onboard-mark {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    font-size: var(--text-xs);
    font-weight: var(--fw-semi);
    color: var(--text-secondary);
    font-variant-numeric: tabular-nums;
  }
  .onboard-step.done .onboard-mark {
    border-color: var(--good);
    color: var(--good);
  }
  .onboard-label { font-size: var(--text-sm); font-weight: var(--fw-semi); }
  .onboard-step.done .onboard-label { color: var(--text-muted); font-weight: normal; }

  .resume-tile {
    display: flex;
    flex-direction: column;
    gap: var(--s1);
    margin-top: var(--s4);
    padding: var(--s4);
    background: var(--accent);
    color: var(--accent-ink);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .resume-tile:hover { text-decoration: none; filter: brightness(1.05); }
  .resume-kicker {
    font-size: var(--text-xs);
    font-weight: var(--fw-semi);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }
  .resume-line { font-size: var(--text-lg); font-weight: var(--fw-semi); }
  .resume-meta { font-size: var(--text-sm); opacity: 0.85; }

  .dash-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s1);
    margin-top: var(--s4);
    padding: var(--s5) var(--s4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .dash-label { font-size: var(--text-sm); color: var(--text-secondary); }
  /* Hero figure: display-size, proportional digits (tabular reads loose here). */
  .dash-value {
    font-size: 3rem;
    line-height: 1;
    font-weight: var(--fw-semi);
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }
  .dash-delta { font-size: var(--text-sm); font-weight: var(--fw-semi); }
  .dash-delta.up { color: var(--good); }
  .dash-delta.down { color: var(--coral); }
  .dash-delta.steady { color: var(--text-muted); }

  .dash-recap {
    margin-top: var(--s4);
    padding: var(--s4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .recap-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
  }
  .recap-head h2 { margin: 0; font-size: var(--text-base); }
  .recap-head a { font-size: var(--text-sm); white-space: nowrap; }
  .recap-meta { margin: var(--s1) 0 0; font-size: var(--text-sm); color: var(--text-muted); }
  .recap-game { margin-top: var(--s3); }
  .recap-game-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .recap-game-head b {
    font-size: var(--text-base);
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }

  .dash-start-row {
    display: flex;
    gap: var(--s3);
    margin-top: var(--s4);
  }
  .dash-start-form { flex: 1; margin: 0; }
  .dash-start { display: block; width: 100%; text-align: center; margin: 0; }
</style>
