---
import Layout from '../layouts/Layout.astro';
import MiniScoresheet from '../components/MiniScoresheet.astro';
import { fetchMiniScoresheets, fetchEarliestIncompleteFrame, type MiniSheet } from '../lib/scoring';
import { fetchAllGamesWithScores, filterScoredGames, average } from '../lib/stats';

const { supabase } = Astro.locals;

// ---- Averages + trend -------------------------------------------------------
// Same default slice as the stats page (practice sessions included, the
// Practice segment of a league night excluded).
const allGamesEver = await fetchAllGamesWithScores(supabase);
const scoredGames = filterScoredGames(allGamesEver, { includePracticeSessions: true });
const overallAverage = average(scoredGames.map((g) => g.score));

// Trend = current average vs the running average as of ~4 weeks ago. Needs at
// least one scored game on the far side of the cutoff to be meaningful.
const cutoff = new Date();
cutoff.setDate(cutoff.getDate() - 28);
const cutoffStr = cutoff.toISOString().slice(0, 10);
const gamesThen = scoredGames.filter((g) => g.sessionDate <= cutoffStr);
const averageThen = gamesThen.length < scoredGames.length ? average(gamesThen.map((g) => g.score)) : null;
const delta = overallAverage != null && averageThen != null ? overallAverage - averageThen : null;

// ---- Latest session (resume + recap) ----------------------------------------
type GameRow = {
  id: string;
  final_score: number | null;
  is_practice: boolean;
  game_number: number | null;
};
type SessionRow = {
  id: string;
  session_date: string;
  session_type: string;
  alley_name: string | null;
  leagues: { name: string } | null;
  games: GameRow[];
};

const { data: latestRows } = await supabase
  .from('sessions')
  .select('id, session_date, session_type, alley_name, leagues(name), games(id, final_score, is_practice, game_number, created_at)')
  .order('session_date', { ascending: false })
  .order('created_at', { ascending: false })
  .order('created_at', { foreignTable: 'games', ascending: true })
  .limit(1);
const latest = (latestRows?.[0] ?? null) as SessionRow | null;

const latestSheets = latest
  ? await fetchMiniScoresheets(supabase, latest.games.map((g) => g.id))
  : new Map<string, MiniSheet>();

function gameLabel(game: GameRow, index: number) {
  if (game.is_practice) return 'Practice';
  if (game.game_number != null) return `Game ${game.game_number}`;
  return `Game ${index + 1}`;
}

function sessionName(s: SessionRow) {
  return s.leagues?.name ?? s.alley_name ?? (s.session_type === 'league' ? 'League' : 'Practice');
}

// A game is done once it has a manual final score or a fully resolvable sheet.
function gameComplete(game: GameRow, sheets: Map<string, MiniSheet>) {
  if (game.final_score != null) return true;
  const sheet = sheets.get(game.id);
  return sheet != null && sheet.cells[9].cumulative != null;
}

// Resume = the earliest unfinished game of the most recent session.
const resumeIndex = latest ? latest.games.findIndex((g) => !gameComplete(g, latestSheets)) : -1;
const resumeGame = resumeIndex >= 0 ? latest!.games[resumeIndex] : null;
const resumeFrame = resumeGame ? await fetchEarliestIncompleteFrame(supabase, resumeGame.id) : null;

const todayStr = new Date().toISOString().slice(0, 10);

// ---- Last-session recap ------------------------------------------------------
// The most recent session with at least one scored game. Usually the latest
// session itself; falls back to wherever the newest score lives.
const lastScored = scoredGames.length > 0 ? scoredGames[scoredGames.length - 1] : null;
const recapSessionId = latest && latest.games.some((g) => latestSheets.get(g.id)?.cells.some((c) => c.bowled))
  ? latest.id
  : lastScored?.sessionId ?? null;

let recap: SessionRow | null = null;
let recapSheets = latestSheets;
if (recapSessionId && latest && recapSessionId === latest.id) {
  recap = latest;
} else if (recapSessionId) {
  const { data: recapRows } = await supabase
    .from('sessions')
    .select('id, session_date, session_type, alley_name, leagues(name), games(id, final_score, is_practice, game_number, created_at)')
    .eq('id', recapSessionId)
    .order('created_at', { foreignTable: 'games', ascending: true })
    .limit(1);
  recap = (recapRows?.[0] ?? null) as SessionRow | null;
  recapSheets = recap ? await fetchMiniScoresheets(supabase, recap.games.map((g) => g.id)) : new Map();
}

const scoreBySessionGame = new Map(allGamesEver.map((g) => [g.gameId, g.score]));

// Series = the session's non-practice-segment scores, like the series stats.
const recapSeries = recap
  ? recap.games
      .filter((g) => !g.is_practice)
      .map((g) => g.final_score ?? scoreBySessionGame.get(g.id) ?? null)
      .filter((s): s is number => s != null)
  : [];

const recapStrip = (gameId: string) => {
  const sheet = recapSheets.get(gameId);
  return sheet && sheet.cells.some((c) => c.bowled) ? sheet : null;
};
---

<Layout title="Dashboard">
  <h1>Dashboard</h1>

  {resumeGame && latest && (
    <a class="resume-tile" href={`/sessions/${latest.id}/games/${resumeGame.id}`}>
      <span class="resume-kicker">{latest.session_date === todayStr ? 'Continue Tonight' : 'Pick Up Where You Left Off'}</span>
      <span class="resume-line">
        {sessionName(latest)} · {gameLabel(resumeGame, resumeIndex)}, Frame {resumeFrame}
      </span>
      <span class="resume-meta">{latest.session_date === todayStr ? 'Tonight' : latest.session_date} →</span>
    </a>
  )}

  <div class="dash-hero">
    <span class="dash-label">Current Average</span>
    <span class="dash-value">{overallAverage != null ? overallAverage.toFixed(1) : '—'}</span>
    {delta != null && (
      <span class:list={['dash-delta', Math.abs(delta) < 0.05 ? 'steady' : delta > 0 ? 'up' : 'down']}>
        {Math.abs(delta) < 0.05 ? '— steady' : `${delta > 0 ? '▲' : '▼'} ${delta > 0 ? '+' : '−'}${Math.abs(delta).toFixed(1)}`} vs 4 weeks ago
      </span>
    )}
  </div>

  {recap ? (
    <section class="dash-recap">
      <div class="recap-head">
        <h2>{recap.session_date === todayStr ? 'Tonight So Far' : 'Last Session'}</h2>
        <a href={`/sessions/${recap.id}`}>View Session →</a>
      </div>
      <p class="recap-meta">
        {recap.session_date} · {sessionName(recap)}
        {recapSeries.length > 1 ? ` · Series ${recapSeries.reduce((a, b) => a + b, 0)} (${recapSeries.length} games)` : ''}
      </p>
      {recap.games.map((game, i) => {
        const sheet = recapStrip(game.id);
        if (!sheet) return null;
        const score = game.final_score ?? scoreBySessionGame.get(game.id) ?? null;
        return (
          <div class="recap-game">
            <div class="recap-game-head">
              <span>{gameLabel(game, i)}</span>
              <b>{score ?? 'In Progress'}</b>
            </div>
            <MiniScoresheet cells={sheet.cells} pinfall={sheet.pinfall} label={gameLabel(game, i)} />
          </div>
        );
      })}
    </section>
  ) : (
    <p class="empty">No sessions yet — <a href="/sessions/new">Start Your First Session</a> to see your scores here.</p>
  )}

  {!resumeGame && recap && (
    <a class="button dash-start" href="/sessions/new">+ Start a Session</a>
  )}
</Layout>

<style>
  .resume-tile {
    display: flex;
    flex-direction: column;
    gap: var(--s1);
    margin-top: var(--s4);
    padding: var(--s4);
    background: var(--accent);
    color: var(--accent-ink);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .resume-tile:hover { text-decoration: none; filter: brightness(1.05); }
  .resume-kicker {
    font-size: var(--text-xs);
    font-weight: var(--fw-semi);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }
  .resume-line { font-size: var(--text-lg); font-weight: var(--fw-semi); }
  .resume-meta { font-size: var(--text-sm); opacity: 0.85; }

  .dash-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--s1);
    margin-top: var(--s4);
    padding: var(--s5) var(--s4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .dash-label { font-size: var(--text-sm); color: var(--text-secondary); }
  /* Hero figure: display-size, proportional digits (tabular reads loose here). */
  .dash-value {
    font-size: 3rem;
    line-height: 1;
    font-weight: var(--fw-semi);
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }
  .dash-delta { font-size: var(--text-sm); font-weight: var(--fw-semi); }
  .dash-delta.up { color: var(--good); }
  .dash-delta.down { color: var(--coral); }
  .dash-delta.steady { color: var(--text-muted); }

  .dash-recap {
    margin-top: var(--s4);
    padding: var(--s4);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }
  .recap-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
  }
  .recap-head h2 { margin: 0; font-size: var(--text-base); }
  .recap-head a { font-size: var(--text-sm); white-space: nowrap; }
  .recap-meta { margin: var(--s1) 0 0; font-size: var(--text-sm); color: var(--text-muted); }
  .recap-game { margin-top: var(--s3); }
  .recap-game-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .recap-game-head b {
    font-size: var(--text-base);
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }

  .dash-start { display: block; margin-top: var(--s4); text-align: center; }
</style>
