---
import Layout from '../../layouts/Layout.astro';

const { supabase } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete') {
    const { error: deleteError } = await supabase.from('balls').delete().eq('id', id);
    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/balls');
    }
  } else {
    const name = formData.get('name')?.toString().trim() ?? '';
    const brand_model = formData.get('brand_model')?.toString().trim() || null;
    const weightRaw = formData.get('weight')?.toString().trim();
    const weight = weightRaw ? Number(weightRaw) : null;
    const notes = formData.get('notes')?.toString().trim() || null;
    const layout_notes = formData.get('layout_notes')?.toString().trim() || null;

    if (!name) {
      error = 'Ball name is required.';
    } else {
      const { error: updateError } = await supabase
        .from('balls')
        .update({ name, brand_model, weight, notes, layout_notes })
        .eq('id', id);

      if (updateError) {
        error = updateError.message;
      } else {
        return Astro.redirect('/balls');
      }
    }
  }
}

const { data: ball } = await supabase.from('balls').select('*').eq('id', id).maybeSingle();

if (!ball) {
  return Astro.redirect('/balls');
}
---

<Layout title={ball.name}>
  <nav class="top"><a href="/balls">&larr; My Balls</a></nav>
  <h1>Edit Ball</h1>

  {error && <p class="error">{error}</p>}

  <form method="POST">
    <label>
      Name
      <input type="text" name="name" required value={ball.name} />
    </label>
    <label>
      Brand / Model
      <input type="text" name="brand_model" value={ball.brand_model ?? ''} />
    </label>
    <label>
      Weight (lb)
      <input type="number" name="weight" step="0.1" min="6" max="16" value={ball.weight ?? ''} />
    </label>
    <label>
      Layout Notes
      <textarea name="layout_notes" rows="3">{ball.layout_notes ?? ''}</textarea>
    </label>
    <label>
      General Notes
      <textarea name="notes" rows="3">{ball.notes ?? ''}</textarea>
    </label>
    <button type="submit">Save Changes</button>
  </form>

  <form method="POST" class="row-actions">
    <input type="hidden" name="intent" value="delete" />
    <button type="submit" class="danger">Delete Ball</button>
  </form>
</Layout>
