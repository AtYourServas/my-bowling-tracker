---
import Layout from '../../layouts/Layout.astro';
import { fetchStatFrames, computeBallDetail } from '../../lib/stats';

const { supabase } = Astro.locals;
const { id } = Astro.params;

let error: string | null = null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const intent = formData.get('intent')?.toString();

  if (intent === 'delete') {
    const { error: deleteError } = await supabase.from('balls').delete().eq('id', id);
    if (deleteError) {
      error = deleteError.message;
    } else {
      return Astro.redirect('/balls');
    }
  } else {
    const name = formData.get('name')?.toString().trim() ?? '';
    const brand_model = formData.get('brand_model')?.toString().trim() || null;
    const weightRaw = formData.get('weight')?.toString().trim();
    const weight = weightRaw ? Number(weightRaw) : null;
    const notes = formData.get('notes')?.toString().trim() || null;
    const layout_notes = formData.get('layout_notes')?.toString().trim() || null;

    if (!name) {
      error = 'Ball name is required.';
    } else {
      const { error: updateError } = await supabase
        .from('balls')
        .update({ name, brand_model, weight, notes, layout_notes })
        .eq('id', id);

      if (updateError) {
        error = updateError.message;
      } else {
        return Astro.redirect('/balls');
      }
    }
  }
}

const { data: ball } = await supabase.from('balls').select('*').eq('id', id).maybeSingle();

if (!ball) {
  return Astro.redirect('/balls');
}

// "Is this ball working?" — same slice as the stats page default (practice
// sessions included, the Practice segment of a league night excluded).
const statFrames = await fetchStatFrames(supabase);
const detail = computeBallDetail(statFrames, { includePracticeSessions: true }, id!);

// Same wording as the stats page's Average Drift tile (StatsCharts.formatDrift).
function formatDrift(boards: number): string {
  const abs = Math.abs(boards);
  if (abs < 0.05) return 'Straight';
  const unit = abs.toFixed(1) === '1.0' ? 'board' : 'boards';
  return `${abs.toFixed(1)} ${unit} ${boards > 0 ? 'right' : 'left'}`;
}
---

<Layout title={ball.name}>
  <nav class="top"><a href="/balls">&larr; My Balls</a></nav>
  <h1>{ball.name}</h1>
  {ball.brand_model && <p class="meta">{ball.brand_model}{ball.weight ? ` · ${ball.weight} lb` : ''}</p>}

  {error && <p class="error">{error}</p>}

  <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Ball Performance</h2></div>
  {detail ? (
    <>
      <div class="rate-grid">
        <div class="rate-stat">
          <span class="rate-label">First-Ball Carry</span>
          <span class="rate-value">{detail.carryAvg != null ? detail.carryAvg.toFixed(1) : '—'}</span>
          <span class="rate-sub">
            {detail.carryShots > 0
              ? `avg pins · ${detail.carryShots} fresh-rack shot${detail.carryShots === 1 ? '' : 's'}`
              : 'No fresh-rack shots yet'}
          </span>
        </div>
        <div class="rate-stat">
          <span class="rate-label">Games Used</span>
          <span class="rate-value">{detail.gamesUsed}</span>
          <span class="rate-sub">{detail.totalShots} shot{detail.totalShots === 1 ? '' : 's'} logged</span>
        </div>
        <div class="rate-stat">
          <span class="rate-label">Avg Drift</span>
          <span class="rate-value">{detail.driftAvg != null ? formatDrift(detail.driftAvg) : '—'}</span>
          <span class="rate-sub">
            {detail.driftShots > 0
              ? `${detail.driftShots} shot${detail.driftShots === 1 ? '' : 's'} with both marks`
              : 'No stance + slide marks yet'}
          </span>
        </div>
      </div>
      <p class="empty">Counts every logged shot with this ball; practice sessions included, the practice segment of a league night excluded.</p>
    </>
  ) : (
    <p class="empty">No shots logged with this ball yet — its stats will appear once you bowl with it.</p>
  )}

  <div class="sechead"><span class="chev"><i></i><i></i><i></i></span><h2>Edit Ball</h2></div>

  <form method="POST">
    <label>
      Name
      <input type="text" name="name" required value={ball.name} />
    </label>
    <label>
      Brand / Model
      <input type="text" name="brand_model" value={ball.brand_model ?? ''} />
    </label>
    <label>
      Weight (lb)
      <input type="number" name="weight" step="0.1" min="6" max="16" value={ball.weight ?? ''} />
    </label>
    <label>
      Layout Notes
      <textarea name="layout_notes" rows="3">{ball.layout_notes ?? ''}</textarea>
    </label>
    <label>
      General Notes
      <textarea name="notes" rows="3">{ball.notes ?? ''}</textarea>
    </label>
    <button type="submit">Save Changes</button>
  </form>

  <form method="POST" class="row-actions">
    <input type="hidden" name="intent" value="delete" />
    <button type="submit" class="danger">Delete Ball</button>
  </form>
</Layout>
