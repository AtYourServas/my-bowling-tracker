---
import Layout from '../layouts/Layout.astro';
import NoteCard from '../components/NoteCard.astro';
import { fetchAllNotes, fetchLeaveNotes, leaveAnchor } from '../lib/notes';

const { supabase } = Astro.locals;

const params = Astro.url.searchParams;
const view = params.get('view') === 'leave' ? 'leave' : 'session';
const filterLeague = params.get('league') ?? '';
const filterSession = params.get('session') ?? '';
const filterAlley = params.get('alley') ?? '';
const filterBall = params.get('ball') ?? '';
const filterFrom = params.get('from') ?? '';
const filterTo = params.get('to') ?? '';
const hasFilters = view === 'session'
  ? Boolean(filterLeague || filterSession || filterAlley || filterBall)
  : Boolean(filterLeague || filterFrom || filterTo);

// By-session view groups notes under their session (league / session / alley /
// ball filters); by-leave groups every note under the leave its ball faced,
// across sessions (league / date-range filters).
const groups = view === 'session'
  ? await fetchAllNotes(supabase, {
      leagueId: filterLeague || undefined,
      sessionId: filterSession || undefined,
      alley: filterAlley || undefined,
      ballId: filterBall || undefined,
    })
  : [];
const leaveGroups = view === 'leave'
  ? await fetchLeaveNotes(supabase, {
      leagueId: filterLeague || undefined,
      from: filterFrom || undefined,
      to: filterTo || undefined,
    })
  : [];

// Filter dropdown options.
const { data: leagues } = await supabase.from('leagues').select('id, name').order('name');
const { data: balls } = await supabase.from('balls').select('id, name').order('name');
const { data: sessionRows } = await supabase
  .from('sessions')
  .select('id, alley_name, session_date')
  .order('session_date', { ascending: false });
// Distinct alley names, for the alley filter dropdown.
const alleys = [...new Set((sessionRows ?? []).map((s) => s.alley_name).filter(Boolean))].sort();

const noteCount = view === 'session'
  ? groups.reduce((n, g) => n + g.entries.length, 0)
  : leaveGroups.reduce((n, g) => n + g.notes.length, 0);
const groupCount = view === 'session' ? groups.length : leaveGroups.length;
const groupNoun = view === 'session' ? 'session' : 'leave';

const sessionLabel = (s: { alley_name: string | null; session_date: string | null }) =>
  `${s.session_date ?? ''}${s.alley_name ? ` · ${s.alley_name}` : ''}`.trim();

const groupHeading = (g: (typeof groups)[number]['session']) =>
  [g.date, g.alley || 'Unnamed alley', g.league].filter(Boolean).join(' · ');
---

<Layout title="Notes">
  <nav class="top"><a href="/dashboard">&larr; Dashboard</a></nav>
  <h1>Notes</h1>
  <p class="meta">{noteCount} note{noteCount === 1 ? '' : 's'} across {groupCount} {groupNoun}{groupCount === 1 ? '' : 's'}</p>

  <div class="entry-toggle" role="group" aria-label="Group notes by">
    <a class:list={['seg', { active: view === 'session' }]} href="/notes" aria-current={view === 'session' ? 'true' : undefined}>By Session</a>
    <a class:list={['seg', { active: view === 'leave' }]} href="/notes?view=leave" aria-current={view === 'leave' ? 'true' : undefined}>By Leave</a>
  </div>

  {view === 'session' ? (
    <form method="GET" class="filter-form">
      <label>
        League
        <select name="league">
          <option value="">All</option>
          {leagues?.map((l) => (
            <option value={l.id} selected={l.id === filterLeague}>{l.name}</option>
          ))}
        </select>
      </label>
      <label>
        Session
        <select name="session">
          <option value="">All</option>
          {sessionRows?.map((s) => (
            <option value={s.id} selected={s.id === filterSession}>{sessionLabel(s)}</option>
          ))}
        </select>
      </label>
      {alleys.length > 0 && (
        <label>
          Alley
          <select name="alley">
            <option value="">All</option>
            {alleys.map((a) => (
              <option value={a} selected={a === filterAlley}>{a}</option>
            ))}
          </select>
        </label>
      )}
      {balls && balls.length > 0 && (
        <label>
          Ball
          <select name="ball">
            <option value="">All</option>
            {balls.map((b) => (
              <option value={b.id} selected={b.id === filterBall}>{b.name}</option>
            ))}
          </select>
        </label>
      )}
      <button type="submit">Filter</button>
      {hasFilters && <a href="/notes">Clear Filters</a>}
    </form>
  ) : (
    <form method="GET" class="filter-form">
      <input type="hidden" name="view" value="leave" />
      <label class="wide">
        League
        <select name="league">
          <option value="">All</option>
          {leagues?.map((l) => (
            <option value={l.id} selected={l.id === filterLeague}>{l.name}</option>
          ))}
        </select>
      </label>
      <label>
        From
        <input type="date" name="from" value={filterFrom} />
      </label>
      <label>
        To
        <input type="date" name="to" value={filterTo} />
      </label>
      <button type="submit">Filter</button>
      {hasFilters && <a href="/notes?view=leave">Clear Filters</a>}
    </form>
  )}

  {view === 'session' ? (
    groups.length > 0 ? (
      <div class="note-groups">
        {groups.map((group) => (
          <section class="note-group">
            <div class="group-head">
              <a href={`/sessions/${group.session.id}#notes`}>{groupHeading(group.session)} &rarr;</a>
            </div>
            <ul class="note-stream">
              {group.entries.map((note) => (
                <li><NoteCard note={note} /></li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    ) : (
      <p class="empty">
        {hasFilters ? 'No notes match those filters.' : 'No notes yet — jot one while bowling or on any session.'}
      </p>
    )
  ) : (
    leaveGroups.length > 0 ? (
      <div class="note-groups">
        {leaveGroups.map((group) => (
          <section class="note-group" id={leaveAnchor(group.leave)}>
            <div class="group-head">
              <span class="leave-title">{group.name}</span>
              <span class="leave-count">{group.notes.length} note{group.notes.length === 1 ? '' : 's'}</span>
            </div>
            <ul class="note-stream">
              {group.notes.map((note) => (
                <li><NoteCard note={note} /></li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    ) : (
      <p class="empty">No leave notes yet — notes you attach to a shot with pins standing show up here, grouped by leave.</p>
    )
  )}
</Layout>

<style>
  .filter-form label.wide {
    grid-column: span 2;
  }
  .note-groups {
    display: grid;
    gap: 1.5rem;
  }
  .group-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--border);
  }
  .group-head a {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .leave-title {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .leave-count {
    font-size: var(--text-sm);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .note-stream {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
</style>
